@echo off
setlocal EnableExtensions DisableDelayedExpansion

set "DO_BUILD=1"
set "REPO_ROOT="

if /I "%~1"=="--help" goto help
if /I "%~1"=="-h" goto help
if /I "%~1"=="--no-build" set "DO_BUILD=0"

if exist "%~dp0CMakeLists.txt" if exist "%~dp0src\GPU_Vulkan.cpp" set "REPO_ROOT=%~dp0"
if not defined REPO_ROOT if exist "%CD%\CMakeLists.txt" if exist "%CD%\src\GPU_Vulkan.cpp" set "REPO_ROOT=%CD%"
if not defined REPO_ROOT if exist "C:\Users\Admin\Documents\git\melonPrimeDS\CMakeLists.txt" set "REPO_ROOT=C:\Users\Admin\Documents\git\melonPrimeDS"

if not defined REPO_ROOT (
    echo [structural-3d-slot] ERROR: melonPrimeDS repository was not found.
    echo [structural-3d-slot] Place this BAT in the repository root.
    pause
    exit /b 2
)

for %%I in ("%REPO_ROOT%\.") do set "REPO_ROOT=%%~fI"
if "%REPO_ROOT:~-1%"=="\" set "REPO_ROOT=%REPO_ROOT:~0,-1%"

echo ============================================================
echo  MelonPrimeDS Vulkan - Native 3D Slot Authority Next Step
echo ============================================================
echo Repository: %REPO_ROOT%
echo.
echo Tracks BG0/3D's structural 2D slot independently from the
echo Software 3D center sample, enabling native Vulkan high-res
echo subpixel coverage and one foreground alpha-blend layer.
echo.

set "SELF_BAT=%~f0"
set "PATCH_PS1=%TEMP%\melonprime_native_3d_slot_%RANDOM%_%RANDOM%.ps1"

powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -Command ^
  "$raw=[IO.File]::ReadAllText($env:SELF_BAT); $marker='__POWERSHELL_PAYLOAD__'; $index=$raw.LastIndexOf($marker,[StringComparison]::Ordinal); if($index -lt 0){Write-Error 'Embedded payload marker is missing.';exit 3}; $b64=$raw.Substring($index+$marker.Length).Trim(); try{$bytes=[Convert]::FromBase64String($b64)}catch{Write-Error ('Embedded payload is invalid: '+$_.Exception.Message);exit 3}; [IO.File]::WriteAllBytes($env:PATCH_PS1,$bytes)"
if errorlevel 1 (
    echo [structural-3d-slot] ERROR: Could not extract patch payload.
    pause
    exit /b 3
)

powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass ^
  -File "%PATCH_PS1%" -RepoRoot "%REPO_ROOT%"
set "PATCH_RESULT=%ERRORLEVEL%"
del /q "%PATCH_PS1%" >nul 2>&1

if not "%PATCH_RESULT%"=="0" (
    echo.
    echo [structural-3d-slot] Patch failed. Original files were restored.
    pause
    exit /b %PATCH_RESULT%
)

where git.exe >nul 2>&1
if not errorlevel 1 (
    pushd "%REPO_ROOT%"
    git diff --check
    if errorlevel 1 (
        popd
        echo [structural-3d-slot] ERROR: git diff --check failed.
        echo [structural-3d-slot] Source patch remains applied.
        pause
        exit /b 4
    )
    echo.
    git diff --stat -- src/GPU_Soft.h src/GPU2D_Soft.h src/GPU2D_Soft.cpp src/GPU_Vulkan.h src/Vulkan_shaders/phase10_presenter.frag
    popd
)

if "%DO_BUILD%"=="0" (
    echo.
    echo [structural-3d-slot] Patch applied. Build was skipped.
    echo [structural-3d-slot] Run .claude\skills\build-mingw-vulkan.bat next.
    pause
    exit /b 0
)

set "BUILD_SCRIPT=%REPO_ROOT%\.claude\skills\build-mingw-vulkan.bat"
if not exist "%BUILD_SCRIPT%" (
    echo [structural-3d-slot] ERROR: Build script is missing:
    echo   %BUILD_SCRIPT%
    echo [structural-3d-slot] Source patch remains applied.
    pause
    exit /b 5
)

echo.
echo [structural-3d-slot] Regenerating SPIR-V and rebuilding Vulkan...
call "%BUILD_SCRIPT%"
set "BUILD_RESULT=%ERRORLEVEL%"

if not "%BUILD_RESULT%"=="0" (
    echo.
    echo [structural-3d-slot] ERROR: Vulkan build failed with exit code %BUILD_RESULT%.
    echo [structural-3d-slot] Source patch remains applied; backup path was printed above.
    pause
    exit /b %BUILD_RESULT%
)

echo.
echo ============================================================
echo  SUCCESS
echo ============================================================
echo Native Vulkan 3D now owns exposed structural BG0/3D slots,
echo including high-resolution subpixel coverage and a single
echo alpha-blended 2D foreground layer.
echo.
echo NativeVulkan3DImplemented remains false until the remaining
echo full 2D stack and display-capture dependencies are removed.
echo.
pause
exit /b 0

:help
echo Place this BAT in the melonPrimeDS repository root.
echo.
echo Usage:
echo   %~nx0
echo   %~nx0 --no-build
echo.
echo Requirements:
echo   - Structured 3D Composition v4 applied
echo   - Structured 3D Build Fix v5 applied
echo.
echo This patch:
echo   - backs up five affected source files
echo   - tracks BG0/3D even when Software 3D alpha is zero
echo   - adopts native high-resolution subpixel coverage
echo   - supports one alpha-blended 2D foreground layer
echo   - regenerates SPIR-V and rebuilds the Windows Vulkan target
exit /b 0

