+static inline float3 mp_apply_master_brightness(float3 color, uint reg)
+{
+    uint mode = reg >> 14;
+    float factor = float(min(reg & 0x1Fu, 16u)) / 16.0;
+    if (mode == 1u)
+        return mix(color, float3(1.0), factor);
+    if (mode == 2u)
+        return color * (1.0 - factor);
+    return color;
+}
 
