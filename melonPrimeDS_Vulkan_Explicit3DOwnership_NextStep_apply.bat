@echo off
setlocal EnableExtensions DisableDelayedExpansion

set "DO_BUILD=1"
set "REPO_ROOT="

:parse_args
if "%~1"=="" goto resolve_repo
if /I "%~1"=="--help" goto help
if /I "%~1"=="-h" goto help
if /I "%~1"=="--no-build" (
    set "DO_BUILD=0"
    shift
    goto parse_args
)
if /I "%~1"=="--repo" (
    if "%~2"=="" (
        echo [explicit-ownership] ERROR: --repo requires a path.
        exit /b 2
    )
    set "REPO_ROOT=%~f2"
    shift
    shift
    goto parse_args
)
if exist "%~f1\CMakeLists.txt" (
    set "REPO_ROOT=%~f1"
    shift
    goto parse_args
)
echo [explicit-ownership] ERROR: Unknown argument: %~1
goto help_error

:resolve_repo
if defined REPO_ROOT goto verify_repo

call :try_repo "%CD%"
if defined REPO_ROOT goto verify_repo
call :try_repo "%~dp0"
if defined REPO_ROOT goto verify_repo
call :try_repo "%USERPROFILE%\git\melonPrimeDS"
if defined REPO_ROOT goto verify_repo
call :try_repo "%USERPROFILE%\Documents\GitHub\melonPrimeDS"
if defined REPO_ROOT goto verify_repo
call :try_repo "%USERPROFILE%\source\repos\melonPrimeDS"
if defined REPO_ROOT goto verify_repo

echo [explicit-ownership] ERROR: melonPrimeDS repository was not found.
echo [explicit-ownership] Run:
echo [explicit-ownership]   %~nx0 --repo C:\path\to\melonPrimeDS
exit /b 2

:try_repo
if exist "%~f1\CMakeLists.txt" (
    if exist "%~f1\src\GPU_Vulkan.cpp" set "REPO_ROOT=%~f1"
)
exit /b 0

:verify_repo
if not exist "%REPO_ROOT%\src\GPU_Vulkan.cpp" (
    echo [explicit-ownership] ERROR: Invalid repository: %REPO_ROOT%
    exit /b 2
)
if not exist "%REPO_ROOT%\src\Vulkan_shaders\phase10_presenter.frag" (
    echo [explicit-ownership] ERROR: Current Vulkan native-raster files are missing.
    exit /b 2
)

echo [explicit-ownership] Repository: %REPO_ROOT%
echo [explicit-ownership] Goal: replace opaque RGB ownership heuristics with
echo [explicit-ownership]       an explicit Software-2D structural 3D ownership mask.

set "PAYLOAD_LINE="
for /f "tokens=1 delims=:" %%N in ('findstr /n /x /c:"__POWERSHELL_PAYLOAD__" "%~f0"') do set "PAYLOAD_LINE=%%N"
if not defined PAYLOAD_LINE (
    echo [explicit-ownership] ERROR: Embedded payload marker is missing.
    exit /b 3
)

set "PATCH_PS1=%TEMP%\melonprime_vulkan_explicit_ownership_%RANDOM%_%RANDOM%.ps1"
powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -Command ^
  "$lines = Get-Content -LiteralPath '%~f0'; $b64 = ($lines | Select-Object -Skip %PAYLOAD_LINE%) -join ''; [IO.File]::WriteAllBytes('%PATCH_PS1%', [Convert]::FromBase64String($b64))"
if errorlevel 1 (
    echo [explicit-ownership] ERROR: Could not extract embedded PowerShell patch.
    exit /b 3
)

powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File "%PATCH_PS1%" -RepoRoot "%REPO_ROOT%"
set "PATCH_RESULT=%ERRORLEVEL%"
del /q "%PATCH_PS1%" >nul 2>&1
if not "%PATCH_RESULT%"=="0" exit /b %PATCH_RESULT%

where git.exe >nul 2>&1
if not errorlevel 1 (
    pushd "%REPO_ROOT%"
    git diff --check
    if errorlevel 1 (
        popd
        echo [explicit-ownership] ERROR: git diff --check failed.
        exit /b 4
    )
    echo.
    git diff --stat -- src/GPU_Soft.h src/GPU_Soft.cpp src/GPU2D_Soft.h src/GPU2D_Soft.cpp src/GPU_Vulkan.h src/GPU_Vulkan.cpp src/Vulkan_shaders/phase10_presenter.frag
    popd
)

if "%DO_BUILD%"=="0" (
    echo.
    echo [explicit-ownership] Patch applied. Build was skipped.
    echo [explicit-ownership] The next Vulkan build will regenerate the SPIR-V header.
    exit /b 0
)

set "BUILD_SCRIPT=%REPO_ROOT%\.claude\skills\build-mingw-vulkan.bat"
if not exist "%BUILD_SCRIPT%" (
    echo [explicit-ownership] ERROR: Build script is missing: %BUILD_SCRIPT%
    echo [explicit-ownership] Patch remains applied.
    exit /b 5
)

echo.
echo [explicit-ownership] Regenerating SPIR-V and building Vulkan-enabled Windows target...
call "%BUILD_SCRIPT%"
set "BUILD_RESULT=%ERRORLEVEL%"
if not "%BUILD_RESULT%"=="0" (
    echo [explicit-ownership] ERROR: Vulkan build failed with exit code %BUILD_RESULT%.
    echo [explicit-ownership] Source patch remains applied; use the generated backup to revert.
    exit /b %BUILD_RESULT%
)

echo.
echo [explicit-ownership] SUCCESS
echo [explicit-ownership] Opaque native Vulkan adoption now uses exact 2D composition ownership.
echo [explicit-ownership] Translucent ownership remains conservative until full Vulkan 2D composition.
exit /b 0

:help
echo Usage:
echo   %~nx0 [--repo C:\path\to\melonPrimeDS] [--no-build]
echo.
echo Applies the next Vulkan-completion correction:
echo   - records exact Engine A pixels directly owned by the unmodified 3D layer
echo   - packs that ownership bit into the native reference texture
echo   - removes RGB-equality ownership gating for opaque native Vulkan pixels
echo   - retains the conservative Software oracle for translucent pixels
echo   - backs up every modified file and runs the Vulkan Windows build
exit /b 0

:help_error
call :help
exit /b 2

