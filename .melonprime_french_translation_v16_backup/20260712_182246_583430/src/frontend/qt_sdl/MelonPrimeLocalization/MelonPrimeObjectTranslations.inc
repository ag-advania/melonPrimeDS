            {MenuLangId::Khmer, "ការកែនេះនៅមិនទាន់មានស្ថេរភាពទេ។ ជាពិសេសក្នុងកំណែកូរ៉េ ផ្លែដាវអាចនៅសល់ក្នុងករណីខ្លះ។"},
            {MenuLangId::Lao, "ການແກ້ນີ້ຍັງບໍ່ສະຖຽນ. ໂດຍສະເພາະໃນເວີຊັນເກົາຫຼີ, ໃບມີດອາດຍັງຄົງຢູ່ໃນບາງກໍລະນີ."},
            {MenuLangId::Armenian, "Այս ուղղումը դեռ անկայուն է։ Հատկապես կորեական տարբերակում սայրը որոշ դեպքերում կարող է մնալ։"},
            {MenuLangId::Albanian, "Ky rregullim ende nuk është i qëndrueshëm. Sidomos në versionin korean, tehu mund të mbetet në disa raste."},
            {MenuLangId::Georgian, "ეს შესწორება ჯერ კიდევ არასტაბილურია. განსაკუთრებით კორეულ ვერსიაში, პირი ზოგჯერ შეიძლება დარჩეს."},
            {MenuLangId::Bosnian, "Ovaj ispravak još nije stabilan. Posebno u korejskoj verziji oštrica u nekim slučajevima može ostati."},
            {MenuLangId::Serbian, "Ова исправка још није стабилна. Посебно у корејској верзији, оштрица у неким случајевима може да остане."},
            {MenuLangId::Macedonian, "Оваа исправка сè уште не е стабилна. Особено во корејската верзија, сечилото понекогаш може да остане."},
            {MenuLangId::Bulgarian, "Тази поправка все още не е стабилна. Особено в корейската версия острието понякога може да остане."},
            {MenuLangId::Belarusian, "Гэта выпраўленне яшчэ нестабільнае. Асабліва ў карэйскай версіі лязо часам можа заставацца."},
            {MenuLangId::Maltese, "Dan it-tiswib għadu mhux stabbli. Speċjalment fil-verżjoni Koreana, ix-xafra tista' tibqa' f'xi każijiet."},
            {MenuLangId::Mongolian, "Энэ засвар одоогоор тогтвортой биш. Ялангуяа солонгос хувилбарт ир зарим тохиолдолд үлдэж болно."},
            {MenuLangId::Latvian, "Šis labojums vēl nav stabils. Īpaši korejiešu versijā asmens dažos gadījumos var palikt."},
            {MenuLangId::Lithuanian, "Šis pataisymas dar nestabilus. Ypač korėjietiškoje versijoje ašmenys kai kuriais atvejais gali likti."},
            {MenuLangId::Afrikaans, "Hierdie regstelling is nog onstabiel. Veral in die Koreaanse weergawe kan die lem in sommige gevalle bly."},
            {MenuLangId::Irish, "Níl an ceartúchán seo cobhsaí fós. Go háirithe sa leagan Cóiréach, d'fhéadfadh an lann fanacht i gcásanna áirithe."},
            {MenuLangId::Assamese, "এই সংশোধন এতিয়াও স্থিৰ নহয়। বিশেষকৈ কোৰিয়ান সংস্কৰণত, কিছুমান ক্ষেত্ৰত ব্লেড থাকি যাব পাৰে।"},
            {MenuLangId::Amharic, "ይህ ማስተካከያ ገና የተረጋጋ አይደለም። በተለይ በኮሪያኛ ስሪት ውስጥ ቢላዋው በአንዳንድ ሁኔታዎች ሊቀር ይችላል።"},
            {MenuLangId::Estonian, "See parandus ei ole veel stabiilne. Eriti Korea versioonis võib tera mõnel juhul alles jääda."},
            {MenuLangId::Kazakh, "Бұл түзету әлі тұрақты емес. Әсіресе корей нұсқасында жүз кейбір жағдайларда қалып қоюы мүмкін."},
            {MenuLangId::Catalan, "Aquesta correcció encara no és estable. Especialment a la versió coreana, la fulla pot quedar-se en alguns casos."},
            {MenuLangId::Kyrgyz, "Бул оңдоо азырынча туруктуу эмес. Айрыкча кореялык нускада бычак айрым учурларда калып калышы мүмкүн."},
            {MenuLangId::Slovak, "Táto oprava ešte nie je stabilná. Najmä v kórejskej verzii môže čepeľ v niektorých prípadoch zostať."},
            {MenuLangId::Slovenian, "Ta popravek še ni stabilen. Zlasti v korejski različici lahko rezilo v nekaterih primerih ostane."},
            {MenuLangId::Zulu, "Lokhu kulungisa akukazinzi okwamanje. Ikakhulukazi enguqulweni yaseKorea, inkemba ingase ihlale kwezinye izimo."},
            {MenuLangId::Basque, "Konponketa hau oraindik ez da egonkorra. Bereziki Koreako bertsioan, xafla zenbait kasutan gera daiteke."},
            {MenuLangId::Hebrew, "התיקון הזה עדיין אינו יציב. במיוחד בגרסה הקוריאנית, הלהב עלול להישאר במקרים מסוימים."},
        }
    },
    {
        "lblMetroidUseFirmwareLanguageDesc",
        {
            {MenuLangId::Japanese, "<html><body>\nDSファームウェアの言語設定を読み取り、その言語で表示するようゲームにパッチします。<br>\nEU ROMには隠し日本語オプションがあり、DSファームウェアを日本語にすると有効になります。<br><br>\n<b>EU / US ROM:</b> すべてのモードで動作します (マルチプレイとアドベンチャー)。<br>\n<b>JP ROM:</b> マルチプレイのみ動作します。<font color=\"red\"><b>有効にするとアドベンチャーモードはプレイできません。</b></font><br>\n<b>KR ROM:</b> まだ未対応です。\n</body></html>"},
            {MenuLangId::German, "<html><body>\nLiest die Spracheinstellung der DS-Firmware aus und passt das Spiel an diese Sprache an.\n<br>\nEU-ROMs haben eine versteckte Japanisch-Option, die aktiv wird, wenn die DS-Firmware auf Japanisch steht.\n<br><br>\n<b>EU / US ROM:</b> Funktioniert überall (Mehrspieler und Abenteuer).\n<br>\n<b>JP ROM:</b> Nur Mehrspieler. <font color=\"red\"><b>Wenn aktiviert, ist das Abenteuer nicht spielbar.</b></font>\n<br>\n<b>KR ROM:</b> Noch nicht unterstützt.\n</body></html>"},
            {MenuLangId::Spanish, "<html><body>\nLee el idioma del firmware de la DS y adapta el juego para mostrarlo en ese idioma.\n<br>\nLas ROM europeas tienen una opción oculta de japonés que se activa cuando el firmware de la DS está en japonés.\n<br><br>\n<b>ROM EU / US:</b> Funciona en todos los modos (multijugador y aventura).\n<br>\n<b>ROM JP:</b> Solo funciona en multijugador. <font color=\"red\"><b>Si se activa, no se puede jugar al modo Aventura.</b></font>\n<br>\n<b>ROM KR:</b> Aún no es compatible.\n</body></html>"},
            {MenuLangId::French, "<html><body>\nLit la langue du firmware DS et adapte le jeu pour l’afficher dans cette langue.\n<br>\nLes ROM EU ont une option japonaise cachée, active quand le firmware DS est en japonais.\n<br><br>\n<b>ROM EU / US :</b> Fonctionne partout (multijoueur et aventure).\n<br>\n<b>ROM JP :</b> Multijoueur uniquement. <font color=\"red\"><b>Si cette option est activée, l’aventure n’est pas jouable.</b></font>\n<br>\n<b>ROM KR :</b> Pas encore pris en charge.\n</body></html>"},
            {MenuLangId::Italian, "<html><body>\nLegge la lingua del firmware DS e adatta il gioco per mostrarla in quella lingua.\n<br>\nLe ROM EU hanno un’opzione giapponese nascosta, attiva quando il firmware DS è in giapponese.\n<br><br>\n<b>ROM EU / US:</b> Funziona ovunque (multigiocatore e avventura).\n<br>\n<b>ROM JP:</b> Solo multigiocatore. <font color=\"red\"><b>Se attivato, l’avventura non è giocabile.</b></font>\n<br>\n<b>ROM KR:</b> Non ancora supportato.\n</body></html>"},
            {MenuLangId::Dutch, "<html><body>\nLeest de taalinstelling van de DS-firmware en past het spel aan om die taal te tonen.\n<br>\nEU-ROMs hebben een verborgen Japanse optie die actief wordt wanneer de DS-firmware op Japans staat.\n<br><br>\n<b>EU / US ROM:</b> Werkt overal (meerspeler en avontuur).\n<br>\n<b>JP ROM:</b> Alleen meerspeler. <font color=\"red\"><b>Wanneer ingeschakeld is het avontuur niet speelbaar.</b></font>\n<br>\n<b>KR ROM:</b> Nog niet ondersteund.\n</body></html>"},
            {MenuLangId::Portuguese, "<html><body>\nLê a definição de idioma do firmware DS e ajusta o jogo para o mostrar nesse idioma.\n<br>\nAs ROM EU têm uma opção japonesa oculta, ativa quando o firmware DS está em japonês.\n<br><br>\n<b>ROM EU / US:</b> Funciona em todos os modos (multijogador e aventura).\n<br>\n<b>ROM JP:</b> Apenas multijogador. <font color=\"red\"><b>Se ativado, a aventura não pode ser jogada.</b></font>\n<br>\n<b>ROM KR:</b> Ainda não suportado.\n</body></html>"},
            {MenuLangId::Russian, "<html><body>\nСчитывает языковую настройку прошивки DS и изменяет игру для отображения на этом языке.\n<br>\nВ EU ROM есть скрытая японская опция, активная при японской прошивке DS.\n<br><br>\n<b>EU / US ROM:</b> Работает везде (мультиплеер и приключение).\n<br>\n<b>JP ROM:</b> Только мультиплеер. <font color=\"red\"><b>При включении приключение недоступно.</b></font>\n<br>\n<b>KR ROM:</b> Пока не поддерживается.\n</body></html>"},
            {MenuLangId::ChineseSimplified, "<html><body>\n读取 DS 固件语言设置，并调整游戏以该语言显示。\n<br>\nEU ROM 有隐藏日语选项，DS 固件设为日语时生效。\n<br><br>\n<b>EU / US ROM：</b>所有玩法可用（多人和冒险）。\n<br>\n<b>JP ROM：</b>仅多人可用。<font color=\"red\"><b>启用后无法游玩冒险。</b></font>\n<br>\n<b>KR ROM：</b>暂不支持。\n</body></html>"},
            {MenuLangId::ChineseTraditional, "<html><body>\n讀取 DS 韌體語言設定，並調整遊戲以該語言顯示。\n<br>\nEU ROM 有隱藏日語選項，DS 韌體設為日語時生效。\n<br><br>\n<b>EU / US ROM：</b>所有玩法可用（多人與冒險）。\n<br>\n<b>JP ROM：</b>僅多人可用。<font color=\"red\"><b>啟用後無法遊玩冒險。</b></font>\n<br>\n<b>KR ROM：</b>暫不支援。\n</body></html>"},
            {MenuLangId::ChineseHongKong, "<html><body>\n讀取 DS 韌體語言設定，並調整遊戲以該語言顯示。\n<br>\nEU ROM 有隱藏日語選項，DS 韌體設為日語時生效。\n<br><br>\n<b>EU / US ROM：</b>所有玩法可用（多人與冒險）。\n<br>\n<b>JP ROM：</b>僅多人可用。<font color=\"red\"><b>啟用後無法遊玩冒險。</b></font>\n<br>\n<b>KR ROM：</b>暫不支援。\n</body></html>"},
            {MenuLangId::Korean, "<html><body>\nDS 펌웨어 언어 설정을 읽어 해당 언어로 표시되도록 게임을 조정합니다.\n<br>\nEU ROM에는 숨겨진 일본어 옵션이 있으며 DS 펌웨어가 일본어일 때 활성화됩니다.\n<br><br>\n<b>EU / US ROM:</b> 모든 곳에서 동작합니다(멀티플레이 및 어드벤처).\n<br>\n<b>JP ROM:</b> 멀티플레이만 동작합니다. <font color=\"red\"><b>활성화하면 어드벤처를 플레이할 수 없습니다.</b></font>\n<br>\n<b>KR ROM:</b> 아직 미지원입니다.\n</body></html>"},
            {MenuLangId::Arabic, "<html><body>\nيقرأ إعداد لغة firmware DS ويعدّل اللعبة لعرضها بهذه اللغة.\n<br>\nتحتوي ROM EU على خيار ياباني مخفي يعمل عندما يكون firmware DS مضبوطًا على اليابانية.\n<br><br>\n<b>ROM EU / US:</b> يعمل في كل الحالات (تعدد اللاعبين والمغامرة).\n<br>\n<b>ROM JP:</b> تعدد اللاعبين فقط. <font color=\"red\"><b>عند تفعيله لا يمكن لعب المغامرة.</b></font>\n<br>\n<b>ROM KR:</b> غير مدعوم بعد.\n</body></html>"},
            {MenuLangId::Indonesian, "<html><body>\nMembaca pengaturan bahasa firmware DS dan menyesuaikan game agar tampil dalam bahasa tersebut.\n<br>\nROM EU memiliki opsi Jepang tersembunyi yang aktif jika firmware DS diatur ke Jepang.\n<br><br>\n<b>ROM EU / US:</b> Berfungsi di semua modus (multipemain dan petualangan).\n<br>\n<b>ROM JP:</b> Hanya multipemain. <font color=\"red\"><b>Jika diaktifkan, petualangan tidak dapat dimainkan.</b></font>\n<br>\n<b>ROM KR:</b> Belum didukung.\n</body></html>"},
            {MenuLangId::Ukrainian, "<html><body>\nЗчитує мовне налаштування прошивки DS і змінює гру для відображення цією мовою.\n<br>\nУ EU ROM є прихована японська опція, активна при японській прошивці DS.\n<br><br>\n<b>EU / US ROM:</b> Працює всюди (багатокористувацька гра і пригода).\n<br>\n<b>JP ROM:</b> Лише багатокористувацька гра. <font color=\"red\"><b>Якщо увімкнено, пригода недоступна.</b></font>\n<br>\n<b>KR ROM:</b> Поки не підтримується.\n</body></html>"},
            {MenuLangId::Greek, "<html><body>\nΔιαβάζει τη ρύθμιση γλώσσας του firmware DS και προσαρμόζει το παιχνίδι για εμφάνιση σε αυτή τη γλώσσα.\n<br>\nΤα EU ROM έχουν κρυφή ιαπωνική επιλογή, ενεργή όταν το firmware DS είναι στα ιαπωνικά.\n<br><br>\n<b>EU / US ROM:</b> Λειτουργεί παντού (πολλαπλοί παίκτες και περιπέτεια).\n<br>\n<b>JP ROM:</b> Μόνο πολλαπλοί παίκτες. <font color=\"red\"><b>Αν ενεργοποιηθεί, η περιπέτεια δεν μπορεί να παιχτεί.</b></font>\n<br>\n<b>KR ROM:</b> Δεν υποστηρίζεται ακόμα.\n</body></html>"},
            {MenuLangId::Swedish, "<html><body>\nLäser DS-firmwarens språkinställning och anpassar spelet för att visa det språket.\n<br>\nEU-ROM har ett dolt japanskt alternativ som aktiveras när DS-firmwaren är på japanska.\n<br><br>\n<b>EU / US ROM:</b> Fungerar överallt (flerspelare och äventyr).\n<br>\n<b>JP ROM:</b> Endast flerspelare. <font color=\"red\"><b>Om aktiverat går äventyret inte att spela.</b></font>\n<br>\n<b>KR ROM:</b> Stöds inte ännu.\n</body></html>"},
            {MenuLangId::Thai, "<html><body>\nอ่านการตั้งค่าภาษา firmware DS และปรับเกมให้แสดงภาษานั้น\n<br>\nROM EU มีตัวเลือกภาษาญี่ปุ่นที่ซ่อนอยู่ ซึ่งทำงานเมื่อ firmware DS เป็นภาษาญี่ปุ่น\n<br><br>\n<b>ROM EU / US:</b> ใช้ได้ทุกส่วน (ผู้เล่นหลายคนและผจญภัย)\n<br>\n<b>ROM JP:</b> ใช้ได้เฉพาะผู้เล่นหลายคน <font color=\"red\"><b>เมื่อเปิดใช้ จะเล่นส่วนผจญภัยไม่ได้</b></font>\n<br>\n<b>ROM KR:</b> ยังไม่รองรับ\n</body></html>"},
            {MenuLangId::Czech, "<html><body>\nNačte jazykové nastavení firmware DS a upraví hru pro zobrazení v tomto jazyce.\n<br>\nEU ROM mají skrytou japonskou volbu, aktivní při japonském firmware DS.\n<br><br>\n<b>EU / US ROM:</b> Funguje všude (více hráčů a dobrodružství).\n<br>\n<b>JP ROM:</b> Pouze více hráčů. <font color=\"red\"><b>Při zapnutí nelze hrát dobrodružství.</b></font>\n<br>\n<b>KR ROM:</b> Zatím nepodporováno.\n</body></html>"},
            {MenuLangId::Danish, "<html><body>\nLæser DS-firmwarens sprogindstilling og tilpasser spillet til at vise det sprog.\n<br>\nEU-ROM har en skjult japansk mulighed, aktiv når DS-firmware er på japansk.\n<br><br>\n<b>EU / US ROM:</b> Virker overalt (flerspiller og eventyr).\n<br>\n<b>JP ROM:</b> Kun flerspiller. <font color=\"red\"><b>Hvis aktiveret, kan eventyret ikke spilles.</b></font>\n<br>\n<b>KR ROM:</b> Endnu ikke understøttet.\n</body></html>"},
            {MenuLangId::Turkish, "<html><body>\nDS firmware dil ayarını okur ve oyunu o dilde göstermek için düzenler.\n<br>\nEU ROMlarda DS firmware Japonca olduğunda etkinleşen gizli Japonca seçeneği vardır.\n<br><br>\n<b>EU / US ROM:</b> Her yerde çalışır (çok oyunculu ve macera).\n<br>\n<b>JP ROM:</b> Yalnızca çok oyunculu. <font color=\"red\"><b>Etkinleştirilirse macera oynanamaz.</b></font>\n<br>\n<b>KR ROM:</b> Henüz desteklenmiyor.\n</body></html>"},
            {MenuLangId::Norwegian, "<html><body>\nLeser DS-firmwarens språkinnstilling og tilpasser spillet for å vise det språket.\n<br>\nEU-ROM har et skjult japansk alternativ som aktiveres når DS-firmware er på japansk.\n<br><br>\n<b>EU / US ROM:</b> Fungerer overalt (flerspiller og eventyr).\n<br>\n<b>JP ROM:</b> Kun flerspiller. <font color=\"red\"><b>Hvis aktivert, kan eventyret ikke spilles.</b></font>\n<br>\n<b>KR ROM:</b> Støttes ikke ennå.\n</body></html>"},
            {MenuLangId::Hungarian, "<html><body>\nBeolvassa a DS firmware nyelvi beállítását, és a játékot ehhez a nyelvhez igazítja.\n<br>\nAz EU ROM-okban rejtett japán opció van, amely aktív, ha a DS firmware japán.\n<br><br>\n<b>EU / US ROM:</b> Mindenhol működik (többjátékos és kaland).\n<br>\n<b>JP ROM:</b> Csak többjátékos. <font color=\"red\"><b>Bekapcsolva a kaland nem játszható.</b></font>\n<br>\n<b>KR ROM:</b> Még nem támogatott.\n</body></html>"},
            {MenuLangId::Finnish, "<html><body>\nLukee DS-firmwaren kieliasetuksen ja mukauttaa pelin näyttämään kyseistä kieltä.\n<br>\nEU-ROMissa on piilotettu japanilainen vaihtoehto, joka aktivoituu kun DS-firmware on japaniksi.\n<br><br>\n<b>EU / US ROM:</b> Toimii kaikkialla (moninpeli ja seikkailu).\n<br>\n<b>JP ROM:</b> Vain moninpeli. <font color=\"red\"><b>Käytössä seikkailua ei voi pelata.</b></font>\n<br>\n<b>KR ROM:</b> Ei vielä tuettu.\n</body></html>"},
            {MenuLangId::Vietnamese, "<html><body>\nĐọc cài đặt ngôn ngữ firmware DS và chỉnh trò chơi để hiển thị bằng ngôn ngữ đó.\n<br>\nROM EU có tùy chọn tiếng Nhật ẩn, kích hoạt khi firmware DS là tiếng Nhật.\n<br><br>\n<b>ROM EU / US:</b> Hoạt động ở mọi phần (nhiều người chơi và phiêu lưu).\n<br>\n<b>ROM JP:</b> Chỉ nhiều người chơi. <font color=\"red\"><b>Bật thì không chơi được phần phiêu lưu.</b></font>\n<br>\n<b>ROM KR:</b> Chưa hỗ trợ.\n</body></html>"},
            {MenuLangId::Polish, "<html><body>\nOdczytuje ustawienie języka firmware DS i dostosowuje grę do wyświetlania w tym języku.\n<br>\nROM EU mają ukrytą opcję japońską, aktywną przy japońskim firmware DS.\n<br><br>\n<b>ROM EU / US:</b> Działa wszędzie (wielu graczy i przygoda).\n<br>\n<b>ROM JP:</b> Tylko wielu graczy. <font color=\"red\"><b>Po włączeniu przygoda jest niedostępna.</b></font>\n<br>\n<b>ROM KR:</b> Jeszcze nieobsługiwane.\n</body></html>"},
            {MenuLangId::Romanian, "<html><body>\nCitește setarea de limbă a firmware-ului DS și ajustează jocul pentru afișare în acea limbă.\n<br>\nROM-urile EU au opțiune japoneză ascunsă, activă când firmware-ul DS este în japoneză.\n<br><br>\n<b>ROM EU / US:</b> Funcționează peste tot (mai mulți jucători și aventură).\n<br>\n<b>ROM JP:</b> Doar mai mulți jucători. <font color=\"red\"><b>Dacă este activat, aventura nu poate fi jucată.</b></font>\n<br>\n<b>ROM KR:</b> Încă neacceptat.\n</body></html>"},
            {MenuLangId::Filipino, "<html><body>\nBinabasa ang ayos ng wika ng DS firmware at inaakma ang laro para ipakita ang wikang iyon.\n<br>\nMay nakatagong opsyon sa Hapones ang EU ROM, na gumagana kapag Hapones ang DS firmware.\n<br><br>\n<b>EU / US ROM:</b> Gumagana sa lahat ng bahagi (maramihang manlalaro at pakikipagsapalaran).\n<br>\n<b>JP ROM:</b> Maramihang manlalaro lang. <font color=\"red\"><b>Kapag pinagana, hindi malalaro ang pakikipagsapalaran.</b></font>\n<br>\n<b>KR ROM:</b> Hindi pa suportado.\n</body></html>"},
            {MenuLangId::Swahili, "<html><body>\nHusoma mpangilio wa lugha wa DS firmware na kurekebisha mchezo uonyeshe lugha hiyo.\n<br>\nEU ROM ina chaguo la siri la Kijapani, linalowashwa ikiwa DS firmware iko Kijapani.\n<br><br>\n<b>EU / US ROM:</b> Hufanya kazi kila sehemu (wachezaji wengi na matukio).\n<br>\n<b>JP ROM:</b> Wachezaji wengi pekee. <font color=\"red\"><b>Ikiwashwa, sehemu ya matukio haiwezi kuchezwa.</b></font>\n<br>\n<b>KR ROM:</b> Bado haijasaidiwa.\n</body></html>"},
            {MenuLangId::Croatian, "<html><body>\nČita postavku jezika DS firmwarea i prilagođava igru za prikaz na tom jeziku.\n<br>\nEU ROM ima skrivenu japansku opciju koja se aktivira ako je DS firmware postavljen na japanski.\n<br><br>\n<b>EU / US ROM:</b> Radi svugdje (više igrača i avantura).\n<br>\n<b>JP ROM:</b> Samo više igrača. <font color=\"red\"><b>Ako je omogućeno, avantura se ne može igrati.</b></font>\n<br>\n<b>KR ROM:</b> Još nije podržano.\n</body></html>"},
            {MenuLangId::Icelandic, "<html><body>\nLes tungumálsstillingu DS firmware og aðlagar leikinn að því tungumáli.\n<br>\nEU ROM hefur falda japanska stillingu sem virkjast ef DS firmware er stillt á japönsku.\n<br><br>\n<b>EU / US ROM:</b> Virkar alls staðar (fjölspilun og ævintýri).\n<br>\n<b>JP ROM:</b> Aðeins fjölspilun. <font color=\"red\"><b>Ef virkt er ekki hægt að spila ævintýrið.</b></font>\n<br>\n<b>KR ROM:</b> Ekki stutt enn.\n</body></html>"},
            {MenuLangId::Hindi, "<html><body>\nDS firmware की भाषा सेटिंग पढ़ता है और खेल को उसी भाषा में दिखाने के लिए बदलता है।\n<br>\nEU ROM में छिपा हुआ जापानी विकल्प है, जो DS firmware जापानी होने पर सक्रिय होता है।\n<br><br>\n<b>EU / US ROM:</b> सभी जगह काम करता है (मल्टीप्लेयर और अभियान)।\n<br>\n<b>JP ROM:</b> केवल मल्टीप्लेयर। <font color=\"red\"><b>सक्षम करने पर अभियान खेला नहीं जा सकेगा।</b></font>\n<br>\n<b>KR ROM:</b> अभी समर्थित नहीं है।\n</body></html>"},
            {MenuLangId::Bengali, "<html><body>\nDS firmware-এর ভাষা সেটিং পড়ে এবং গেমটিকে সেই ভাষায় দেখানোর জন্য বদলে দেয়।\n<br>\nEU ROM-এ একটি লুকানো জাপানি বিকল্প আছে, যা DS firmware জাপানি হলে সক্রিয় হয়।\n<br><br>\n<b>EU / US ROM:</b> সব জায়গায় কাজ করে (মাল্টিপ্লেয়ার ও অ্যাডভেঞ্চার)।\n<br>\n<b>JP ROM:</b> শুধু মাল্টিপ্লেয়ার। <font color=\"red\"><b>সক্ষম করলে অ্যাডভেঞ্চার খেলা যাবে না।</b></font>\n<br>\n<b>KR ROM:</b> এখনও সমর্থিত নয়।\n</body></html>"},
            {MenuLangId::Urdu, "<html><body>\nDS firmware کی زبان کی ترتیب پڑھتا ہے اور گیم کو اسی زبان میں دکھانے کے لیے بدلتا ہے۔\n<br>\nEU ROM میں ایک پوشیدہ جاپانی اختیار ہے، جو DS firmware جاپانی ہونے پر فعال ہوتا ہے۔\n<br><br>\n<b>EU / US ROM:</b> ہر جگہ کام کرتا ہے (ملٹی پلیئر اور مہم)۔\n<br>\n<b>JP ROM:</b> صرف ملٹی پلیئر۔ <font color=\"red\"><b>فعال کرنے پر مہم نہیں کھیلی جا سکے گی۔</b></font>\n<br>\n<b>KR ROM:</b> ابھی معاونت یافتہ نہیں۔\n</body></html>"},
            {MenuLangId::Punjabi, "<html><body>\nDS firmware ਦੀ ਭਾਸ਼ਾ ਸੈਟਿੰਗ ਪੜ੍ਹਦਾ ਹੈ ਅਤੇ ਗੇਮ ਨੂੰ ਉਸੇ ਭਾਸ਼ਾ ਵਿੱਚ ਦਿਖਾਉਣ ਲਈ ਬਦਲਦਾ ਹੈ।\n<br>\nEU ROM ਵਿੱਚ ਇੱਕ ਲੁਕਿਆ ਜਾਪਾਨੀ ਵਿਕਲਪ ਹੈ, ਜੋ DS firmware ਜਾਪਾਨੀ ਹੋਣ ਤੇ ਸਰਗਰਮ ਹੁੰਦਾ ਹੈ।\n<br><br>\n<b>EU / US ROM:</b> ਹਰ ਥਾਂ ਕੰਮ ਕਰਦਾ ਹੈ (ਮਲਟੀਪਲੇਅਰ ਅਤੇ ਮੁਹਿੰਮ)।\n<br>\n<b>JP ROM:</b> ਸਿਰਫ਼ ਮਲਟੀਪਲੇਅਰ। <font color=\"red\"><b>ਚਾਲੂ ਕਰਨ ਤੇ ਮੁਹਿੰਮ ਨਹੀਂ ਖੇਡੀ ਜਾ ਸਕੇਗੀ।</b></font>\n<br>\n<b>KR ROM:</b> ਹਾਲੇ ਸਮਰਥਿਤ ਨਹੀਂ।\n</body></html>"},
            {MenuLangId::Telugu, "<html><body>\nDS firmware భాష సెట్టింగ్‌ను చదివి గేమ్‌ను అదే భాషలో చూపేందుకు మారుస్తుంది.\n<br>\nEU ROMలో దాచిన జపనీస్ ఎంపిక ఉంది; DS firmware జపనీస్ అయితే అది సక్రియమవుతుంది.\n<br><br>\n<b>EU / US ROM:</b> అన్ని చోట్ల పనిచేస్తుంది (బహుళ ఆటగాళ్లు మరియు సాహసం).\n<br>\n<b>JP ROM:</b> బహుళ ఆటగాళ్లు మాత్రమే. <font color=\"red\"><b>దీన్ని సక్రియం చేస్తే సాహసం ఆడలేరు.</b></font>\n<br>\n<b>KR ROM:</b> ఇంకా మద్దతు లేదు.\n</body></html>"},
            {MenuLangId::Persian, "<html><body>\nتنظیم زبان DS firmware را می‌خواند و بازی را برای نمایش با همان زبان تنظیم می‌کند.\n<br>\nEU ROM یک گزینه ژاپنی پنهان دارد که وقتی DS firmware روی ژاپنی باشد فعال می‌شود.\n<br><br>\n<b>EU / US ROM:</b> همه‌جا کار می‌کند (چندنفره و ماجراجویی).\n<br>\n<b>JP ROM:</b> فقط چندنفره. <font color=\"red\"><b>اگر فعال شود، بخش ماجراجویی قابل بازی نیست.</b></font>\n<br>\n<b>KR ROM:</b> هنوز پشتیبانی نمی‌شود.\n</body></html>"},
            {MenuLangId::Malay, "<html><body>\nMembaca tetapan bahasa DS firmware dan melaraskan permainan supaya dipaparkan dalam bahasa itu.\n<br>\nEU ROM mempunyai pilihan Jepun tersembunyi yang aktif apabila DS firmware ditetapkan kepada Jepun.\n<br><br>\n<b>EU / US ROM:</b> Berfungsi di semua bahagian (berbilang pemain dan pengembaraan).\n<br>\n<b>JP ROM:</b> Berbilang pemain sahaja. <font color=\"red\"><b>Jika didayakan, pengembaraan tidak boleh dimainkan.</b></font>\n<br>\n<b>KR ROM:</b> Belum disokong.\n</body></html>"},
            {MenuLangId::Marathi, "<html><body>\nDS firmware ची भाषा सेटिंग वाचतो आणि गेम त्याच भाषेत दाखवण्यासाठी बदलतो.\n<br>\nEU ROM मध्ये एक लपलेला जपानी पर्याय आहे, जो DS firmware जपानी असल्यास सक्रिय होतो.\n<br><br>\n<b>EU / US ROM:</b> सर्वत्र कार्य करते (मल्टीप्लेअर आणि अ‍ॅडव्हेंचर).\n<br>\n<b>JP ROM:</b> फक्त मल्टीप्लेअर. <font color=\"red\"><b>सक्षम केल्यास अ‍ॅडव्हेंचर खेळता येणार नाही.</b></font>\n<br>\n<b>KR ROM:</b> अजून समर्थित नाही.\n</body></html>"},
            {MenuLangId::Tamil, "<html><body>\nDS firmware மொழி அமைப்பை வாசித்து, விளையாட்டை அதே மொழியில் காட்ட மாற்றுகிறது.\n<br>\nEU ROM இல் மறைக்கப்பட்ட ஜப்பானிய விருப்பம் உள்ளது; DS firmware ஜப்பானியமாக இருந்தால் அது செயல்படும்.\n<br><br>\n<b>EU / US ROM:</b> எல்லா பகுதிகளிலும் வேலை செய்கிறது (பலர் விளையாட்டு மற்றும் சாகசம்).\n<br>\n<b>JP ROM:</b> பலர் விளையாட்டு மட்டும். <font color=\"red\"><b>இதை செயல்படுத்தினால் சாகசத்தை விளையாட முடியாது.</b></font>\n<br>\n<b>KR ROM:</b> இன்னும் ஆதரிக்கப்படவில்லை.\n</body></html>"},
            {MenuLangId::Gujarati, "<html><body>\nDS firmware ની ભાષા સેટિંગ વાંચે છે અને ગેમને એ જ ભાષામાં બતાવવા બદલાવે છે.\n<br>\nEU ROM માં છુપાયેલો જાપાની વિકલ્પ છે, જે DS firmware જાપાની હોય ત્યારે સક્રિય થાય છે.\n<br><br>\n<b>EU / US ROM:</b> બધે કાર્ય કરે છે (મલ્ટિપ્લેયર અને સાહસ).\n<br>\n<b>JP ROM:</b> માત્ર મલ્ટિપ્લેયર. <font color=\"red\"><b>સક્ષમ કરવાથી સાહસ રમી શકાશે નહીં.</b></font>\n<br>\n<b>KR ROM:</b> હજી સમર્થિત નથી.\n</body></html>"},
            {MenuLangId::Kannada, "<html><body>\nDS firmware ಭಾಷೆ ಸೆಟ್ಟಿಂಗ್ ಓದಿ, ಗೇಮ್ ಅನ್ನು ಅದೇ ಭಾಷೆಯಲ್ಲಿ ತೋರಿಸಲು ಬದಲಿಸುತ್ತದೆ.\n<br>\nEU ROM ನಲ್ಲಿ ಮರೆಮಾಚಿದ ಜಪಾನೀಸ್ ಆಯ್ಕೆ ಇದೆ; DS firmware ಜಪಾನೀಸ್ ಆಗಿದ್ದರೆ ಅದು ಸಕ್ರಿಯವಾಗುತ್ತದೆ.\n<br><br>\n<b>EU / US ROM:</b> ಎಲ್ಲೆಡೆ ಕೆಲಸ ಮಾಡುತ್ತದೆ (ಬಹುಆಟಗಾರ ಮತ್ತು ಸಾಹಸ).\n<br>\n<b>JP ROM:</b> ಬಹುಆಟಗಾರ ಮಾತ್ರ. <font color=\"red\"><b>ಇದನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿದರೆ ಸಾಹಸ ಆಡಲು ಆಗುವುದಿಲ್ಲ.</b></font>\n<br>\n<b>KR ROM:</b> ಇನ್ನೂ ಬೆಂಬಲಿತವಿಲ್ಲ.\n</body></html>"},
            {MenuLangId::Odia, "<html><body>\nDS firmware ଭାଷା ସେଟିଂ ପଢ଼ି, ଗେମ୍‌କୁ ସେହି ଭାଷାରେ ଦେଖାଇବାକୁ ବଦଳାଏ।\n<br>\nEU ROM ରେ ଲୁଚା ଜାପାନୀ ବିକଳ୍ପ ଅଛି; DS firmware ଜାପାନୀ ହେଲେ ଏହା ସକ୍ରିୟ ହୁଏ।\n<br><br>\n<b>EU / US ROM:</b> ସବୁଠାରେ କାମ କରେ (ମଲ୍ଟିପ୍ଲେୟର ଓ ଅଭିଯାନ)।\n<br>\n<b>JP ROM:</b> କେବଳ ମଲ୍ଟିପ୍ଲେୟର। <font color=\"red\"><b>ସକ୍ରିୟ କଲେ ଅଭିଯାନ ଖେଳିପାରିବେ ନାହିଁ।</b></font>\n<br>\n<b>KR ROM:</b> ଏଖଣି ସମର୍ଥିତ ନୁହେଁ।\n</body></html>"},
            {MenuLangId::Malayalam, "<html><body>\nDS firmware ഭാഷാ ക്രമീകരണം വായിച്ച് ഗെയിം അതേ ഭാഷയിൽ കാണിക്കാൻ മാറ്റുന്നു.\n<br>\nEU ROMൽ മറഞ്ഞ ജാപ്പനീസ് ഓപ്ഷൻ ഉണ്ട്; DS firmware ജാപ്പനീസ് ആണെങ്കിൽ അത് സജീവമാകും.\n<br><br>\n<b>EU / US ROM:</b> എല്ലായിടത്തും പ്രവർത്തിക്കുന്നു (മൾട്ടിപ്ലെയർ, സാഹസം).\n<br>\n<b>JP ROM:</b> മൾട്ടിപ്ലെയർ മാത്രം. <font color=\"red\"><b>സജീവമാക്കിയാൽ സാഹസം കളിക്കാൻ കഴിയില്ല.</b></font>\n<br>\n<b>KR ROM:</b> ഇനിയും പിന്തുണയില്ല.\n</body></html>"},
            {MenuLangId::Burmese, "<html><body>\nDS firmware ဘာသာစကား ဆက်တင်ကို ဖတ်ပြီး ဂိမ်းကို ထိုဘာသာစကားဖြင့် ပြရန် ပြောင်းလဲသည်။\n<br>\nEU ROM တွင် ဝှက်ထားသော ဂျပန်ရွေးချယ်စရာ ရှိပြီး DS firmware ဂျပန်ဘာသာ ဖြစ်လျှင် ဖွင့်မည်။\n<br><br>\n<b>EU / US ROM:</b> နေရာအားလုံးတွင် အလုပ်လုပ်သည် (အများကစား နှင့် စွန့်စားခန်း)။\n<br>\n<b>JP ROM:</b> အများကစားသာ။ <font color=\"red\"><b>ဖွင့်ပါက စွန့်စားခန်း မကစားနိုင်ပါ။</b></font>\n<br>\n<b>KR ROM:</b> မထောက်ပံ့သေးပါ။\n</body></html>"},
            {MenuLangId::Uzbek, "<html><body>\nDS firmware til sozlamasini oʻqib, oʻyinni shu tilda koʻrsatish uchun moslaydi.\n<br>\nEU ROMʼda yashirin yaponcha tanlov bor; DS firmware yaponcha boʻlsa, u faollashadi.\n<br><br>\n<b>EU / US ROM:</b> hamma joyda ishlaydi (koʻp oʻyinchi va sarguzasht).\n<br>\n<b>JP ROM:</b> faqat koʻp oʻyinchi. <font color=\"red\"><b>Faollashtirilsa, sarguzashtni oʻynab boʻlmaydi.</b></font>\n<br>\n<b>KR ROM:</b> hali qoʻllab-quvvatlanmaydi.\n</body></html>"},
            {MenuLangId::Azerbaijani, "<html><body>\nDS firmware dil ayarını oxuyur və oyunu həmin dildə göstərmək üçün uyğunlaşdırır.\n<br>\nEU ROM-da gizli yapon seçimi var; DS firmware yaponca olarsa aktiv olur.\n<br><br>\n<b>EU / US ROM:</b> hər yerdə işləyir (çoxoyunçulu və macəra).\n<br>\n<b>JP ROM:</b> yalnız çoxoyunçulu. <font color=\"red\"><b>Aktiv edilərsə, macəra oynanmayacaq.</b></font>\n<br>\n<b>KR ROM:</b> hələ dəstəklənmir.\n</body></html>"},
            {MenuLangId::Nepali, "<html><body>\nDS firmware भाषा सेटिङ पढेर खेललाई त्यही भाषामा देखाउन मिलाउँछ।\n<br>\nEU ROM मा लुकेको जापानी विकल्प छ; DS firmware जापानी भएमा यो सक्रिय हुन्छ।\n<br><br>\n<b>EU / US ROM:</b> सबै ठाउँमा काम गर्छ (बहु खेलाडी र साहसिक)।\n<br>\n<b>JP ROM:</b> केवल बहु खेलाडी। <font color=\"red\"><b>सक्रिय गरेमा साहसिक खेल्न सकिँदैन।</b></font>\n<br>\n<b>KR ROM:</b> अझै समर्थित छैन।\n</body></html>"},
            {MenuLangId::Sinhala, "<html><body>\nDS firmware භාෂා සැකසුම කියවා ක්‍රීඩාව ඒ භාෂාවෙන් පෙන්වීමට සකසයි.\n<br>\nEU ROM හි සඟවා ඇති ජපන් විකල්පයක් ඇත; DS firmware ජපන් නම් එය සක්‍රීය වේ.\n<br><br>\n<b>EU / US ROM:</b> සෑම තැනකම ක්‍රියා කරයි (බහු ක්‍රීඩක සහ සැරිසරීම).\n<br>\n<b>JP ROM:</b> බහු ක්‍රීඩක පමණි. <font color=\"red\"><b>සක්‍රීය කළොත් සැරිසරීම ක්‍රීඩා කළ නොහැක.</b></font>\n<br>\n<b>KR ROM:</b> තවම සහාය නැත.\n</body></html>"},
            {MenuLangId::Khmer, "<html><body>\nអានការកំណត់ភាសា DS firmware ហើយកែហ្គេមឱ្យបង្ហាញជាភាសានោះ។\n<br>\nEU ROM មានជម្រើសជប៉ុនលាក់ ដែលសកម្មនៅពេល DS firmware ជាភាសាជប៉ុន។\n<br><br>\n<b>EU / US ROM:</b> ដំណើរការគ្រប់ផ្នែក (អ្នកលេងច្រើន និង ផ្សងព្រេង)។\n<br>\n<b>JP ROM:</b> អ្នកលេងច្រើនប៉ុណ្ណោះ។ <font color=\"red\"><b>បើបើក នឹងមិនអាចលេងផ្នែកផ្សងព្រេងបានទេ។</b></font>\n<br>\n<b>KR ROM:</b> មិនទាន់គាំទ្រ។\n</body></html>"},
            {MenuLangId::Lao, "<html><body>\nອ່ານການຕັ້ງຄ່າພາສາ DS firmware ແລະປັບເກມໃຫ້ສະແດງເປັນພາສານັ້ນ.\n<br>\nEU ROM ມີຕົວເລືອກພາສາຍີ່ປຸ່ນທີ່ເຊື່ອງ ເຊິ່ງໃຊ້ໄດ້ເມື່ອ DS firmware ເປັນພາສາຍີ່ປຸ່ນ.\n<br><br>\n<b>EU / US ROM:</b> ເຮັດວຽກໃນທຸກສ່ວນ (ຫຼາຍຜູ້ຫຼິ້ນ ແລະ ຜະຈົນໄພ).\n<br>\n<b>JP ROM:</b> ຫຼາຍຜູ້ຫຼິ້ນເທົ່ານັ້ນ. <font color=\"red\"><b>ຖ້າເປີດ ຈະບໍ່ສາມາດຫຼິ້ນສ່ວນຜະຈົນໄພໄດ້.</b></font>\n<br>\n<b>KR ROM:</b> ຍັງບໍ່ຮອງຮັບ.\n</body></html>"},
            {MenuLangId::Armenian, "<html><body>\nԿարդում է DS firmware-ի լեզվի կարգավորումը և խաղը հարմարեցնում այդ լեզվով ցուցադրելու համար։\n<br>\nEU ROM-ում կա թաքնված ճապոներեն տարբերակ, որը ակտիվանում է, երբ DS firmware-ը ճապոներեն է։\n<br><br>\n<b>EU / US ROM:</b> աշխատում է ամենուր (բազմախաղացող և արկած)։\n<br>\n<b>JP ROM:</b> միայն բազմախաղացող։ <font color=\"red\"><b>Եթե ակտիվացնեք, արկածը խաղալ չի լինի։</b></font>\n<br>\n<b>KR ROM:</b> դեռ չի աջակցվում։\n</body></html>"},
            {MenuLangId::Albanian, "<html><body>\nLexon rregullimin e gjuhës së DS firmware dhe përshtat lojën që të shfaqet në atë gjuhë.\n<br>\nEU ROM ka një opsion të fshehur japonisht, që aktivizohet kur DS firmware është në japonisht.\n<br><br>\n<b>EU / US ROM:</b> punon kudo (me shumë lojtarë dhe aventurë).\n<br>\n<b>JP ROM:</b> vetëm me shumë lojtarë. <font color=\"red\"><b>Nëse aktivizohet, aventura nuk mund të luhet.</b></font>\n<br>\n<b>KR ROM:</b> ende nuk mbështetet.\n</body></html>"},
            {MenuLangId::Georgian, "<html><body>\nკითხულობს DS firmware-ის ენის პარამეტრს და თამაშს იმ ენაზე გამოსაჩენად მოარგებს.\n<br>\nEU ROM-ში არის დამალული იაპონური ვარიანტი, რომელიც აქტიურდება, როცა DS firmware იაპონურია.\n<br><br>\n<b>EU / US ROM:</b> მუშაობს ყველგან (მრავალმოთამაშიანი და თავგადასავალი).\n<br>\n<b>JP ROM:</b> მხოლოდ მრავალმოთამაშიანი. <font color=\"red\"><b>ჩართვისას თავგადასავლის თამაში შეუძლებელია.</b></font>\n<br>\n<b>KR ROM:</b> ჯერ მხარდაჭერილი არ არის.\n</body></html>"},
            {MenuLangId::Bosnian, "<html><body>\nČita jezičku postavku DS firmwarea i prilagođava igru da se prikaže na tom jeziku.\n<br>\nEU ROM ima skrivenu japansku opciju koja se aktivira ako je DS firmware na japanskom.\n<br><br>\n<b>EU / US ROM:</b> radi svuda (više igrača i avantura).\n<br>\n<b>JP ROM:</b> samo više igrača. <font color=\"red\"><b>Ako se omogući, avantura se ne može igrati.</b></font>\n<br>\n<b>KR ROM:</b> još nije podržano.\n</body></html>"},
            {MenuLangId::Serbian, "<html><body>\nЧита језичку поставку DS firmware-а и прилагођава игру да се прикаже на том језику.\n<br>\nEU ROM има скривену јапанску опцију која се активира ако је DS firmware на јапанском.\n<br><br>\n<b>EU / US ROM:</b> ради свуда (више играча и авантура).\n<br>\n<b>JP ROM:</b> само више играча. <font color=\"red\"><b>Ако се омогући, авантура се не може играти.</b></font>\n<br>\n<b>KR ROM:</b> још није подржано.\n</body></html>"},
            {MenuLangId::Macedonian, "<html><body>\nГо чита јазичното поставување на DS firmware и ја приспособува играта да се прикаже на тој јазик.\n<br>\nEU ROM има скриена јапонска опција која се активира ако DS firmware е на јапонски.\n<br><br>\n<b>EU / US ROM:</b> работи секаде (повеќе играчи и авантура).\n<br>\n<b>JP ROM:</b> само повеќе играчи. <font color=\"red\"><b>Ако се овозможи, авантурата не може да се игра.</b></font>\n<br>\n<b>KR ROM:</b> сè уште не е поддржано.\n</body></html>"},
            {MenuLangId::Bulgarian, "<html><body>\nЧете езиковата настройка на DS firmware и приспособява играта да се показва на този език.\n<br>\nEU ROM има скрита японска опция, която се активира, ако DS firmware е на японски.\n<br><br>\n<b>EU / US ROM:</b> работи навсякъде (много играчи и приключение).\n<br>\n<b>JP ROM:</b> само много играчи. <font color=\"red\"><b>Ако се включи, приключението не може да се играе.</b></font>\n<br>\n<b>KR ROM:</b> все още не се поддържа.\n</body></html>"},
            {MenuLangId::Belarusian, "<html><body>\nЧытае моўную наладу DS firmware і прыстасоўвае гульню для паказу на гэтай мове.\n<br>\nEU ROM мае схаваную японскую опцыю, якая актывуецца, калі DS firmware на японскай мове.\n<br><br>\n<b>EU / US ROM:</b> працуе ўсюды (шмат гульцоў і прыгода).\n<br>\n<b>JP ROM:</b> толькі шмат гульцоў. <font color=\"red\"><b>Калі ўключыць, прыгоду нельга будзе гуляць.</b></font>\n<br>\n<b>KR ROM:</b> пакуль не падтрымліваецца.\n</body></html>"},
            {MenuLangId::Maltese, "<html><body>\nJaqra l-issettjar tal-lingwa tad-DS firmware u jadatta l-logħba biex tidher b’dik il-lingwa.\n<br>\nEU ROM għandu għażla Ġappuniża moħbija li tiġi attivata meta d-DS firmware ikun bil-Ġappuniż.\n<br><br>\n<b>EU / US ROM:</b> jaħdem kullimkien (bosta plejers u avventura).\n<br>\n<b>JP ROM:</b> bosta plejers biss. <font color=\"red\"><b>Jekk jiġi attivat, l-avventura ma tistax tintlagħab.</b></font>\n<br>\n<b>KR ROM:</b> għadu mhux appoġġjat.\n</body></html>"},
            {MenuLangId::Mongolian, "<html><body>\nDS firmware-ийн хэлний тохиргоог уншиж, тоглоомыг тэр хэлээр харуулахын тулд тохируулна.\n<br>\nEU ROM нь нуусан япон хэлний сонголттой бөгөөд DS firmware япон хэлтэй үед идэвхжинэ.\n<br><br>\n<b>EU / US ROM:</b> бүх хэсэгт ажиллана (олон тоглогч болон адал явдал).\n<br>\n<b>JP ROM:</b> зөвхөн олон тоглогч. <font color=\"red\"><b>Идэвхжүүлбэл адал явдлыг тоглох боломжгүй.</b></font>\n<br>\n<b>KR ROM:</b> одоогоор дэмжигдээгүй.\n</body></html>"},
            {MenuLangId::Latvian, "<html><body>\nNolasa DS firmware valodas iestatījumu un pielāgo spēli attēlošanai šajā valodā.\n<br>\nEU ROM ir slēpta japāņu opcija, kas aktivizējas, ja DS firmware ir japāņu valodā.\n<br><br>\n<b>EU / US ROM:</b> darbojas visur (vairāki spēlētāji un piedzīvojums).\n<br>\n<b>JP ROM:</b> tikai vairāki spēlētāji. <font color=\"red\"><b>Ja ieslēgts, piedzīvojumu nevar spēlēt.</b></font>\n<br>\n<b>KR ROM:</b> vēl netiek atbalstīts.\n</body></html>"},
            {MenuLangId::Lithuanian, "<html><body>\nNuskaito DS firmware kalbos nustatymą ir pritaiko žaidimą rodyti ta kalba.\n<br>\nEU ROM turi paslėptą japonų parinktį, kuri aktyvuojama, kai DS firmware yra japonų kalba.\n<br><br>\n<b>EU / US ROM:</b> veikia visur (keli žaidėjai ir nuotykis).\n<br>\n<b>JP ROM:</b> tik keli žaidėjai. <font color=\"red\"><b>Įjungus nuotykio žaisti negalima.</b></font>\n<br>\n<b>KR ROM:</b> dar nepalaikoma.\n</body></html>"},
            {MenuLangId::Afrikaans, "<html><body>\nLees die DS firmware-taalinstelling en pas die spel aan om in daardie taal te vertoon.\n<br>\nEU ROM het ’n versteekte Japannese opsie wat aktiveer wanneer DS firmware op Japans is.\n<br><br>\n<b>EU / US ROM:</b> werk oral (veelspeler en avontuur).\n<br>\n<b>JP ROM:</b> net veelspeler. <font color=\"red\"><b>As dit aangeskakel is, kan die avontuur nie gespeel word nie.</b></font>\n<br>\n<b>KR ROM:</b> nog nie ondersteun nie.\n</body></html>"},
            {MenuLangId::Irish, "<html><body>\nLéann sé socrú teanga DS firmware agus cuireann sé an cluiche in oiriúint don teanga sin.\n<br>\nTá rogha Sheapáinise i bhfolach ag EU ROM, a ghníomhachtaítear nuair atá DS firmware i Seapáinis.\n<br><br>\n<b>EU / US ROM:</b> oibríonn sé i ngach áit (il-imreoir agus eachtra).\n<br>\n<b>JP ROM:</b> il-imreoir amháin. <font color=\"red\"><b>Má chumasaítear é, ní féidir an eachtra a imirt.</b></font>\n<br>\n<b>KR ROM:</b> níl sé tacaithe fós.\n</body></html>"},
            {MenuLangId::Assamese, "<html><body>\nDS firmware ভাষা ছেটিং পঢ়ি, গেমটো সেই ভাষাত দেখুৱাবলৈ মিলায়।\n<br>\nEU ROM-ত লুকুৱা জাপানী বিকল্প আছে; DS firmware জাপানী হলে ই সক্ৰিয় হয়।\n<br><br>\n<b>EU / US ROM:</b> সকলো ঠাইত কাম কৰে (বহু খেলুৱৈ আৰু অভিযান)।\n<br>\n<b>JP ROM:</b> কেৱল বহু খেলুৱৈ। <font color=\"red\"><b>সক্ৰিয় কৰিলে অভিযান খেলিব নোৱাৰি।</b></font>\n<br>\n<b>KR ROM:</b> এতিয়াও সমৰ্থিত নহয়।\n</body></html>"},
            {MenuLangId::Amharic, "<html><body>\nየDS firmware የቋንቋ ቅንብርን ያነባል እና ጨዋታውን በዚያ ቋንቋ እንዲታይ ያስተካክላል።\n<br>\nEU ROM የተደበቀ የጃፓንኛ አማራጭ አለው፤ DS firmware ጃፓንኛ ከሆነ ይነቃል።\n<br><br>\n<b>EU / US ROM:</b> በሁሉም ክፍል ይሰራል (ብዙ ተጫዋቾች እና ጀብዱ)።\n<br>\n<b>JP ROM:</b> ብዙ ተጫዋቾች ብቻ። <font color=\"red\"><b>ካነቁት ጀብዱን መጫወት አይቻልም።</b></font>\n<br>\n<b>KR ROM:</b> ገና አይደገፍም።\n</body></html>"},
            {MenuLangId::Estonian, "<html><body>\nLoeb DS firmware keele seadistuse ja kohandab mängu selles keeles kuvamiseks.\n<br>\nEU ROMis on peidetud jaapani valik, mis aktiveerub, kui DS firmware on jaapani keeles.\n<br><br>\n<b>EU / US ROM:</b> töötab kõikjal (mitmikmäng ja seiklus).\n<br>\n<b>JP ROM:</b> ainult mitmikmäng. <font color=\"red\"><b>Kui see on sisse lülitatud, ei saa seiklust mängida.</b></font>\n<br>\n<b>KR ROM:</b> pole veel toetatud.\n</body></html>"},
            {MenuLangId::Kazakh, "<html><body>\nDS firmware тіл баптауын оқып, ойынды сол тілде көрсетуге бейімдейді.\n<br>\nEU ROM ішінде жасырын жапон тілі таңдауы бар; DS firmware жапонша болса, ол іске қосылады.\n<br><br>\n<b>EU / US ROM:</b> барлық жерде жұмыс істейді (көп ойыншы және шытырман оқиға).\n<br>\n<b>JP ROM:</b> тек көп ойыншы. <font color=\"red\"><b>Қосылса, шытырман оқиғаны ойнауға болмайды.</b></font>\n<br>\n<b>KR ROM:</b> әзірге қолдау жоқ.\n</body></html>"},
            {MenuLangId::Catalan, "<html><body>\nLlegeix la configuració d’idioma del DS firmware i adapta el joc perquè es mostri en aquest idioma.\n<br>\nEU ROM té una opció japonesa oculta que s’activa quan el DS firmware és en japonès.\n<br><br>\n<b>EU / US ROM:</b> funciona a tot arreu (multijugador i aventura).\n<br>\n<b>JP ROM:</b> només multijugador. <font color=\"red\"><b>Si està activat, no es pot jugar l’aventura.</b></font>\n<br>\n<b>KR ROM:</b> encara no compatible.\n</body></html>"},
            {MenuLangId::Kyrgyz, "<html><body>\nDS firmware тил жөндөөсүн окуп, оюнду ошол тилде көрсөтүүгө ылайыкташтырат.\n<br>\nEU ROM ичинде жашырылган жапон тили тандоосу бар; DS firmware жапончо болсо, ал активдешет.\n<br><br>\n<b>EU / US ROM:</b> бардык жерде иштейт (көп оюнчу жана укмуштуу окуя).\n<br>\n<b>JP ROM:</b> көп оюнчу гана. <font color=\"red\"><b>Иштетилсе, укмуштуу окуяны ойноого болбойт.</b></font>\n<br>\n<b>KR ROM:</b> азырынча колдоого алынбайт.\n</body></html>"},
            {MenuLangId::Slovak, "<html><body>\nČíta nastavenie jazyka DS firmware a upravuje hru, aby sa zobrazovala v tomto jazyku.\n<br>\nEU ROM má skrytú japonskú možnosť, ktorá sa aktivuje, keď je DS firmware v japončine.\n<br><br>\n<b>EU / US ROM:</b> funguje všade (hra viacerých hráčov a dobrodružstvo).\n<br>\n<b>JP ROM:</b> iba hra viacerých hráčov. <font color=\"red\"><b>Ak je zapnuté, dobrodružstvo sa nedá hrať.</b></font>\n<br>\n<b>KR ROM:</b> zatiaľ nie je podporované.\n</body></html>"},
            {MenuLangId::Slovenian, "<html><body>\nPrebere nastavitev jezika DS firmware in prilagodi igro, da se prikaže v tem jeziku.\n<br>\nEU ROM ima skrito japonsko možnost, ki se aktivira, ko je DS firmware v japonščini.\n<br><br>\n<b>EU / US ROM:</b> deluje povsod (več igralcev in pustolovščina).\n<br>\n<b>JP ROM:</b> samo več igralcev. <font color=\"red\"><b>Če je omogočeno, pustolovščine ni mogoče igrati.</b></font>\n<br>\n<b>KR ROM:</b> za zdaj ni podprto.\n</body></html>"},
            {MenuLangId::Zulu, "<html><body>\nIfunda ukulungiselelwa kolimi kwe-DS firmware bese ilungisa umdlalo ukuze uboniswe ngalolo limi.\n<br>\nEU ROM inenketho efihliwe yesiJapane, esebenza uma i-DS firmware isiJapane.\n<br><br>\n<b>EU / US ROM:</b> isebenza kuyo yonke indawo (abadlali abaningi nohambo).\n<br>\n<b>JP ROM:</b> abadlali abaningi kuphela. <font color=\"red\"><b>Uma kuvuliwe, uhambo alunakudlalwa.</b></font>\n<br>\n<b>KR ROM:</b> okwamanje ayikasekelwa.\n</body></html>"},
            {MenuLangId::Basque, "<html><body>\nDS firmware hizkuntza-ezarpena irakurtzen du eta jokoa hizkuntza horretan erakusteko egokitzen du.\n<br>\nEU ROM-ek japonierazko aukera ezkutua dauka, DS firmware japonieraz dagoenean aktibatzen dena.\n<br><br>\n<b>EU / US ROM:</b> edonon dabil (jokalari anitzekoa eta abentura).\n<br>\n<b>JP ROM:</b> jokalari anitzekoa bakarrik. <font color=\"red\"><b>Gaituta badago, abentura ezin da jokatu.</b></font>\n<br>\n<b>KR ROM:</b> oraindik ez dago onartuta.\n</body></html>"},
            {MenuLangId::Hebrew, "<html><body>\nקורא את הגדרת השפה של DS firmware ומתאים את המשחק להצגה בשפה הזו.\n<br>\nל-EU ROM יש אפשרות יפנית מוסתרת, שמופעלת כאשר DS firmware מוגדר ליפנית.\n<br><br>\n<b>EU / US ROM:</b> עובד בכל מקום (רב משתתפים והרפתקה).\n<br>\n<b>JP ROM:</b> רב משתתפים בלבד. <font color=\"red\"><b>אם מופעל, אי אפשר לשחק בהרפתקה.</b></font>\n<br>\n<b>KR ROM:</b> עדיין לא נתמך.\n</body></html>"},
        }
