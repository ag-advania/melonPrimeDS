    {
        "lblMetroidExpandStageMatrixExtraDesc",
        {
            {MenuLangId::Japanese, "<html><body>\n基本選択に加えて、さらに9個の組み合わせを解放します。<br><br>\n<b>バトル / ノード / プライムハンター / サバイバル</b><br>\n&nbsp;&nbsp;トランスファーロック・ワイド (Transfer Lock Wide) — 通常重力<br><br>\n<b>ディフェンダー</b><br>\n&nbsp;&nbsp;トランスファーロック (Transfer Lock) — ディフェンダーリングなし、ボルトドライバー + バトルハンマーのみ<br>\n&nbsp;&nbsp;コンプレッサールーム (Compression Chamber) — ディフェンダーリングなし、ジャンパーなし、アイテムなし<br>\n&nbsp;&nbsp;インキュベーションルーム (Incubation Vault) — ディフェンダーリングなし、アイテムとジャンパーあり<br>\n&nbsp;&nbsp;フュールスタック (Fuel Stack) — ディフェンダーリングなし、浮遊なし、インペリアリストのみ<br>\n&nbsp;&nbsp;ヘッドショット (Head Shot) — ディフェンダーリングなし、通常重力、ジャンパー2個、トランスフォーム通路は射出なし\n</body></html>"},
            {MenuLangId::German, "<html><body>\nSchaltet zusätzlich zu den Basiseinträgen 9 weitere Kombinationen frei.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Weite Transferschleuse (Transfer Lock Wide) — normale Schwerkraft<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Transferschleuse (Transfer Lock) — ohne Defender-Ring, nur Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;Druckkammer (Compression Chamber) — ohne Defender-Ring, ohne Sprungplattform, ohne Gegenstände<br>\n&nbsp;&nbsp;Brutraum (Incubation Vault) — ohne Defender-Ring, mit Gegenstände und Sprungplattform<br>\n&nbsp;&nbsp;Treibstofflager (Fuel Stack) — ohne Defender-Ring, ohne Schweben, nur Imperialist<br>\n&nbsp;&nbsp;Kopfschuss (Head Shot) — ohne Defender-Ring, normale Schwerkraft, 2 Sprungplattform, Umwandlung-Pfad ohne Abschuss\n</body></html>"},
            {MenuLangId::Spanish, "<html><body>\nDesbloquea 9 combinaciones adicionales además de las selecciones básicas.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Esclusa transbordo amplia (Transfer Lock Wide) — gravedad normal<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Esclusa transbordo (Transfer Lock) — sin anillo Defender, solo Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;Cámara de compresión (Compression Chamber) — sin anillo Defender, sin plataforma de salto, sin ítems<br>\n&nbsp;&nbsp;Sala de incubación (Incubation Vault) — sin anillo Defender, con ítems y una plataforma de salto<br>\n&nbsp;&nbsp;Esclusa combustible (Fuel Stack) — sin anillo Defender, sin flotación, solo Imperialist<br>\n&nbsp;&nbsp;Impacto mortal (Head Shot) — sin anillo Defender, gravedad normal, 2 plataformas de salto, sin lanzamiento en el pasillo de transformación\n</body></html>"},
            {MenuLangId::French, "<html><body>\nDébloque 9 combinaisons supplémentaires en plus de la sélection de base.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Verrouillage large (Transfer Lock Wide) — gravité normale<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Verrouillage (Transfer Lock) — sans anneau Defender, Volt Driver + Battlehammer uniquement<br>\n&nbsp;&nbsp;Compression (Compression Chamber) — sans anneau Defender, sans tremplin, sans objets<br>\n&nbsp;&nbsp;Incubation (Incubation Vault) — sans anneau Defender, avec objets et tremplin<br>\n&nbsp;&nbsp;Fuel (Fuel Stack) — sans anneau Defender, sans flottation, Imperialist uniquement<br>\n&nbsp;&nbsp;Headshot (Head Shot) — sans anneau Defender, gravité normale, 2 tremplins, passage transformation sans éjection\n</body></html>"},
            {MenuLangId::Italian, "<html><body>\nSblocca 9 combinazioni aggiuntive oltre alla selezione base.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Blocco Transfer ampio (Transfer Lock Wide) — gravità normale<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Blocco Transfer (Transfer Lock) — senza anello Defender, solo Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;Camera compressione (Compression Chamber) — senza anello Defender, senza trampolino, senza oggetti<br>\n&nbsp;&nbsp;Sala incubazione (Incubation Vault) — senza anello Defender, con oggetti e trampolino<br>\n&nbsp;&nbsp;Deposito carburante (Fuel Stack) — senza anello Defender, senza fluttuazione, solo Imperialist<br>\n&nbsp;&nbsp;Colpo in testa (Head Shot) — senza anello Defender, gravità normale, 2 trampolino, corridoio trasformazione senza espulsione\n</body></html>"},
            {MenuLangId::Dutch, "<html><body>\nOntgrendelt 9 extra combinaties naast de basisselectie.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Brede transfersluis (Transfer Lock Wide) — normale zwaartekracht<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Transfersluis (Transfer Lock) — zonder Defender-ring, alleen Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;Compressorkamer (Compression Chamber) — zonder Defender-ring, zonder springplatform, zonder voorwerpen<br>\n&nbsp;&nbsp;Broedkamer (Incubation Vault) — zonder Defender-ring, met voorwerpen en springplatform<br>\n&nbsp;&nbsp;Brandstofopslag (Fuel Stack) — zonder Defender-ring, zonder zweven, alleen Imperialist<br>\n&nbsp;&nbsp;Hoofdschot (Head Shot) — zonder Defender-ring, normale zwaartekracht, 2 springplatformen, transformatie-pad zonder afschieten\n</body></html>"},
            {MenuLangId::Portuguese, "<html><body>\nDesbloqueia 9 combinações adicionais além da seleção base.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Bloqueio de transferência amplo (Transfer Lock Wide) — gravidade normal<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Bloqueio de transferência (Transfer Lock) — sem anel Defender, apenas Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;Câmara do compressor (Compression Chamber) — sem anel Defender, sem plataforma de impulso, sem itens<br>\n&nbsp;&nbsp;Incubadora (Incubation Vault) — sem anel Defender, com itens e plataforma de impulso<br>\n&nbsp;&nbsp;Depósito de combustível (Fuel Stack) — sem anel Defender, sem flutuação, apenas Imperialist<br>\n&nbsp;&nbsp;Tiro na cabeça (Head Shot) — sem anel Defender, gravidade normal, 2 plataformas de impulso, corredor de transformação sem expulsão\n</body></html>"},
            {MenuLangId::Russian, "<html><body>\nРазблокирует 9 дополнительных комбинаций помимо базового выбора.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Широкий трансферный шлюз (Transfer Lock Wide) — обычная гравитация<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Трансферный шлюз (Transfer Lock) — без кольца Defender, только Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;Компрессорная камера (Compression Chamber) — без кольца Defender, без прыгуна, без предметов<br>\n&nbsp;&nbsp;Инкубатор (Incubation Vault) — без кольца Defender, с предметами и прыгуном<br>\n&nbsp;&nbsp;Топливный склад (Fuel Stack) — без кольца Defender, без парения, только Imperialist<br>\n&nbsp;&nbsp;Выстрел в голову (Head Shot) — без кольца Defender, обычная гравитация, 2 прыгуна, трансформ-коридор без выброса\n</body></html>"},
            {MenuLangId::ChineseSimplified, "<html><body>\n在基本选择之外再解锁 9 个组合。\n<br><br>\n<b>战斗 / 节点 / Prime Hunter / 生存</b><br>\n&nbsp;&nbsp;宽型传送锁 (Transfer Lock Wide) — 正常重力<br><br>\n<b>防守</b><br>\n&nbsp;&nbsp;传送锁 (Transfer Lock) — 无防守环，仅 Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;压缩机室 (Compression Chamber) — 无防守环，无跳跃台，无道具<br>\n&nbsp;&nbsp;孵化室 (Incubation Vault) — 无防守环，有道具与跳跃台<br>\n&nbsp;&nbsp;燃料堆栈 (Fuel Stack) — 无防守环，无漂浮，仅 Imperialist<br>\n&nbsp;&nbsp;爆头 (Head Shot) — 无防守环，正常重力，2 个跳跃台，变形通道无弹射\n</body></html>"},
