{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "description": "Base configuration",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "base-vcpkg",
      "inherits": "base",
      "description": "Base configuration with vcpkg",
      "cacheVariables": {
        "USE_VCPKG": {
          "type": "BOOL",
          "value": "ON"
        },
        "BUILD_STATIC": {
          "type": "BOOL",
          "value": "ON"
        }
      },
      "hidden": true
    },
    {
      "name": "release",
      "inherits": "base",
      "description": "Generic release build",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "release-mingw-x86_64",
      "inherits": "base-vcpkg",
      "displayName": "Windows MinGW Release (x64)",
      "condition": {
        "type": "notEquals",
        "lhs": "$env{MINGW_PREFIX}",
        "rhs": ""
      }
    },
    {
      "name": "rebuild-mingw-x86_64",
      "inherits": "release-mingw-x86_64",
      "displayName": "Windows MinGW Vulkan Sapphire Rebuild, exact-pinned, symbolizable (x64)",
      "description": "Dedicated clean tree for vulkan_sapphire_desktop_rebuild (S81-1): exact-pinned GPU2D, no Desktop rebuild heuristics/features, diagnostic symbols with LTO/strip disabled so crash RVAs are addr2line-resolvable.",
      "cacheVariables": {
        "MELONPRIME_ENABLE_VULKAN": "ON",
        "MELONPRIME_ENABLE_DEVELOPER_FEATURES": "ON",
        "MELONPRIME_SAPPHIRE_REBUILD": "ON",
        "MELONPRIME_SAPPHIRE_REBUILD_SOLID_COLOR": "OFF",
        "MELONPRIME_SAPPHIRE_REBUILD_FEATURES": "OFF",
        "MELONPRIME_SAPPHIRE_GPU2D_EXACT_PIN": "ON",
        "MELONPRIME_DIAGNOSTIC_SYMBOLS": "ON",
        "ENABLE_LTO_RELEASE": "OFF"
      }
    },
    {
      "name": "base-windows",
      "inherits": "base-vcpkg",
      "description": "Base settings for Windows VS builds",
      "hidden": true,
      "displayName": "Windows base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang.exe",
        "CMAKE_CXX_COMPILER": "clang++.exe",
        "CMAKE_RC_COMPILER": "llvm-rc.exe"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": [ "Windows" ]
        }
      }
    },
    {
      "name": "release-windows-x86_64",
      "inherits": "base-windows",
      "displayName": "Windows Release (x64)",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "debug-windows-x86_64",
      "inherits": "release-windows-x86_64",
      "displayName": "Windows Debug (x64)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-windows-arm64",
      "inherits": "base-windows",
      "displayName": "Windows Release (ARM64)",
      "architecture": {
        "value": "arm64",
        "strategy": "external"
      }
    },
    {
      "name": "debug-windows-arm64",
      "inherits": "release-windows-arm64",
      "displayName": "Windows Debug (ARM64)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-mac-x86_64",
      "inherits": "base-vcpkg",
      "displayName": "macOS release (x86_64)",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "x86_64"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "release-mac-arm64",
      "inherits": "base-vcpkg",
      "displayName": "macOS release (arm64)",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "displayName": "Release"
    },
    {
      "name": "release-mingw-x86_64",
      "configurePreset": "release-mingw-x86_64",
      "displayName": "MinGW Release (x86_64)"
    },
    {
      "name": "rebuild-mingw-x86_64",
      "configurePreset": "rebuild-mingw-x86_64",
      "displayName": "MinGW Vulkan Sapphire Rebuild, exact-pinned, symbolizable (x86_64)"
    },
    {
      "name": "release-windows-x86_64",
      "configurePreset": "release-windows-x86_64",
      "displayName": "Windows Release (x64)"
    },
    {
      "name": "debug-windows-x86_64",
      "configurePreset": "debug-windows-x86_64",
      "displayName": "Windows Debug (x64)"
    },
    {
      "name": "release-windows-arm64",
      "configurePreset": "release-windows-arm64",
      "displayName": "Windows Release (ARM64)"
    },
    {
      "name": "debug-windows-arm64",
      "configurePreset": "debug-windows-arm64",
      "displayName": "Windows Debug (ARM64)"
    },
    {
      "name": "release-mac-x86_64",
      "configurePreset": "release-mac-x86_64",
      "displayName": "macOS Release (x86_64)"
    },
    {
      "name": "release-mac-arm64",
      "configurePreset": "release-mac-arm64",
      "displayName": "macOS Release (arm64)"
    }
  ]
}
