+struct ImageResource
+{
+    VkImage Image = VK_NULL_HANDLE;
+    VkDeviceMemory Memory = VK_NULL_HANDLE;
+    VkImageView View = VK_NULL_HANDLE;
+    VkImageLayout Layout = VK_IMAGE_LAYOUT_UNDEFINED;
+    VkFormat Format = VK_FORMAT_UNDEFINED;
+    VkExtent2D Extent{};
+};
