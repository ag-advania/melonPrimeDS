-        for (int i = 0; i < 3; i++)
-        {
-            OSDItem& item = splashText[i];
-
-            if (!osdTextures.count(item.id))
-                continue;
-
-            glBindTexture(GL_TEXTURE_2D, osdTextures[item.id]);
-            glUniform2i(osdPosULoc, splashPos[i].x(), splashPos[i].y());
