@echo off
setlocal EnableExtensions DisableDelayedExpansion

set "DO_BUILD=1"
set "REPO_ROOT="

if /I "%~1"=="--help" goto help
if /I "%~1"=="-h" goto help
if /I "%~1"=="--no-build" set "DO_BUILD=0"

rem This patch is intended to be placed in the melonPrimeDS repository root.
if exist "%~dp0CMakeLists.txt" if exist "%~dp0src\GPU_Vulkan.cpp" set "REPO_ROOT=%~dp0"
if not defined REPO_ROOT if exist "%CD%\CMakeLists.txt" if exist "%CD%\src\GPU_Vulkan.cpp" set "REPO_ROOT=%CD%"
if not defined REPO_ROOT if exist "C:\Users\Admin\Documents\git\melonPrimeDS\CMakeLists.txt" set "REPO_ROOT=C:\Users\Admin\Documents\git\melonPrimeDS"

if not defined REPO_ROOT (
    echo [structured-3d] ERROR: melonPrimeDS repository was not found.
    echo [structured-3d] Place this BAT in the repository root and run it again.
    pause
    exit /b 2
)

rem Normalize through "\." so a repository discovered via %%~dp0 does not
rem retain a trailing backslash. A trailing backslash immediately before the
rem closing quote can be passed to powershell.exe as a literal quote character.
for %%I in ("%REPO_ROOT%\.") do set "REPO_ROOT=%%~fI"
if "%REPO_ROOT:~-1%"=="\" set "REPO_ROOT=%REPO_ROOT:~0,-1%"

echo ============================================================
echo  MelonPrimeDS Vulkan - Structured 3D Composition Next Step v4
echo ============================================================
echo Repository: %REPO_ROOT%
echo.
echo This patch removes the remaining RGB-oracle gate for native
echo Vulkan 3D pixels by transporting the exact Software 2D effect:
echo direct, 3D alpha, EVA/EVB, brightness up, or brightness down.
echo.

set "SELF_BAT=%~f0"
set "PATCH_PS1=%TEMP%\melonprime_vulkan_structured_3d_%RANDOM%_%RANDOM%.ps1"
powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -Command ^
  "$raw = [IO.File]::ReadAllText($env:SELF_BAT); $marker = '__POWERSHELL_PAYLOAD__'; $index = $raw.LastIndexOf($marker, [StringComparison]::Ordinal); if ($index -lt 0) { Write-Error 'Embedded payload marker is missing.'; exit 3 }; $b64 = $raw.Substring($index + $marker.Length).Trim(); try { $bytes = [Convert]::FromBase64String($b64) } catch { Write-Error ('Embedded payload is invalid: ' + $_.Exception.Message); exit 3 }; [IO.File]::WriteAllBytes($env:PATCH_PS1, $bytes)"
if errorlevel 1 (
    echo [structured-3d] ERROR: Could not extract embedded PowerShell patch.
    pause
    exit /b 3
)

powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File "%PATCH_PS1%" -RepoRoot "%REPO_ROOT%"
set "PATCH_RESULT=%ERRORLEVEL%"
del /q "%PATCH_PS1%" >nul 2>&1
if not "%PATCH_RESULT%"=="0" (
    echo.
    echo [structured-3d] Patch failed. Original files were restored.
    pause
    exit /b %PATCH_RESULT%
)

where git.exe >nul 2>&1
if not errorlevel 1 (
    pushd "%REPO_ROOT%"
    git diff --check
    if errorlevel 1 (
        popd
        echo [structured-3d] ERROR: git diff --check failed.
        pause
        exit /b 4
    )
    echo.
    git diff --stat -- src/GPU_Soft.h src/GPU_Soft.cpp src/GPU2D_Soft.h src/GPU2D_Soft.cpp src/GPU_Vulkan.h src/GPU_Vulkan.cpp src/Vulkan_shaders/phase10_presenter.frag
    popd
)

if "%DO_BUILD%"=="0" (
    echo.
    echo [structured-3d] Patch applied. Build was skipped.
    echo [structured-3d] Run .claude\skills\build-mingw-vulkan.bat next.
    pause
    exit /b 0
)

set "BUILD_SCRIPT=%REPO_ROOT%\.claude\skills\build-mingw-vulkan.bat"
if not exist "%BUILD_SCRIPT%" (
    echo [structured-3d] ERROR: Build script is missing:
    echo   %BUILD_SCRIPT%
    echo [structured-3d] Source patch remains applied.
    pause
    exit /b 5
)

echo.
echo [structured-3d] Regenerating SPIR-V and building Vulkan-enabled Windows target...
call "%BUILD_SCRIPT%"
set "BUILD_RESULT=%ERRORLEVEL%"
if not "%BUILD_RESULT%"=="0" (
    echo.
    echo [structured-3d] ERROR: Vulkan build failed with exit code %BUILD_RESULT%.
    echo [structured-3d] Source patch remains applied; backup path was printed above.
    pause
    exit /b %BUILD_RESULT%
)

echo.
echo ============================================================
echo  SUCCESS
echo ============================================================
echo Native Vulkan 3D now receives the exact Software 2D
echo composition mode for direct, translucent, EVA/EVB and
echo brightness pixels. The low-resolution RGB parity oracle is
echo no longer used for ROM-visible native raster adoption.
echo.
pause
exit /b 0

:help
echo Place this BAT in the melonPrimeDS repository root.
echo.
echo Usage:
echo   %~nx0
echo   %~nx0 --no-build
echo.
echo The patch:
echo   - upgrades the explicit ownership bit to a per-pixel composition record
echo   - reproduces DS ColorBlend4, ColorBlend5 and brightness math in Vulkan
echo   - removes the remaining translucent RGB-equality gate
echo   - creates a complete backup before editing
echo   - regenerates SPIR-V and runs the Windows Vulkan build
exit /b 0

