+        const uint index = (value >> ((pixel & 1u) * 4u)) & 0xFu;
+        return mp_palette_texel(texturePalette, paletteAddress, index,
+            (texParam & (1u << 29u)) != 0u && index == 0u);
+    }
+    if (format == 4u)
+    {
+        const uint index = mp_read8(textureMemory, 0x7FFFFu, textureAddress + pixel);
+        return mp_palette_texel(texturePalette, paletteAddress, index,
