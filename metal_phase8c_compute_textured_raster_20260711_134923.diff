+        {
+        case 0u: colors[3] = 0u; break;
+        case 1u:
+            colors[2] = mp_mix_rgb555(colors[0], colors[1], 1u, 1u, 1u) | 0x8000u;
+            colors[3] = 0u;
+            break;
+        case 2u: break;
+        default:
+            colors[2] = mp_mix_rgb555(colors[0], colors[1], 5u, 3u, 3u) | 0x8000u;
+            colors[3] = mp_mix_rgb555(colors[0], colors[1], 3u, 5u, 3u) | 0x8000u;
+            break;
+        }
