+                        color0 = tileColor;
+                        depth0 = tileDepth;
+                        attr0 = opaqueAttr;
+                    }
+                    else
+                    {
+                        color1 = tileColor;
+                        depth1 = tileDepth;
+                        attr1 = opaqueAttr;
+                        secondLayerWrites++;
+                    }
+
+                    opaqueLayers++;
+                    layersAccepted++;
+                }
+                else
+                {
+                    const bool writeDepth =
+                        (polygonAttr & (1u << 11u)) != 0u;
+                    bool accepted = false;
+
+                    if (!writeSecondLayer)
+                    {
+                        accepted |= mpd_plot_translucent(
+                            color0,
+                            depth0,
+                            attr0,
+                            isShadow,
+                            tileColor,
+                            sourceAlpha,
+                            tileDepth,
+                            sourceAttr,
+                            writeDepth);
+                    }
+
+                    if (writeSecondLayer ||
+                        (destinationAttr & 0x3u) != 0u)
+                    {
+                        const bool secondAccepted =
+                            mpd_plot_translucent(
+                                color1,
+                                depth1,
+                                attr1,
+                                isShadow,
+                                tileColor,
+                                sourceAlpha,
+                                tileDepth,
+                                sourceAttr,
+                                writeDepth);
+                        accepted |= secondAccepted;
+                        if (secondAccepted)
+                            secondLayerWrites++;
+                    }
+
+                    if (accepted)
+                    {
+                        translucentLayers++;
+                        layersAccepted++;
+                    }
+                }
+            }
+            else
+            {
+                shadowMasks++;
+                if (!previousShadowMask)
+                    stencil = 0u;
+
+                if (!mpd_depth_pass(
+                        depth0,
+                        tileDepth,
+                        equalDepth,
+                        config.wBuffer != 0u))
+                {
+                    stencil = 0x1u;
+                }
+
+                if ((destinationAttr & 0x3u) != 0u &&
+                    !mpd_depth_pass(
+                        depth1,
+                        tileDepth,
+                        equalDepth,
+                        config.wBuffer != 0u))
+                {
+                    stencil |= 0x2u;
+                }
+            }
+        }
+    }
+
+    const uint layerStride = pixelCount;
+    resultColor[gid] = color0;
+    resultColor[layerStride + gid] = color1;
+    resultDepth[gid] = depth0;
+    resultDepth[layerStride + gid] = depth1;
+    resultAttr[gid] = attr0;
+    resultAttr[layerStride + gid] = attr1;
+
+    atomic_fetch_add_explicit(
+        &summary[MPD_SummaryPixels],
+        1u,
+        memory_order_relaxed);
+    atomic_fetch_add_explicit(
+        &summary[MPD_SummaryLayersTested],
+        layersTested,
+        memory_order_relaxed);
+    atomic_fetch_add_explicit(
+        &summary[MPD_SummaryLayersAccepted],
+        layersAccepted,
+        memory_order_relaxed);
+    atomic_fetch_add_explicit(
+        &summary[MPD_SummaryTranslucent],
+        translucentLayers,
+        memory_order_relaxed);
+    atomic_fetch_add_explicit(
+        &summary[MPD_SummaryOpaque],
+        opaqueLayers,
+        memory_order_relaxed);
+    atomic_fetch_add_explicit(
+        &summary[MPD_SummaryShadowMasks],
+        shadowMasks,
+        memory_order_relaxed);
+    atomic_fetch_add_explicit(
+        &summary[MPD_SummaryShadowPolygons],
+        shadowPolygons,
+        memory_order_relaxed);
+    atomic_fetch_add_explicit(
+        &summary[MPD_SummarySecondLayerWrites],
+        secondLayerWrites,
+        memory_order_relaxed);
+
+    const uint hash =
+        color0 ^
+        (color1 * 0x9E3779B9u) ^
+        (gid * 0x85EBCA6Bu);
+    atomic_fetch_xor_explicit(
+        &summary[MPD_SummaryColorHash],
+        hash,
+        memory_order_relaxed);
+    atomic_fetch_min_explicit(
+        &summary[MPD_SummaryDepthMin],
+        depth0,
+        memory_order_relaxed);
+    atomic_fetch_max_explicit(
+        &summary[MPD_SummaryDepthMax],
+        depth0,
+        memory_order_relaxed);
+}
+)MSL";
