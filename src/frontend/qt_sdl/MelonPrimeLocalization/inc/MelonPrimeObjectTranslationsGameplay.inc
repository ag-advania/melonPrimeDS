            {MenuLangId::Romanian, "Informațiile despre HP se actualizează foarte rar, așa că nu sunt prea fiabile. Folosește-le doar ca indiciu aproximativ despre cine a fost lovit."},
            {MenuLangId::Filipino, "Bihirang-bihira ma-update ang impormasyon ng HP, kaya hindi ito gaanong mapagkakatiwalaan. Gamitin lamang bilang magaspang na palatandaan kung sino ang tinamaan mo."},
            {MenuLangId::Swahili, "Taarifa za HP husasishwa mara chache sana, kwa hiyo si za kuaminika sana. Zitumie tu kama makadirio ya jumla ya yule uliyempiga."},
            {MenuLangId::Croatian, "Podaci o HP-u ažuriraju se vrlo rijetko pa nisu osobito pouzdani. Koristi ih samo kao približnu naznaku koga si pogodio."},
            {MenuLangId::Icelandic, "HP-upplýsingar uppfærast mjög sjaldan og eru því ekki sérlega áreiðanlegar. Notaðu þær aðeins sem grófa vísbendingu um hvern þú hittir."},
            {MenuLangId::Hindi, "HP की जानकारी बहुत कम अपडेट होती है, इसलिए उस पर पूरी तरह भरोसा नहीं किया जा सकता। इसे केवल मोटे तौर पर यह जानने के लिए उपयोग करें कि आपने किसे मारा।"},
            {MenuLangId::Bengali, "HP-এর তথ্য খুব কমই হালনাগাদ হয়, তাই এটি খুব নির্ভরযোগ্য নয়। আপনি কাকে আঘাত করেছেন তা মোটামুটি বোঝার জন্যই এটি ব্যবহার করুন।"},
            {MenuLangId::Urdu, "HP کی معلومات بہت کم اپ ڈیٹ ہوتی ہیں، اس لیے ان پر زیادہ بھروسا نہیں کیا جا سکتا۔ انہیں صرف اندازاً یہ جاننے کے لیے استعمال کریں کہ آپ نے کس کو نشانہ بنایا۔"},
            {MenuLangId::Punjabi, "HP ਦੀ ਜਾਣਕਾਰੀ ਬਹੁਤ ਘੱਟ ਅੱਪਡੇਟ ਹੁੰਦੀ ਹੈ, ਇਸ ਲਈ ਇਹ ਜ਼ਿਆਦਾ ਭਰੋਸੇਯੋਗ ਨਹੀਂ ਹੈ। ਇਸਨੂੰ ਸਿਰਫ਼ ਲਗਭਗ ਇਹ ਜਾਣਨ ਲਈ ਵਰਤੋ ਕਿ ਤੁਸੀਂ ਕਿਸ ਨੂੰ ਹਿੱਟ ਕੀਤਾ।"},
            {MenuLangId::Telugu, "HP సమాచారం చాలా అరుదుగా నవీకరించబడుతుంది, కాబట్టి అది పూర్తిగా నమ్మదగినది కాదు. మీరు ఎవరిని తాకారో సుమారుగా తెలుసుకోవడానికి మాత్రమే దీన్ని ఉపయోగించండి."},
            {MenuLangId::Persian, "اطلاعات HP به‌ندرت به‌روزرسانی می‌شود، بنابراین چندان قابل اعتماد نیست. فقط برای تشخیص تقریبی این‌که به چه کسی شلیک کرده‌اید از آن استفاده کنید."},
            {MenuLangId::Malay, "Maklumat HP sangat jarang dikemas kini, jadi ia tidak begitu boleh dipercayai. Gunakannya hanya sebagai petunjuk kasar tentang siapa yang anda terkena."},
            {MenuLangId::Marathi, "HP ची माहिती फार क्वचित अद्ययावत होते, त्यामुळे ती पूर्णपणे विश्वासार्ह नाही. तुम्ही कोणाला मारले याचा साधारण अंदाज घेण्यासाठीच ती वापरा."},
            {MenuLangId::Tamil, "HP தகவல் மிகவும் அரிதாகவே புதுப்பிக்கப்படுகிறது; எனவே அது முழுமையாக நம்பகமானதல்ல. நீங்கள் யாரைத் தாக்கினீர்கள் என்பதை தோராயமாக அறிய மட்டுமே இதைப் பயன்படுத்தவும்."},
            {MenuLangId::Gujarati, "HPની માહિતી બહુ ઓછી વાર અપડેટ થાય છે, તેથી તે સંપૂર્ણપણે વિશ્વસનીય નથી. તમે કોને હિટ કર્યું તેનો અંદાજ મેળવવા માટે જ તેનો ઉપયોગ કરો."},
            {MenuLangId::Kannada, "HP ಮಾಹಿತಿ ಬಹಳ ವಿರಳವಾಗಿ ನವೀಕರಿಸಲಾಗುತ್ತದೆ, ಆದ್ದರಿಂದ ಅದು ಸಂಪೂರ್ಣವಾಗಿ ನಂಬಿಕೆಗೆ ಅರ್ಹವಲ್ಲ. ನೀವು ಯಾರಿಗೆ ಹೊಡೆದಿರಿ ಎಂಬುದನ್ನು ಸರಿಸುಮಾರು ತಿಳಿಯಲು ಮಾತ್ರ ಇದನ್ನು ಬಳಸಿ."},
            {MenuLangId::Odia, "HP ସୂଚନା ବହୁତ କମ୍ ସମୟରେ ଅଦ୍ୟତନ ହୁଏ, ତେଣୁ ଏହା ବହୁତ ବିଶ୍ୱସନୀୟ ନୁହେଁ। ଆପଣ କାହାକୁ ଆଘାତ କରିଛନ୍ତି ତାହାର ଆନୁମାନିକ ସୂଚନା ପାଇଁ ମାତ୍ର ଏହାକୁ ବ୍ୟବହାର କରନ୍ତୁ।"},
            {MenuLangId::Malayalam, "HP വിവരങ്ങൾ വളരെ അപൂർവമായാണ് പുതുക്കപ്പെടുന്നത്, അതിനാൽ അവ പൂർണ്ണമായി വിശ്വസനീയമല്ല. നിങ്ങൾ ആരെയാണ് തട്ടിയതെന്ന് ഏകദേശമായി അറിയാൻ മാത്രം ഇത് ഉപയോഗിക്കുക."},
            {MenuLangId::Burmese, "HP အချက်အလက်ကို အလွန်ရှားရှားပါးပါးသာ အပ်ဒိတ်လုပ်သောကြောင့် အပြည့်အဝ ယုံကြည်၍မရပါ။ သင်ဘယ်သူ့ကို ထိမှန်ခဲ့သည်ကို အကြမ်းဖျဉ်း သိရန်သာ အသုံးပြုပါ။"},
            {MenuLangId::Uzbek, "HP ma’lumoti juda kam yangilanadi, shuning uchun unga to‘liq ishonib bo‘lmaydi. Uni faqat kimga tekkaningizni taxminan bilish uchun ishlating."},
            {MenuLangId::Azerbaijani, "HP məlumatı çox nadir hallarda yenilənir, buna görə də ona tam etibar etmək olmaz. Ondan yalnız kimi vurduğunuzu təxmini müəyyən etmək üçün istifadə edin."},
            {MenuLangId::Nepali, "HP सम्बन्धी जानकारी अत्यन्त कम अद्यावधिक हुन्छ, त्यसैले यो धेरै भरपर्दो हुँदैन। तपाईंले कसलाई प्रहार गर्नुभयो भन्ने मोटामोटी अनुमानका लागि मात्र प्रयोग गर्नुहोस्।"},
            {MenuLangId::Sinhala, "HP තොරතුරු යාවත්කාලීන වන්නේ ඉතා කලාතුරකින් බැවින් ඒවා සම්පූර්ණයෙන් විශ්වාස කළ නොහැක. ඔබ පහර දුන්නේ කාටද යන්න දළ වශයෙන් දැනගැනීමට පමණක් මෙය භාවිත කරන්න."},
            {MenuLangId::Khmer, "ព័ត៌មាន HP ត្រូវបានធ្វើបច្ចុប្បន្នភាពកម្រណាស់ ដូច្នេះវាមិនសូវអាចទុកចិត្តបានទេ។ ប្រើវាតែជាសូចនាករប្រហាក់ប្រហែលថាអ្នកបានបាញ់ត្រូវនរណា។"},
            {MenuLangId::Lao, "ຂໍ້ມູນ HP ຖືກອັບເດດໜ້ອຍຫຼາຍ ຈຶ່ງບໍ່ຄ່ອຍໜ້າເຊື່ອຖື. ໃຊ້ມັນພຽງເພື່ອປະເມີນຄ່າວໆວ່າທ່ານຍິງຖືກໃຜ."},
            {MenuLangId::Armenian, "HP-ի տվյալները շատ հազվադեպ են թարմացվում, ուստի լիովին հուսալի չեն։ Օգտագործեք դրանք միայն մոտավոր հասկանալու համար, թե ում եք հարվածել։"},
            {MenuLangId::Albanian, "Të dhënat e HP-së përditësohen shumë rrallë, ndaj nuk janë veçanërisht të besueshme. Përdorini vetëm si tregues të përafërt se kë keni goditur."},
            {MenuLangId::Georgian, "HP-ის ინფორმაცია ძალიან იშვიათად ახლდება, ამიტომ ბოლომდე სანდო არ არის. გამოიყენეთ მხოლოდ იმის დაახლოებით გასაგებად, თუ ვის მოარტყით."},
            {MenuLangId::Bosnian, "Podaci o HP-u ažuriraju se vrlo rijetko, pa nisu naročito pouzdani. Koristite ih samo kao približan pokazatelj koga ste pogodili."},
            {MenuLangId::Serbian, "Подаци о HP-у ажурирају се веома ретко, па нису нарочито поуздани. Користите их само као приближан показатељ кога сте погодили."},
            {MenuLangId::Macedonian, "Податоците за HP се ажурираат многу ретко, па не се особено сигурни. Користете ги само како приближен показател кого сте погодиле."},
            {MenuLangId::Bulgarian, "Данните за HP се обновяват много рядко и затова не са особено надеждни. Използвайте ги само като приблизителна индикация кого сте уцелили."},
            {MenuLangId::Belarusian, "Даныя HP абнаўляюцца вельмі рэдка, таму яны не надта надзейныя. Выкарыстоўвайце іх толькі як прыблізны арыенцір таго, у каго вы трапілі."},
            {MenuLangId::Maltese, "L-informazzjoni tal-HP tiġi aġġornata rari ħafna, għalhekk mhijiex partikolarment affidabbli. Użaha biss bħala indikazzjoni approssimattiva ta’ lil min laqatt."},
            {MenuLangId::Mongolian, "HP-ийн мэдээлэл маш ховор шинэчлэгддэг тул төдийлөн найдвартай биш. Хэнийг оносноо ойролцоогоор мэдэхэд л ашиглаарай."},
            {MenuLangId::Latvian, "HP informācija tiek atjaunināta ļoti reti, tāpēc tā nav īpaši uzticama. Izmantojiet to tikai kā aptuvenu norādi, kam trāpījāt."},
            {MenuLangId::Lithuanian, "HP informacija atnaujinama labai retai, todėl ji nėra itin patikima. Naudokite ją tik kaip apytikslę nuorodą, kam pataikėte."},
            {MenuLangId::Afrikaans, "HP-inligting word baie selde bygewerk en is daarom nie besonder betroubaar nie. Gebruik dit slegs as ’n rowwe aanduiding van wie jy getref het."},
            {MenuLangId::Irish, "Is fíorannamh a nuashonraítear an fhaisnéis HP, mar sin níl sí thar a bheith iontaofa. Ná húsáid í ach mar chomhartha garbh ar cé a bhuail tú."},
            {MenuLangId::Assamese, "HP-ৰ তথ্য অতি কম সময়তহে আপডেট হয়, সেয়ে ই সম্পূৰ্ণ নিৰ্ভৰযোগ্য নহয়। আপুনি কাক আঘাত কৰিলে তাৰ আনুমানিক ধাৰণা ল’বলৈহে ইয়াক ব্যৱহাৰ কৰক।"},
            {MenuLangId::Amharic, "የHP መረጃ በጣም አልፎ አልፎ ብቻ ይዘምናል፣ ስለዚህ ሙሉ በሙሉ አስተማማኝ አይደለም። ማንን እንደመቱ በግምት ለማወቅ ብቻ ይጠቀሙበት።"},
            {MenuLangId::Estonian, "HP-teavet uuendatakse väga harva, mistõttu pole see eriti usaldusväärne. Kasutage seda ainult ligikaudse vihjena selle kohta, keda tabasite."},
            {MenuLangId::Kazakh, "HP ақпараты өте сирек жаңартылады, сондықтан оған толық сенуге болмайды. Оны тек кімді атқаныңызды шамамен білу үшін пайдаланыңыз."},
            {MenuLangId::Catalan, "La informació d’HP s’actualitza molt poques vegades i, per tant, no és gaire fiable. Utilitzeu-la només com a indicació aproximada de qui heu tocat."},
            {MenuLangId::Kyrgyz, "HP маалыматы өтө сейрек жаңыртылат, ошондуктан ага толук ишенүүгө болбойт. Аны кимге тийгениңизди болжол менен билүү үчүн гана колдонуңуз."},
            {MenuLangId::Slovak, "Informácie o HP sa aktualizujú len veľmi zriedka, preto nie sú veľmi spoľahlivé. Používajte ich iba ako približný údaj o tom, koho ste zasiahli."},
            {MenuLangId::Slovenian, "Podatki o HP se posodabljajo zelo redko, zato niso posebej zanesljivi. Uporabljajte jih le kot približen pokazatelj, koga ste zadeli."},
            {MenuLangId::Zulu, "Ulwazi lwe-HP lubuyekezwa kuyaqabukela kakhulu, ngakho aluthembekile kakhulu. Lusebenzise kuphela njengenkomba ecishe iveze ukuthi ushaye bani."},
            {MenuLangId::Basque, "HP informazioa oso gutxitan eguneratzen da; beraz, ez da oso fidagarria. Erabili soilik nor jo duzun gutxi gorabehera jakiteko."},
            {MenuLangId::Hebrew, "מידע ה-HP מתעדכן לעיתים רחוקות מאוד, ולכן אינו אמין במיוחד. השתמש בו רק כאינדיקציה כללית למי שפגעת בו."},
        }
