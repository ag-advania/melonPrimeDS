    {
        "lblMetroidExpandStageMatrixExtraDesc",
        {
            {MenuLangId::Japanese, "<html><body>\n基本選択に加えて、さらに9個の組み合わせを解放します。<br><br>\n<b>バトル / ノード / プライムハンター / サバイバル</b><br>\n&nbsp;&nbsp;トランスファーロック・ワイド (Transfer Lock Wide) — 通常重力<br><br>\n<b>ディフェンダー</b><br>\n&nbsp;&nbsp;トランスファーロック (Transfer Lock) — ディフェンダーリングなし、ボルトドライバー + バトルハンマーのみ<br>\n&nbsp;&nbsp;コンプレッサールーム (Compression Chamber) — ディフェンダーリングなし、ジャンパーなし、アイテムなし<br>\n&nbsp;&nbsp;インキュベーションルーム (Incubation Vault) — ディフェンダーリングなし、アイテムとジャンパーあり<br>\n&nbsp;&nbsp;フュールスタック (Fuel Stack) — ディフェンダーリングなし、浮遊なし、インペリアリストのみ<br>\n&nbsp;&nbsp;ヘッドショット (Head Shot) — ディフェンダーリングなし、通常重力、ジャンパー2個、トランスフォーム通路は射出なし\n</body></html>"},
            {MenuLangId::German, "<html><body>\nSchaltet zusätzlich zu den Basiseinträgen 9 weitere Kombinationen frei.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Weite Transferschleuse (Transfer Lock Wide) — normale Schwerkraft<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Transferschleuse (Transfer Lock) — ohne Defender-Ring, nur Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;Druckkammer (Compression Chamber) — ohne Defender-Ring, ohne Sprungplattform und ohne Gegenstände<br>\n&nbsp;&nbsp;Brutraum (Incubation Vault) — ohne Defender-Ring, mit Gegenständen und einer Sprungplattform<br>\n&nbsp;&nbsp;Treibstofflager (Fuel Stack) — ohne Defender-Ring, ohne Schweben, nur Imperialist<br>\n&nbsp;&nbsp;Kopfschuss (Head Shot) — ohne Defender-Ring, normale Schwerkraft, 2 Sprungplattformen und kein Abschuss im Transformationskorridor\n</body></html>"},
            {MenuLangId::Spanish, "<html><body>\nDesbloquea 9 combinaciones adicionales además de las selecciones básicas.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Esclusa transbordo amplia (Transfer Lock Wide) — gravedad normal<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Esclusa transbordo (Transfer Lock) — sin anillo Defender, solo Voltric + Destruktor<br>\n&nbsp;&nbsp;Cámara de compresión (Compression Chamber) — sin anillo Defender, sin plataforma de salto, sin ítems<br>\n&nbsp;&nbsp;Sala de incubación (Incubation Vault) — sin anillo Defender, con ítems y una plataforma de salto<br>\n&nbsp;&nbsp;Esclusa combustible (Fuel Stack) — sin anillo Defender, sin flotación, solo Imperialist<br>\n&nbsp;&nbsp;Impacto mortal (Head Shot) — sin anillo Defender, gravedad normal, 2 plataformas de salto, sin lanzamiento en el pasillo de transformación\n</body></html>"},
            {MenuLangId::French, "<html><body>\nDébloque 9 combinaisons supplémentaires en plus des choix de base.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Verrouillage large (Transfer Lock Wide) — gravité normale<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Verrouillage (Transfer Lock) — sans anneau de zone Defender, Voltar + Marteau uniquement<br>\n&nbsp;&nbsp;Compression (Compression Chamber) — sans anneau de zone Defender, sans tremplin ni objets<br>\n&nbsp;&nbsp;Incubation (Incubation Vault) — sans anneau de zone Defender, avec des objets et un tremplin<br>\n&nbsp;&nbsp;Fuel (Fuel Stack) — sans anneau de zone Defender, sans flottement, Impérialiste uniquement<br>\n&nbsp;&nbsp;Headshot (Head Shot) — sans anneau de zone Defender, gravité normale, 2 tremplins, aucune éjection dans le passage de transformation\n</body></html>"},
            {MenuLangId::Italian, "<html><body>\nSblocca altre 9 combinazioni oltre alle selezioni di base.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Blocco Transfer ampio (Transfer Lock Wide) — gravità normale<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Blocco Transfer (Transfer Lock) — senza anello Defender, solo Raggio Voltaico + Raggio da Guerra<br>\n&nbsp;&nbsp;Camera di compressione (Compression Chamber) — senza anello Defender, senza trampolino e senza oggetti<br>\n&nbsp;&nbsp;Sala d’incubazione (Incubation Vault) — senza anello Defender, con oggetti e un trampolino<br>\n&nbsp;&nbsp;Deposito di carburante (Fuel Stack) — senza anello Defender, senza fluttuazione, solo Raggio Imperium<br>\n&nbsp;&nbsp;Colpo alla testa (Head Shot) — senza anello Defender, gravità normale, 2 trampolini e nessun lancio nel corridoio di trasformazione\n</body></html>"},
            {MenuLangId::Dutch, "<html><body>\nOntgrendelt naast de basisselectie nog 9 combinaties.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Brede transfersluis (Transfer Lock Wide) — normale zwaartekracht<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Transfersluis (Transfer Lock) — zonder Defender-ring, alleen Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;Compressorkamer (Compression Chamber) — zonder Defender-ring, zonder springplatform en zonder voorwerpen<br>\n&nbsp;&nbsp;Broedkamer (Incubation Vault) — zonder Defender-ring, met voorwerpen en een springplatform<br>\n&nbsp;&nbsp;Brandstofopslag (Fuel Stack) — zonder Defender-ring, zonder zweven, alleen Imperialist<br>\n&nbsp;&nbsp;Hoofdschot (Head Shot) — zonder Defender-ring, normale zwaartekracht, 2 springplatformen en geen lancering in de transformatiecorridor\n</body></html>"},
            {MenuLangId::Portuguese, "<html><body>\nDesbloqueia mais 9 combinações além das seleções básicas.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Bloqueio de transferência amplo (Transfer Lock Wide) — gravidade normal<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Bloqueio de transferência (Transfer Lock) — sem anel da zona Defender; apenas Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;Câmara de compressão (Compression Chamber) — sem anel da zona Defender, sem plataforma de salto nem itens<br>\n&nbsp;&nbsp;Câmara de incubação (Incubation Vault) — sem anel da zona Defender, com itens e uma plataforma de salto<br>\n&nbsp;&nbsp;Depósito de combustível (Fuel Stack) — sem anel da zona Defender, sem flutuação; apenas Imperialist<br>\n&nbsp;&nbsp;Tiro na cabeça (Head Shot) — sem anel da zona Defender, gravidade normal, 2 plataformas de salto e sem lançamento no corredor de transformação\n</body></html>"},
            {MenuLangId::Russian, "<html><body>\nРазблокирует 9 дополнительных комбинаций помимо базового выбора.\n<br><br>\n<b>Battle / Node / Prime Hunter / Survival</b><br>\n&nbsp;&nbsp;Широкий трансферный шлюз (Transfer Lock Wide) — обычная гравитация<br><br>\n<b>Defender</b><br>\n&nbsp;&nbsp;Трансферный шлюз (Transfer Lock) — без кольца Defender, только Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;Компрессорная камера (Compression Chamber) — без кольца Defender, без прыгуна, без предметов<br>\n&nbsp;&nbsp;Инкубатор (Incubation Vault) — без кольца Defender, с предметами и прыгуном<br>\n&nbsp;&nbsp;Топливный склад (Fuel Stack) — без кольца Defender, без парения, только Imperialist<br>\n&nbsp;&nbsp;Выстрел в голову (Head Shot) — без кольца Defender, обычная гравитация, 2 прыгуна, трансформ-коридор без выброса\n</body></html>"},
            {MenuLangId::ChineseSimplified, "<html><body>\n在基本选择之外再解锁 9 个组合。\n<br><br>\n<b>战斗 / 节点 / Prime Hunter / 生存</b><br>\n&nbsp;&nbsp;宽型传送锁 (Transfer Lock Wide) — 正常重力<br><br>\n<b>防守</b><br>\n&nbsp;&nbsp;传送锁 (Transfer Lock) — 无防守环，仅 Volt Driver + Battlehammer<br>\n&nbsp;&nbsp;压缩机室 (Compression Chamber) — 无防守环，无跳跃台，无道具<br>\n&nbsp;&nbsp;孵化室 (Incubation Vault) — 无防守环，有道具与跳跃台<br>\n&nbsp;&nbsp;燃料堆栈 (Fuel Stack) — 无防守环，无漂浮，仅 Imperialist<br>\n&nbsp;&nbsp;爆头 (Head Shot) — 无防守环，正常重力，2 个跳跃台，变形通道无弹射\n</body></html>"},
