            {MenuLangId::Japanese, "(1.5147 = MPH標準、1.9429 = X/Y角速度一致 [オプション])"},
            {MenuLangId::German, "(1.5147 = MPH-Standard, 1.9429 = gleiche Winkelgeschwindigkeit auf der X- und Y-Achse [optional])"},
            {MenuLangId::Spanish, "(1.5147 = estándar MPH, 1.9429 = misma velocidad angular X/Y [opcional])"},
            {MenuLangId::French, "(1.5147 = valeur native de MPH ; 1.9429 = vitesse angulaire X/Y parfaitement identique [facultatif])"},
