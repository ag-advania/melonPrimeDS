        "metroidAimAdjustLabel",
        {
            {MenuLangId::Japanese, "<html><head/><body><p><b>入力しきい値 (デッドゾーン + スナップ)</b> (推奨: 0.01 [既定] または 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → そのまま (a=0: オフ = 1未満をすべて無視、スナップなし)<br/>エイムが思った通りに動かない場合は、この値を下げてみてください。</p></body></html>"},
            {MenuLangId::German, "<html><head/><body><p><b>Eingabeschwellenwert (Totzone + Snap)</b> (empfohlen: 0.01 [Standard] oder 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → unverändert (a=0: Aus = alles unter 1 ignorieren, kein Snap)<br/>Wenn sich die Zielbewegung nicht wie erwartet anfühlt, versuche diesen Wert zu senken.</p></body></html>"},
            {MenuLangId::Spanish, "<html><head/><body><p><b>Umbral de entrada (zona muerta + snap)</b> (recomendado: 0.01 [predeterminado] o 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → sin cambios (a=0: desactivado = ignorar todo bajo 1, sin snap)<br/>Si la puntería no se comporta como esperas, prueba a bajar este valor.</p></body></html>"},
            {MenuLangId::French, "<html><head/><body><p><b>Seuil d'entrée (zone morte + snap)</b> (recommandé : 0.01 [par défaut] ou 0.5) : |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → inchangé (a=0 : désactivé = ignorer tout en dessous de 1, pas de snap)<br/>Si la visée ne réagit pas comme prévu, essayez de baisser cette valeur.</p></body></html>"},
            {MenuLangId::Italian, "<html><head/><body><p><b>Soglia di input (zona morta + snap)</b> (consigliato: 0.01 [predefinito] o 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → invariato (a=0: disattivato = ignora tutto sotto 1, nessuno snap)<br/>Se la mira non si comporta come previsto, prova ad abbassare questo valore.</p></body></html>"},
            {MenuLangId::Dutch, "<html><head/><body><p><b>Invoerdrempel (dode zone + snap)</b> (aanbevolen: 0.01 [standaard] of 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ongewijzigd (a=0: uit = alles onder 1 negeren, geen snap)<br/>Als het richten niet aanvoelt zoals verwacht, probeer deze waarde te verlagen.</p></body></html>"},
            {MenuLangId::Portuguese, "<html><head/><body><p><b>Limite de entrada (zona morta + snap)</b> (recomendado: 0.01 [predefinição] ou 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → inalterado (a=0: desativado = ignorar tudo abaixo de 1, sem snap)<br/>Se a mira não se comportar como esperado, tente diminuir este valor.</p></body></html>"},
            {MenuLangId::Russian, "<html><head/><body><p><b>Порог ввода (мёртвая зона + snap)</b> (рекомендуется: 0.01 [по умолчанию] или 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → без изменений (a=0: выкл. = игнорировать всё ниже 1, без snap)<br/>Если прицеливание ведёт себя не так, как ожидается, попробуйте уменьшить это значение.</p></body></html>"},
            {MenuLangId::ChineseSimplified, "<html><head/><body><p><b>输入阈值（死区 + 吸附）</b>（推荐：0.01 [默认] 或 0.5）：|x|&lt;a → 0，a ≤ |x|&lt;1 → ±1，|x|≥1 → 保持不变（a=0：关闭 = 忽略 1 以下全部，无吸附）<br/>若瞄准手感不符合预期，可尝试降低此值。</p></body></html>"},
            {MenuLangId::ChineseTraditional, "<html><head/><body><p><b>輸入閾值（死區 + 吸附）</b>（推薦：0.01 [預設] 或 0.5）：|x|&lt;a → 0，a ≤ |x|&lt;1 → ±1，|x|≥1 → 保持不變（a=0：關閉 = 忽略 1 以下全部，無吸附）<br/>若瞄準手感不符合預期，可嘗試降低此值。</p></body></html>"},
            {MenuLangId::ChineseHongKong, "<html><head/><body><p><b>輸入閾值（死區 + 吸附）</b>（推薦：0.01 [預設] 或 0.5）：|x|&lt;a → 0，a ≤ |x|&lt;1 → ±1，|x|≥1 → 保持不變（a=0：關閉 = 忽略 1 以下全部，無吸附）<br/>若瞄準手感不符合預期，可嘗試降低此值。</p></body></html>"},
            {MenuLangId::Korean, "<html><head/><body><p><b>입력 임계값 (데드존 + 스냅)</b> (권장: 0.01 [기본] 또는 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → 그대로 (a=0: 끔 = 1 미만 모두 무시, 스냅 없음)<br/>조준이 예상과 다르게 느껴지면 이 값을 낮춰 보세요.</p></body></html>"},
            {MenuLangId::Arabic, "<html><head/><body><p><b>عتبة الإدخال (منطقة ميتة + snap)</b> (موصى به: 0.01 [افتراضي] أو 0.5): |x|&lt;a → 0، a ≤ |x|&lt;1 → ±1، |x|≥1 → دون تغيير (a=0: إيقاف = تجاهل كل ما دون 1، بدون snap)<br/>إذا لم يتحرك التصويب كما تتوقع، جرّب خفض هذه القيمة.</p></body></html>"},
            {MenuLangId::Indonesian, "<html><head/><body><p><b>Ambang input (dead zone + snap)</b> (disarankan: 0.01 [bawaan] atau 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → tidak berubah (a=0: mati = abaikan semua di bawah 1, tanpa snap)<br/>Jika bidik tidak terasa seperti yang diharapkan, coba turunkan nilai ini.</p></body></html>"},
            {MenuLangId::Ukrainian, "<html><head/><body><p><b>Поріг вводу (мертва зона + snap)</b> (рекомендовано: 0.01 [за замовч.] або 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → без змін (a=0: вимк. = ігнорувати все нижче 1, без snap)<br/>Якщо прицілювання поводиться не так, як очікується, спробуйте зменшити це значення.</p></body></html>"},
            {MenuLangId::Greek, "<html><head/><body><p><b>Όριο εισόδου (νεκρή ζώνη + snap)</b> (συνιστάται: 0.01 [προεπιλογή] ή 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → αμετάβλητο (a=0: ανενεργό = αγνόηση όλων κάτω από 1, χωρίς snap)<br/>Αν η σκόπευση δεν συμπεριφέρεται όπως αναμένετε, δοκιμάστε να μειώσετε αυτή την τιμή.</p></body></html>"},
            {MenuLangId::Swedish, "<html><head/><body><p><b>Ingångströskel (dödzon + snap)</b> (rekommenderat: 0.01 [standard] eller 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → oförändrat (a=0: av = ignorera allt under 1, ingen snap)<br/>Om siktet inte känns som förväntat, prova att sänka detta värde.</p></body></html>"},
            {MenuLangId::Thai, "<html><head/><body><p><b>เกณฑ์อินพุต (dead zone + snap)</b> (แนะนำ: 0.01 [ค่าเริ่มต้น] หรือ 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ไม่เปลี่ยน (a=0: ปิด = ละเว้นทั้งหมดต่ำกว่า 1 ไม่มี snap)<br/>หากการเล็งไม่เป็นไปตามที่คาด ลองลดค่านี้</p></body></html>"},
            {MenuLangId::Czech, "<html><head/><body><p><b>Vstupní práh (mrtvá zóna + snap)</b> (doporučeno: 0.01 [výchozí] nebo 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → beze změny (a=0: vyp = ignorovat vše pod 1, bez snap)<br/>Pokud míření neodpovídá očekávání, zkuste snížit tuto hodnotu.</p></body></html>"},
            {MenuLangId::Danish, "<html><head/><body><p><b>Inputtærskel (død zone + snap)</b> (anbefalet: 0.01 [standard] eller 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → uændret (a=0: fra = ignorer alt under 1, ingen snap)<br/>Hvis sigtet ikke føles som forventet, prøv at sænke denne værdi.</p></body></html>"},
            {MenuLangId::Turkish, "<html><head/><body><p><b>Giriş eşiği (ölü bölge + snap)</b> (önerilen: 0.01 [varsayılan] veya 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → değişmez (a=0: kapalı = 1'in altındakileri yoksay, snap yok)<br/>Nişan beklendiği gibi hissettirmiyorsa bu değeri düşürmeyi deneyin.</p></body></html>"},
            {MenuLangId::Norwegian, "<html><head/><body><p><b>Inngangsterskel (dødsone + snap)</b> (anbefalt: 0.01 [standard] eller 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → uendret (a=0: av = ignorer alt under 1, ingen snap)<br/>Hvis siktet ikke føles som forventet, prøv å senke denne verdien.</p></body></html>"},
            {MenuLangId::Hungarian, "<html><head/><body><p><b>Bemeneti küszöb (holtsáv + snap)</b> (ajánlott: 0.01 [alapértelmezett] vagy 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → változatlan (a=0: ki = minden 1 alatti figyelmen kívül, nincs snap)<br/>Ha a célzás nem úgy viselkedik, mint vártad, próbáld csökkenteni ezt az értéket.</p></body></html>"},
            {MenuLangId::Finnish, "<html><head/><body><p><b>Syötekynnys (kuollut alue + snap)</b> (suositeltu: 0.01 [oletus] tai 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ennallaan (a=0: pois = ohita kaikki alle 1, ei snap)<br/>Jos tähtäys ei tunnu odotetulta, kokeile laskea tätä arvoa.</p></body></html>"},
            {MenuLangId::Vietnamese, "<html><head/><body><p><b>Ngưỡng đầu vào (vùng chết + snap)</b> (khuyến nghị: 0.01 [mặc định] hoặc 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → giữ nguyên (a=0: tắt = bỏ qua mọi giá trị dưới 1, không snap)<br/>Nếu ngắm không như mong đợi, hãy thử giảm giá trị này.</p></body></html>"},
            {MenuLangId::Polish, "<html><head/><body><p><b>Próg wejścia (martwa strefa + snap)</b> (zalecane: 0.01 [domyślnie] lub 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → bez zmian (a=0: wył. = ignoruj wszystko poniżej 1, bez snap)<br/>Jeśli celowanie nie działa jak oczekiwano, spróbuj obniżyć tę wartość.</p></body></html>"},
            {MenuLangId::Romanian, "<html><head/><body><p><b>Prag de intrare (zonă moartă + snap)</b> (recomandat: 0.01 [implicit] sau 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → neschimbat (a=0: oprit = ignoră tot sub 1, fără snap)<br/>Dacă țintirea nu se comportă cum vă așteptați, încercați să scădeți această valoare.</p></body></html>"},            {MenuLangId::Filipino, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (inirerekomenda: 0.01 [default] o 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → hindi binabago (a=0: off = huwag pansinin ang lahat sa ibaba ng 1, walang snap)<br/>Kung hindi tama ang pakiramdam ng aim, subukang babaan ang value na ito.</p></body></html>"},            {MenuLangId::Swahili, "<html><head/><body><p><b>Kizingiti cha ingizo (dead zone + snap)</b> (inapendekezwa: 0.01 [chaguo-msingi] au 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → haibadilishwi (a=0: off = puuza yote chini ya 1, hakuna snap)<br/>Kama aim haihisi inavyotarajiwa, jaribu kupunguza thamani hii.</p></body></html>"},            {MenuLangId::Croatian, "<html><head/><body><p><b>Prag unosa (dead zone + snap)</b> (preporučeno: 0.01 [zadano] ili 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → bez promjene (a=0: isključeno = zanemari sve ispod 1, bez snap efekta)<br/>Ako ciljanje nema očekivani osjećaj, pokušajte smanjiti ovu vrijednost.</p></body></html>"},            {MenuLangId::Icelandic, "<html><head/><body><p><b>Inntaksþröskuldur (dead zone + snap)</b> (mælt með: 0.01 [sjálfgefið] eða 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → óbreytt (a=0: slökkt = hunsa allt undir 1, ekkert snap)<br/>Ef miðunin finnst ekki eins og hún ætti að gera, reyndu að lækka þetta gildi.</p></body></html>"},            {MenuLangId::Hindi, "<html><head/><body><p><b>इनपुट सीमा (dead zone + snap)</b> (अनुशंसित: 0.01 [डिफ़ॉल्ट] या 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → अपरिवर्तित (a=0: बंद = 1 से नीचे सब अनदेखा, snap नहीं)<br/>यदि aim अपेक्षित जैसा महसूस नहीं होता, तो इस मान को कम करने का प्रयास करें।</p></body></html>"},            {MenuLangId::Bengali, "<html><head/><body><p><b>ইনপুট সীমা (dead zone + snap)</b> (প্রস্তাবিত: 0.01 [ডিফল্ট] বা 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → অপরিবর্তিত (a=0: off = 1-এর নিচে সব উপেক্ষা, snap নেই)<br/>Aim প্রত্যাশামতো না লাগলে, এই মান কমিয়ে দেখুন।</p></body></html>"},            {MenuLangId::Urdu, "<html><head/><body><p><b>ان پٹ حد (dead zone + snap)</b> (تجویز کردہ: 0.01 [ڈیفالٹ] یا 0.5): |x|&lt;a → 0، a ≤ |x|&lt;1 → ±1، |x|≥1 → کوئی تبدیلی نہیں (a=0: off = 1 سے نیچے سب نظر انداز، snap نہیں)<br/>اگر aim توقع کے مطابق محسوس نہیں ہوتا تو اس قدر کو کم کر کے دیکھیں۔</p></body></html>"},            {MenuLangId::Punjabi, "<html><head/><body><p><b>ਇਨਪੁੱਟ ਸੀਮਾ (dead zone + snap)</b> (ਸਿਫ਼ਾਰਸ਼ੀ: 0.01 [ਡਿਫਾਲਟ] ਜਾਂ 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ਬਦਲਾਅ ਨਹੀਂ (a=0: off = 1 ਤੋਂ ਹੇਠਾਂ ਸਭ ਅਣਡਿੱਠਾ, snap ਨਹੀਂ)<br/>ਜੇ aim ਉਮੀਦ ਮੁਤਾਬਕ ਮਹਿਸੂਸ ਨਹੀਂ ਹੁੰਦਾ, ਤਾਂ ਇਹ ਮੁੱਲ ਘਟਾ ਕੇ ਵੇਖੋ।</p></body></html>"},            {MenuLangId::Telugu, "<html><head/><body><p><b>ఇన్‌పుట్ పరిమితి (dead zone + snap)</b> (సిఫార్సు: 0.01 [డిఫాల్ట్] లేదా 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → మార్పు లేదు (a=0: off = 1 కంటే తక్కువ అన్నీ విస్మరించు, snap లేదు)<br/>Aim అంచనాలకు తగ్గట్టు అనిపించకపోతే, ఈ విలువను తగ్గించి చూడండి.</p></body></html>"},            {MenuLangId::Persian, "<html><head/><body><p><b>آستانه ورودی (dead zone + snap)</b> (پیشنهادی: 0.01 [پیش‌فرض] یا 0.5): |x|&lt;a → 0، a ≤ |x|&lt;1 → ±1، |x|≥1 → بدون تغییر (a=0: خاموش = همه چیز زیر 1 نادیده گرفته می‌شود، snap ندارد)<br/>اگر aim مطابق انتظار حس نمی‌شود، این مقدار را کمتر کنید.</p></body></html>"},            {MenuLangId::Malay, "<html><head/><body><p><b>Ambang input (dead zone + snap)</b> (disyorkan: 0.01 [lalai] atau 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → tidak berubah (a=0: off = semua di bawah 1 diabaikan, tiada snap)<br/>Jika aim tidak terasa seperti dijangka, cuba turunkan nilai ini.</p></body></html>"},            {MenuLangId::Marathi, "<html><head/><body><p><b>इनपुट मर्यादा (dead zone + snap)</b> (शिफारस: 0.01 [डीफॉल्ट] किंवा 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → बदल नाही (a=0: off = 1 खालील सर्व दुर्लक्ष, snap नाही)<br/>Aim अपेक्षेप्रमाणे वाटत नसेल तर हे मूल्य कमी करून पाहा.</p></body></html>"},            {MenuLangId::Tamil, "<html><head/><body><p><b>உள்ளீட்டு வரம்பு (dead zone + snap)</b> (பரிந்துரை: 0.01 [இயல்புநிலை] அல்லது 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → மாற்றமில்லை (a=0: off = 1 க்குக் கீழே உள்ள அனைத்தும் புறக்கணிக்கப்படும், snap இல்லை)<br/>Aim எதிர்பார்த்தபடி உணரப்படவில்லை என்றால், இந்த மதிப்பை குறைத்து பார்க்கவும்.</p></body></html>"},            {MenuLangId::Gujarati, "<html><head/><body><p><b>ઇનપુટ મર્યાદા (dead zone + snap)</b> (ભલામણ: 0.01 [ડિફૉલ્ટ] અથવા 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ફેરફાર નહીં (a=0: off = 1 કરતા નીચે બધું અવગણો, snap નહીં)<br/>Aim અપેક્ષા મુજબ ન લાગે તો આ મૂલ્ય ઘટાડીને જુઓ.</p></body></html>"},            {MenuLangId::Kannada, "<html><head/><body><p><b>ಇನ್‌ಪುಟ್ ಮಿತಿ (dead zone + snap)</b> (ಶಿಫಾರಸು: 0.01 [ಡೀಫಾಲ್ಟ್] ಅಥವಾ 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ಬದಲಾವಣೆ ಇಲ್ಲ (a=0: off = 1 ಕ್ಕಿಂತ ಕೆಳಗಿನ ಎಲ್ಲವೂ ನಿರ್ಲಕ್ಷ್ಯ, snap ಇಲ್ಲ)<br/>Aim ನಿರೀಕ್ಷೆಯಂತೆ ಅನಿಸದಿದ್ದರೆ, ಈ ಮೌಲ್ಯವನ್ನು ಕಡಿಮೆ ಮಾಡಿ ನೋಡಿ.</p></body></html>"},            {MenuLangId::Odia, "<html><head/><body><p><b>ଇନପୁଟ୍ ସୀମା (dead zone + snap)</b> (ସୁପାରିଶ: 0.01 [ଡିଫଲ୍ଟ] କିମ୍ବା 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ପରିବର୍ତ୍ତନ ନାହିଁ (a=0: off = 1 ଠାରୁ କମ୍ ସବୁ ଅଗଣା, snap ନାହିଁ)<br/>Aim ଆଶା କରିଥିବା ଭଳି ଲାଗୁନଥିଲେ, ଏହି ମୂଲ୍ୟ କମାଇ ଦେଖନ୍ତୁ.</p></body></html>"},            {MenuLangId::Malayalam, "<html><head/><body><p><b>ഇൻപുട്ട് പരിധി (dead zone + snap)</b> (ശുപാർശ: 0.01 [ഡിഫോൾട്ട്] അല്ലെങ്കിൽ 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → മാറ്റമില്ല (a=0: off = 1-നു താഴെയുള്ള എല്ലാം അവഗണിക്കും, snap ഇല്ല)<br/>Aim പ്രതീക്ഷിച്ചതുപോലെ തോന്നുന്നില്ലെങ്കിൽ, ഈ മൂല്യം കുറച്ച് നോക്കുക.</p></body></html>"},            {MenuLangId::Burmese, "<html><head/><body><p><b>input threshold (dead zone + snap)</b> (အကြံပြု: 0.01 [မူရင်း] သို့မဟုတ် 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → မပြောင်းလဲ (a=0: off = 1 ထက်နည်းသောအရာအားလုံးကို လျစ်လျူရှု, snap မရှိ)<br/>Aim မျှော်လင့်သလို မခံစားရပါက ဤတန်ဖိုးကို လျှော့၍ စမ်းကြည့်ပါ။</p></body></html>"},            {MenuLangId::Uzbek, "<html><head/><body><p><b>Kiritish thresholdi (dead zone + snap)</b> (tavsiya: 0.01 [standart] yoki 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → oʻzgarish yoʻq (a=0: off = 1 dan past hammasi eʼtiborsiz, snap yoʻq)<br/>Aim kutilgandek tuyulmasa, bu qiymatni kamaytirib koʻring.</p></body></html>"},            {MenuLangId::Azerbaijani, "<html><head/><body><p><b>Giriş threshold-u (dead zone + snap)</b> (tövsiyə: 0.01 [standart] və ya 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → dəyişiklik yoxdur (a=0: off = 1-dən aşağı olan hər şey nəzərə alınmır, snap yoxdur)<br/>Aim gözlənilən kimi hiss olunmursa, bu dəyəri azaltmağı sınayın.</p></body></html>"},            {MenuLangId::Nepali, "<html><head/><body><p><b>इनपुट threshold (dead zone + snap)</b> (सिफारिस: 0.01 [पूर्वनिर्धारित] वा 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → परिवर्तन छैन (a=0: off = 1 भन्दा कम सबै बेवास्ता, snap छैन)<br/>Aim अपेक्षा गरेजस्तो लागेन भने यो मान घटाएर हेर्नुहोस्।</p></body></html>"},            {MenuLangId::Sinhala, "<html><head/><body><p><b>ආදාන threshold (dead zone + snap)</b> (නිර්දේශය: 0.01 [පෙරනිමි] හෝ 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → වෙනසක් නැත (a=0: off = 1 ට අඩු සියල්ල නොසලකා හරී, snap නැත)<br/>Aim බලාපොරොත්තු වූ ලෙස නොහැඟේ නම්, මෙම අගය අඩු කර බලන්න.</p></body></html>"},            {MenuLangId::Khmer, "<html><head/><body><p><b>threshold បញ្ចូល (dead zone + snap)</b> (ណែនាំ: 0.01 [លំនាំដើម] ឬ 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → មិនផ្លាស់ប្តូរ (a=0: off = មិនគិតអ្វីទាំងអស់ក្រោម 1, គ្មាន snap)<br/>បើ Aim មិនដូចការរំពឹងទុក សូមសាកល្បងបន្ថយតម្លៃនេះ។</p></body></html>"},            {MenuLangId::Lao, "<html><head/><body><p><b>threshold ອິນພຸດ (dead zone + snap)</b> (ແນະນຳ: 0.01 [ຄ່າເລີ່ມຕົ້ນ] ຫຼື 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ບໍ່ປ່ຽນ (a=0: off = ບໍ່ສົນໃຈທຸກຢ່າງຕ່ຳກວ່າ 1, ບໍ່ມີ snap)<br/>ຖ້າ Aim ບໍ່ຮູ້ສຶກຕາມທີ່ຄາດ, ລອງຫຼຸດຄ່ານີ້.</p></body></html>"},            {MenuLangId::Armenian, "<html><head/><body><p><b>Մուտքի threshold (dead zone + snap)</b> (առաջարկվում է՝ 0.01 [լռելյայն] կամ 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → փոփոխություն չկա (a=0: off = 1-ից ցածր ամեն ինչ անտեսվում է, snap չկա)<br/>Եթե Aim-ը սպասվածի պես չի զգացվում, փորձեք նվազեցնել այս արժեքը։</p></body></html>"},            {MenuLangId::Albanian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (rekomandohet: 0.01 [parazgjedhje] ose 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → pa ndryshim (a=0: off = çdo gjë nën 1 shpërfillet, pa snap)<br/>Nëse Aim nuk ndihet siç pritet, provoni ta ulni këtë vlerë.</p></body></html>"},            {MenuLangId::Georgian, "<html><head/><body><p><b>შეყვანის threshold (dead zone + snap)</b> (რეკომენდებულია: 0.01 [ნაგულისხმევი] ან 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ცვლილება არაა (a=0: off = 1-ზე დაბალი ყველაფერი იგნორირდება, snap არაა)<br/>თუ Aim მოსალოდნელად არ იგრძნობა, სცადეთ ამ მნიშვნელობის შემცირება.</p></body></html>"},            {MenuLangId::Bosnian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (preporučeno: 0.01 [zadano] ili 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → bez promjene (a=0: off = sve ispod 1 se ignoriše, bez snap)<br/>Ako Aim ne djeluje očekivano, pokušajte smanjiti ovu vrijednost.</p></body></html>"},            {MenuLangId::Serbian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (препоручено: 0.01 [подразумевано] или 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → без промене (a=0: off = све испод 1 се игнорише, без snap)<br/>Ако Aim не делује очекивано, покушајте да смањите ову вредност.</p></body></html>"},            {MenuLangId::Macedonian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (препорачано: 0.01 [стандардно] или 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → без промена (a=0: off = сè под 1 се игнорира, без snap)<br/>Ако Aim не се чувствува како што очекувате, обидете се да ја намалите оваа вредност.</p></body></html>"},            {MenuLangId::Bulgarian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (препоръчително: 0.01 [по подразбиране] или 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → без промяна (a=0: off = всичко под 1 се игнорира, без snap)<br/>Ако Aim не се усеща както очаквате, опитайте да намалите тази стойност.</p></body></html>"},            {MenuLangId::Belarusian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (рэкамендавана: 0.01 [прадвызначана] або 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → без змен (a=0: off = усё ніжэй за 1 ігнаруецца, без snap)<br/>Калі Aim адчуваецца не так, як чакалася, паспрабуйце паменшыць гэта значэнне.</p></body></html>"},            {MenuLangId::Maltese, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (rakkomandat: 0.01 [default] jew 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → l-ebda bidla (a=0: off = kollox taħt 1 jiġi injorat, mingħajr snap)<br/>Jekk Aim ma jħossux kif mistenni, ipprova naqqas dan il-valur.</p></body></html>"},            {MenuLangId::Mongolian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (зөвлөмж: 0.01 [анхдагч] эсвэл 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → өөрчлөлтгүй (a=0: off = 1-ээс доош бүхнийг үл тооно, snap байхгүй)<br/>Aim хүлээсэн шиг ажиллахгүй байвал энэ утгыг багасгаж үзнэ үү.</p></body></html>"},            {MenuLangId::Latvian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (ieteicams: 0.01 [noklusējums] vai 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → bez izmaiņām (a=0: off = viss zem 1 tiek ignorēts, bez snap)<br/>Ja Aim nejūtas kā gaidīts, mēģiniet samazināt šo vērtību.</p></body></html>"},            {MenuLangId::Lithuanian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (rekomenduojama: 0.01 [numatyta] arba 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → be pakeitimų (a=0: off = viskas žemiau 1 ignoruojama, be snap)<br/>Jei Aim nesijaučia taip, kaip tikėtasi, pabandykite sumažinti šią reikšmę.</p></body></html>"},            {MenuLangId::Afrikaans, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (aanbeveel: 0.01 [verstek] of 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → geen verandering (a=0: off = alles onder 1 word geïgnoreer, geen snap)<br/>As Aim nie voel soos verwag nie, probeer om hierdie waarde te verlaag.</p></body></html>"},            {MenuLangId::Irish, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (molta: 0.01 [réamhshocrú] nó 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → gan athrú (a=0: off = déantar neamhaird de gach rud faoi 1, gan snap)<br/>Mura mothaíonn Aim mar a bhíothas ag súil leis, bain triail as an luach seo a laghdú.</p></body></html>"},            {MenuLangId::Assamese, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (পৰামৰ্শিত: 0.01 [ডিফল্ট] বা 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → সলনি নহয় (a=0: off = 1-ৰ তলৰ সকলো উপেক্ষা কৰা হয়, snap নাই)<br/>Aim আশা কৰা ধৰণে নালাগিলে, এই মান কমাই চাওক।</p></body></html>"},            {MenuLangId::Amharic, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (የሚመከር፦ 0.01 [ነባሪ] ወይም 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ለውጥ የለም (a=0: off = ከ1 በታች ሁሉ ይተዋል፣ snap የለም)<br/>Aim እንደተጠበቀው ካልሆነ ይህንን እሴት ለመቀነስ ይሞክሩ።</p></body></html>"},            {MenuLangId::Estonian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (soovitus: 0.01 [vaikimisi] või 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → muutuseta (a=0: off = kõik alla 1 lõigatakse ära, snap puudub)<br/>Kui Aim ei tundu ootuspärane, proovi seda väärtust vähendada.</p></body></html>"},            {MenuLangId::Kazakh, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (ұсынылады: 0.01 [әдепкі] немесе 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → өзгеріс жоқ (a=0: off = 1-ден төменнің бәрі қиылады, snap жоқ)<br/>Aim күткендей сезілмесе, бұл мәнді азайтып көріңіз.</p></body></html>"},            {MenuLangId::Catalan, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (recomanat: 0.01 [per defecte] o 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → sense canvi (a=0: off = tot el que és sota 1 es talla, sense snap)<br/>Si l'Aim no se sent com s'espera, prova de reduir aquest valor.</p></body></html>"},            {MenuLangId::Kyrgyz, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (сунушталат: 0.01 [демейки] же 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → өзгөрбөйт (a=0: off = 1ден төмөндүн баары кесилет, snap жок)<br/>Aim күтүлгөндөй сезилбесе, бул маанини азайтып көрүңүз.</p></body></html>"},            {MenuLangId::Slovak, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (odporúčané: 0.01 [predvolené] alebo 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → bez zmeny (a=0: off = všetko pod 1 sa odreže, bez snap)<br/>Ak Aim nepôsobí podľa očakávania, skúste túto hodnotu znížiť.</p></body></html>"},            {MenuLangId::Slovenian, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (priporočeno: 0.01 [privzeto] ali 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → brez spremembe (a=0: off = vse pod 1 se odreže, brez snap)<br/>Če Aim ne deluje po pričakovanjih, poskusite zmanjšati to vrednost.</p></body></html>"},            {MenuLangId::Zulu, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (kunconyiwe: 0.01 [okuzenzakalelayo] noma 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → akukho shintsho (a=0: off = konke okungaphansi kuka-1 kuyasikwa, akukho snap)<br/>Uma i-Aim ingazizwa ilindelekile, zama ukwehlisa leli nani.</p></body></html>"},            {MenuLangId::Basque, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (gomendatua: 0.01 [lehenetsia] edo 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → aldaketarik ez (a=0: off = 1 azpiko guztia mozten da, snap gabe)<br/>Aim espero bezala sentitzen ez bada, saiatu balio hau jaisten.</p></body></html>"},            {MenuLangId::Hebrew, "<html><head/><body><p><b>Input threshold (dead zone + snap)</b> (מומלץ: 0.01 [ברירת מחדל] או 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → ללא שינוי (a=0: off = כל מה שמתחת ל-1 נחתך, ללא snap)<br/>אם Aim לא מרגיש כמצופה, נסה להקטין את הערך הזה.</p></body></html>"},

















































        }
