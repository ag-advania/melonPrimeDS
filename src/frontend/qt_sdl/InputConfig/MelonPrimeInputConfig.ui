									</layout>
								</widget>
							</item>

							<item>
								<widget class="QPushButton" name="btnToggleBugFix">
									<property name="text"><string>▶ BUG FIXES</string></property>
									<property name="checkable"><bool>true</bool></property>
									<property name="checked"><bool>false</bool></property>
									<property name="flat"><bool>true</bool></property>
									<property name="styleSheet"><string>QPushButton { text-align: left; font-weight: bold; padding: 4px; } QPushButton::checked { font-weight: bold; }</string></property>
								</widget>
							</item>
							<item>
								<widget class="QWidget" name="sectionBugFix">
									<layout class="QVBoxLayout" name="vboxBugFix">
										<property name="leftMargin"><number>8</number></property>
										<property name="topMargin"><number>2</number></property>
										<property name="rightMargin"><number>0</number></property>
										<property name="bottomMargin"><number>4</number></property>
										<item>
											<widget class="QCheckBox" name="cbMetroidFixWifiBitset">
												<property name="text">
													<string>Friend/Rival Wi-Fi Active Bitset Fix (v2)</string>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidFixWifiBitsetDesc">
												<property name="text">
													<string>Fixes the broken pseudo-64-bit bitset used to track active friend/rival slots.
Slot indices 32-59 are not handled correctly in JP1.0 / US1.0 / EU1.0,
causing some friends/rivals to be invisible online.
Replaced with byte-indexed bitset matching JP1.1 / US1.1 / EU1.1 / KR1.0 behavior.
(JP1.0 / US1.0 / EU1.0 only — no effect on other ROM versions)</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
												<property name="enabled">
													<bool>true</bool>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QCheckBox" name="cbMetroidFixShadowFreeze">
												<property name="text">
													<string>Shadow Freeze Fix (Ice Wave full 3D angle check)</string>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidFixShadowFreezeDesc">
												<property name="text">
													<string>Fixes the Shadow Freeze issue by replacing Ice Wave's final hit/miss angle decision with a full 3D check while keeping the original lateral range check.</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QCheckBox" name="cbMetroidFixNoxusBladePersistence">
												<property name="text">
													<string>Fix Noxus Blade Persistence on Death</string>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidFixNoxusBladePersistenceDesc">
												<property name="text">
													<string>Fixes a bug where Noxus&apos;s Vhoscythe/blade attack continues dealing damage after death and respawn. When Noxus dies mid-blade-attack, the alt attack timer is not cleared, causing the blade hit detection to remain active after revival. This fix clears the timer at the moment of death.</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidFixNoxusBladePersistenceWarning">
												<property name="text">
													<string>This fix is still unstable. The blade may still remain active in some cases, especially in the Korean version.</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
											</widget>
										</item>
									</layout>
								</widget>
							</item>

							<item>
								<widget class="QPushButton" name="btnToggleGameFeature">
									<property name="text"><string>▶ GAME FEATURE IMPROVEMENTS</string></property>
									<property name="checkable"><bool>true</bool></property>
									<property name="checked"><bool>false</bool></property>
									<property name="flat"><bool>true</bool></property>
									<property name="styleSheet"><string>QPushButton { text-align: left; font-weight: bold; padding: 4px; } QPushButton::checked { font-weight: bold; }</string></property>
								</widget>
							</item>
							<item>
								<widget class="QWidget" name="sectionGameFeature">
									<layout class="QVBoxLayout" name="vboxGameFeature">
										<property name="leftMargin"><number>8</number></property>
										<property name="topMargin"><number>2</number></property>
										<property name="rightMargin"><number>0</number></property>
										<property name="bottomMargin"><number>4</number></property>
										<item>
											<widget class="QCheckBox" name="cbMetroidUseFirmwareLanguage">
												<property name="text">
													<string>Use DS Firmware Language (EU-style Auto Patch)</string>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidUseFirmwareLanguageDesc">
												<property name="text">
													<string>&lt;html&gt;&lt;body&gt;
Reads your DS firmware language and patches the game to display in that language.&lt;br&gt;
The EU ROM has a hidden Japanese option — setting your DS firmware to Japanese activates it.&lt;br&gt;&lt;br&gt;
&lt;b&gt;EU / US ROM:&lt;/b&gt; Works in all modes (multiplayer and adventure).&lt;br&gt;
&lt;b&gt;JP ROM:&lt;/b&gt; Works in multiplayer only. &lt;font color=&quot;red&quot;&gt;&lt;b&gt;Adventure mode will not be playable with this enabled.&lt;/b&gt;&lt;/font&gt;&lt;br&gt;
&lt;b&gt;KR ROM:&lt;/b&gt; Not yet supported.
&lt;/body&gt;&lt;/html&gt;</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QCheckBox" name="cbMetroidShowHeadshotOnline">
												<property name="text">
													<string>Show Headshot Notification Online</string>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidShowHeadshotOnlineDesc">
												<property name="text">
													<string>Forces the standalone HEADSHOT notification to appear during Wi-Fi/online matches.</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QCheckBox" name="cbMetroidShowEnemyHpMeterOnline">
												<property name="text">
													<string>Show Enemy HP Meter Online</string>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidShowEnemyHpMeterOnlineDesc">
												<property name="text">
													<string>HP information is generally not updated, so it is unreliable. You can use it as a rough indicator of who you hit.</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QCheckBox" name="cbMetroidExpandStageMatrix">
												<property name="text">
													<string>Expand Stage Selection (Unlock Extra Stages)</string>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidExpandStageMatrixDesc">
												<property name="text">
													<string>&lt;html&gt;&lt;body&gt;
Unlocks 5 stage/mode combinations verified as stable. Applied automatically while the stage select menu is open.&lt;br&gt;&lt;br&gt;
&lt;b&gt;Bounty&lt;/b&gt;&lt;br&gt;
&amp;nbsp;&amp;nbsp;Fuel Stack — Octolith present, items available&lt;br&gt;
&amp;nbsp;&amp;nbsp;Alinos Gateway — Octolith present, affinity weapon spawns below the slope&lt;br&gt;&lt;br&gt;
&lt;b&gt;Capture&lt;/b&gt;&lt;br&gt;
&amp;nbsp;&amp;nbsp;Celestial Gateway — Octolith present, jumpers and items available&lt;br&gt;&lt;br&gt;
&lt;b&gt;Defender&lt;/b&gt;&lt;br&gt;
&amp;nbsp;&amp;nbsp;High Ground — items present, defender zone ring at bottom-left of Magmaul area&lt;br&gt;
&amp;nbsp;&amp;nbsp;Elder Passage — items present, defender zone ring at bottom-left of Magmaul area
&lt;/body&gt;&lt;/html&gt;</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QCheckBox" name="cbMetroidExpandStageMatrixExtra">
												<property name="text">
													<string>Also unlock additional stages</string>
												</property>
												<property name="styleSheet">
													<string>margin-left: 16px;</string>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidExpandStageMatrixExtraDesc">
												<property name="text">
													<string>&lt;html&gt;&lt;body&gt;
Unlocks 9 more combinations on top of the base selection.&lt;br&gt;&lt;br&gt;
&lt;b&gt;Battle / Node / Prime Hunter / Survival&lt;/b&gt;&lt;br&gt;
&amp;nbsp;&amp;nbsp;Transfer Lock Wide — normal gravity&lt;br&gt;&lt;br&gt;
&lt;b&gt;Defender&lt;/b&gt;&lt;br&gt;
&amp;nbsp;&amp;nbsp;Transfer Lock — no defender rings, Volt Driver + Battlehammer weapons only&lt;br&gt;
&amp;nbsp;&amp;nbsp;Compressor Room — no defender rings, no jumpers, no items&lt;br&gt;
&amp;nbsp;&amp;nbsp;Incubator — no defender rings, items and jumpers present&lt;br&gt;
&amp;nbsp;&amp;nbsp;Fuel Stack — no defender rings, no floating, Imperialist only&lt;br&gt;
&amp;nbsp;&amp;nbsp;Head Shot — no defender rings, normal gravity, 2 jumpers, Alt Form corridor does not launch
&lt;/body&gt;&lt;/html&gt;</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
												<property name="styleSheet">
													<string>margin-left: 16px;</string>
												</property>
											</widget>
										</item>
									</layout>
								</widget>
							</item>

							<item>
								<widget class="QPushButton" name="btnToggleDisableFeatures">
									<property name="text"><string>▶ DISABLE FEATURES</string></property>
									<property name="checkable"><bool>true</bool></property>
									<property name="checked"><bool>false</bool></property>
									<property name="flat"><bool>true</bool></property>
									<property name="styleSheet"><string>QPushButton { text-align: left; font-weight: bold; padding: 4px; } QPushButton::checked { font-weight: bold; }</string></property>
								</widget>
							</item>
							<item>
								<widget class="QWidget" name="sectionDisableFeatures">
									<layout class="QVBoxLayout" name="vboxDisableFeatures">
										<property name="leftMargin"><number>8</number></property>
										<property name="topMargin"><number>2</number></property>
										<property name="rightMargin"><number>0</number></property>
										<property name="bottomMargin"><number>4</number></property>
										<item>
											<widget class="QCheckBox" name="cbMetroidDisableDoubleDamageMultiplier">
												<property name="text">
													<string>Disable Double Damage Multiplier</string>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidDisableDoubleDamageMultiplierDesc">
												<property name="text">
													<string>&lt;html&gt;&lt;body&gt;
Keeps the Double Damage pickup, timer, HUD, sound, and visual effects, but changes the damage boost from 2x to 1x.&lt;br&gt;&lt;br&gt;
&lt;font color=&quot;red&quot;&gt;&lt;b&gt;Important:&lt;/b&gt; the 2x → 1x change only applies on &lt;b&gt;your&lt;/b&gt; side. If your opponents do not also enable Damage 1x, your shots will still deal 2x damage to them while Double Damage is active.&lt;/font&gt;&lt;br&gt;&lt;br&gt;
Please use this only with all participants' consent.
&lt;/body&gt;&lt;/html&gt;</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
											</widget>
										</item>
										<item>
											<widget class="QCheckBox" name="cbMetroidDamageNotifyPurple">
												<property name="text">
													<string>Damage Notify Purple</string>
												</property>
												<property name="styleSheet"><string>QCheckBox { margin-left: 20px; }</string></property>
											</widget>
										</item>
										<item>
											<widget class="QLabel" name="lblMetroidDamageNotifyPurpleDesc">
												<property name="text">
													<string>&lt;html&gt;&lt;body&gt;
Briefly flashes you in the Double Damage purple state when you take damage, so opponents can see you got hit.&lt;br&gt;&lt;br&gt;
&lt;font color=&quot;red&quot;&gt;&lt;b&gt;Important:&lt;/b&gt; this writes a real Double Damage timer, so for a brief moment you actually &lt;b&gt;enter Double Damage state&lt;/b&gt; — your shots will deal 2x damage to opponents during that window unless they also have Damage 1x enabled.&lt;/font&gt;&lt;br&gt;&lt;br&gt;
&lt;b&gt;Always get every participant's consent before using this in a match.&lt;/b&gt; Pair with &quot;Disable Double Damage Multiplier&quot; above to keep your own damage at 1x.
&lt;/body&gt;&lt;/html&gt;</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
												<property name="styleSheet"><string>QLabel { margin-left: 20px; }</string></property>
											</widget>
										</item>
										<item>
											<widget class="QPushButton" name="btnToggleDisablePickingUpSpecificItems">
