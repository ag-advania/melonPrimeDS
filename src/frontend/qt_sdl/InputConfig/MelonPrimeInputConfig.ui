							<!-- LOW HP WARNING toggle -->
							<item><widget class="QPushButton" name="btnToggleLowHpWarning">
								<property name="text"><string>▶ LOW HP WARNING</string></property>
								<property name="checkable"><bool>true</bool></property>
								<property name="checked"><bool>false</bool></property>
								<property name="flat"><bool>true</bool></property>
								<property name="styleSheet"><string>QPushButton { text-align: left; font-weight: bold; padding: 4px; } QPushButton::checked { font-weight: bold; }</string></property>
							</widget></item>
							<item>
								<widget class="QWidget" name="sectionLowHpWarning">
								<layout class="QVBoxLayout">
									<item>
										<widget class="QLabel">
											<property name="text"><string>Changes the HP value at which the low-HP warning sound and warning HUD state trigger (vanilla: 25). Applied at the start of each match based on the current Damage setting.</string></property>
											<property name="wordWrap"><bool>true</bool></property>
										</widget>
									</item>
									<item>
										<layout class="QFormLayout" name="formLowHpWarning">
											<item row="0" column="0"><widget class="QLabel"><property name="text"><string>Mode</string></property></widget></item>
											<item row="0" column="1">
												<widget class="QComboBox" name="comboMetroidLowHpWarningMode">
													<item><property name="text"><string>Disabled (vanilla 25)</string></property></item>
													<item><property name="text"><string>Fixed</string></property></item>
													<item><property name="text"><string>Per Damage (Low / Medium / High)</string></property></item>
													<item><property name="text"><string>Auto Scale (by Damage)</string></property></item>
												</widget>
											</item>
											<item row="1" column="0"><widget class="QLabel" name="lblMetroidLowHpWarningFixed"><property name="text"><string>Fixed Threshold</string></property></widget></item>
											<item row="1" column="1"><widget class="QSpinBox" name="spinMetroidLowHpWarningFixed"><property name="minimum"><number>0</number></property><property name="maximum"><number>255</number></property></widget></item>
											<item row="2" column="0"><widget class="QLabel" name="lblMetroidLowHpWarningLow"><property name="text"><string>Per Damage — Low</string></property></widget></item>
											<item row="2" column="1"><widget class="QSpinBox" name="spinMetroidLowHpWarningLow"><property name="minimum"><number>0</number></property><property name="maximum"><number>255</number></property></widget></item>
											<item row="3" column="0"><widget class="QLabel" name="lblMetroidLowHpWarningMedium"><property name="text"><string>Per Damage — Medium</string></property></widget></item>
											<item row="3" column="1"><widget class="QSpinBox" name="spinMetroidLowHpWarningMedium"><property name="minimum"><number>0</number></property><property name="maximum"><number>255</number></property></widget></item>
											<item row="4" column="0"><widget class="QLabel" name="lblMetroidLowHpWarningHigh"><property name="text"><string>Per Damage — High</string></property></widget></item>
											<item row="4" column="1"><widget class="QSpinBox" name="spinMetroidLowHpWarningHigh"><property name="minimum"><number>0</number></property><property name="maximum"><number>255</number></property></widget></item>
											<item row="5" column="0"><widget class="QLabel" name="lblMetroidLowHpWarningAutoBase"><property name="text"><string>Auto Scale — Base</string></property></widget></item>
											<item row="5" column="1"><widget class="QSpinBox" name="spinMetroidLowHpWarningAutoBase"><property name="minimum"><number>0</number></property><property name="maximum"><number>255</number></property></widget></item>
										</layout>
									</item>
									<item>
										<widget class="QLabel" name="lblMetroidLowHpWarningDesc">
											<property name="text"><string>Auto Scale: Low = Base ×0.75, Medium = Base, High = Base ×1.25 (rounded). 0 effectively disables the warning. Range 0–255.</string></property>
											<property name="wordWrap"><bool>true</bool></property>
											<property name="indent"><number>20</number></property>
										</widget>
									</item>
								</layout>
								</widget>
							</item>

							<item><widget class="QPushButton" name="btnToggleDeveloperOnly">
								<property name="text"><string>▶ DEVELOPER ONLY</string></property>
								<property name="checkable"><bool>true</bool></property>
								<property name="checked"><bool>false</bool></property>
								<property name="flat"><bool>true</bool></property>
								<property name="styleSheet"><string>QPushButton { text-align: left; font-weight: bold; padding: 4px; } QPushButton::checked { font-weight: bold; }</string></property>
							</widget></item>
							<item>
								<widget class="QWidget" name="sectionDeveloperOnly">
								<layout class="QVBoxLayout" name="vboxDeveloperOnly">
									<property name="leftMargin"><number>8</number></property>
									<property name="topMargin"><number>2</number></property>
									<property name="rightMargin"><number>0</number></property>
									<property name="bottomMargin"><number>4</number></property>
									<item>
										<widget class="QLabel" name="lblMetroidDeveloperOnlyDesc">
											<property name="text"><string>Features in this section are still in development and are not ready for public release. They may or may not be released.</string></property>
											<property name="wordWrap"><bool>true</bool></property>
										</widget>
									</item>
									<item>
										<widget class="QCheckBox" name="cbMetroidEnableNativeAimRegisterInjection">
											<property name="enabled"><bool>false</bool></property>
											<property name="text"><string>Enable Native Aim Register Injection</string></property>
											<property name="toolTip"><string>Developer-only option. Currently disabled.</string></property>
										</widget>
									</item>
									<item>
										<widget class="QLabel" name="lblMetroidNativeAimRegisterInjectionDesc">
											<property name="enabled"><bool>false</bool></property>
											<property name="text"><string>Hooks at the aim call-site for lowest latency. Covers Biped and AltForm spec108=1 (Trace/Sylux/Weavel). When enabled, this overrides Native Aim Delta Hook (PostFold Write) above.</string></property>
											<property name="wordWrap"><bool>true</bool></property>
											<property name="styleSheet"><string>QLabel { margin-left: 20px; }</string></property>
										</widget>
									</item>
									<item>
										<widget class="QCheckBox" name="cbMetroidEnableImmediateInputEdgeOverlay">
											<property name="enabled"><bool>false</bool></property>
											<property name="text"><string>Enable Immediate Input Edge Overlay</string></property>
											<property name="toolTip"><string>Developer-only option. Currently disabled.</string></property>
										</widget>
									</item>
									<item>
										<widget class="QLabel" name="lblMetroidImmediateInputEdgeOverlayDesc">
											<property name="enabled"><bool>false</bool></property>
											<property name="text"><string>Generate pressed/released edges on the emulator side and overlay them into MPH's internal input state before player actions are processed. Covers fire, jump, zoom, and movement. Button masks are read from the player's current control-preset binding table, so all presets (Touch R/L, Dual R/L) are supported automatically.</string></property>
											<property name="wordWrap"><bool>true</bool></property>
											<property name="styleSheet"><string>QLabel { margin-left: 20px; }</string></property>
										</widget>
									</item>
								</layout>
								</widget>
							</item>

							<item>
								<spacer name="settingsSpacer"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property></spacer>
							</item>

						</layout>
									</widget>
								</widget>
							</item>
						</layout>
					</widget>



					<widget class="QWidget" name="tabCrosshair">
						<attribute name="title"><string>Custom HUD</string></attribute>
						<layout class="QVBoxLayout" name="customHudOuterVLayout">
							<property name="leftMargin"><number>0</number></property>
							<property name="topMargin"><number>0</number></property>
							<property name="rightMargin"><number>0</number></property>
							<property name="bottomMargin"><number>0</number></property>
							<item>
								<widget class="QPushButton" name="btnEditHudLayout">
									<property name="text"><string>Edit HUD Layout</string></property>
									<property name="toolTip"><string>Hide this dialog and enter the interactive HUD position editor</string></property>
								</widget>
							</item>
							<item>
								<widget class="QScrollArea" name="scrollCustomHud">
									<property name="widgetResizable"><bool>true</bool></property>
									<property name="frameShape"><enum>QFrame::NoFrame</enum></property>
									<widget class="QWidget" name="scrollCustomHudContents">
						<layout class="QVBoxLayout" name="crosshairVLayout">

							<!-- Enable Custom HUD -->
							<item>
								<widget class="QCheckBox" name="cbMetroidEnableCustomHud"><property name="text"><string>Enable Custom HUD (Replaces the in-game HUD with a custom overlay showing HP, ammo, weapon icons and crosshair)</string></property></widget>
							</item>

							<item>
								<spacer name="customHudSpacer"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property></spacer>
							</item>

						</layout>
									</widget>
								</widget>
							</item>
						</layout>
					</widget>
					<widget class="QWidget" name="tabCustomHudCode">
						<attribute name="title"><string>Custom HUD Input/Output</string></attribute>
						<layout class="QVBoxLayout" name="verticalLayoutCustomHudCode">
							<property name="leftMargin"><number>12</number></property>
							<property name="topMargin"><number>12</number></property>
							<property name="rightMargin"><number>12</number></property>
							<property name="bottomMargin"><number>12</number></property>
							<item>
								<widget class="QLabel" name="labelMetroidCustomHudCodeIntro">
									<property name="text"><string>Share your Custom HUD setup as TOML text, or paste TOML into the input area to apply it to the current dialog.</string></property>
									<property name="wordWrap"><bool>true</bool></property>
								</widget>
							</item>
							<item>
								<widget class="QLabel" name="labelMetroidCustomHudCodeOutputTitle">
									<property name="text"><string>Output</string></property>
								</widget>
							</item>
							<item>
								<widget class="QPlainTextEdit" name="pteMetroidCustomHudCodeOutput">
									<property name="readOnly"><bool>true</bool></property>
									<property name="placeholderText"><string>Press Generate to build sharable Custom HUD TOML.</string></property>
								</widget>
							</item>
							<item>
								<layout class="QHBoxLayout" name="layoutMetroidCustomHudCodeOutputButtons">
									<item><widget class="QPushButton" name="btnMetroidCustomHudCodeGenerate"><property name="text"><string>Generate</string></property></widget></item>
									<item><widget class="QPushButton" name="btnMetroidCustomHudCodeCopy"><property name="text"><string>Copy Output</string></property></widget></item>
									<item><spacer name="spacerMetroidCustomHudCodeOutput"><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property></spacer></item>
								</layout>
							</item>
							<item>
								<widget class="QLabel" name="labelMetroidCustomHudCodeInputTitle">
									<property name="text"><string>Input</string></property>
								</widget>
							</item>
							<item>
								<widget class="QPlainTextEdit" name="pteMetroidCustomHudCodeInput">
									<property name="placeholderText"><string>Paste Custom HUD TOML here, then press Apply Input.</string></property>
								</widget>
							</item>
							<item>
								<layout class="QHBoxLayout" name="layoutMetroidCustomHudCodeInputButtons">
									<item><widget class="QPushButton" name="btnMetroidCustomHudCodeUseOutput"><property name="text"><string>Copy Output to Input</string></property></widget></item>
									<item><widget class="QPushButton" name="btnMetroidCustomHudCodeApply"><property name="text"><string>Apply Input to Custom HUD</string></property></widget></item>
									<item><spacer name="spacerMetroidCustomHudCodeInput"><property name="orientation"><enum>Qt::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property></spacer></item>
								</layout>
							</item>
							<item>
								<widget class="QLabel" name="labelMetroidCustomHudCodeStatus">
                                    <property name="text"><string></string></property>
									<property name="wordWrap"><bool>true</bool></property>
								</widget>
							</item>
							<item>
								<spacer name="spacerMetroidCustomHudCodeBottom"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property></spacer>
							</item>
						</layout>
					</widget>

				</widget>
			</item>
		</layout>
	</widget>

	<resources>
		<include location="resources/ds.qrc"/>
	</resources>

	<connections>
	</connections>
</ui>
