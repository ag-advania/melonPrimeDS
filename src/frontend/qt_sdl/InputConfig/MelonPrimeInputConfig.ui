										</widget>
									</item>
									<item>
										<widget class="QLabel" name="lblMetroidJoy2KeySupportDesc">
											<property name="text"><string>Compatibility mode for external controller-to-keyboard/mouse tools such as JoyToKey, Steam Input, reWASD, or similar remappers. It can help when mapped keys sometimes stay pressed after release. If you use a normal keyboard and mouse directly, disabling this may reduce input latency slightly.</string></property>
											<property name="wordWrap"><bool>true</bool></property>
											<property name="styleSheet"><string>QLabel { margin-left: 20px; }</string></property>
										</widget>
									</item>
									</layout>
