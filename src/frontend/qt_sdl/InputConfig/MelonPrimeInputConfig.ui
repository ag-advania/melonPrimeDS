								<widget class="QWidget" name="sectionInGameAspectRatio">
								<layout class="QVBoxLayout">
									<item>
										<widget class="QLabel">
											<property name="text"><string>When playing with an Aspect Ratio other than 4:3 (Native), apply this to change the in-game 3D aspect ratio to match. Changes are applied at the start of each match.</string></property>
