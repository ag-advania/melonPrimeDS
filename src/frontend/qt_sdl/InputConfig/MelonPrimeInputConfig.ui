											<item><widget class="QSpinBox" name="inputMetroidBtmOverlayDstY"><property name="minimum"><number>0</number></property><property name="maximum"><number>191</number></property><property name="value"><number>0</number></property><property name="minimumSize"><size><width>72</width><height>0</height></size></property></widget></item>
											<item><widget class="QLabel" name="labelMetroidBtmOverlayDstY"><property name="text"><string>0</string></property><property name="minimumSize"><size><width>30</width><height>0</height></size></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property></widget></item>
