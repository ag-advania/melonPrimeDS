								</widget>
							</item>
							<item>
								<widget class="QWidget" name="sectionSensitivity">
									<layout class="QFormLayout" name="formSens">
										<item row="0" column="0">
											<widget class="QDoubleSpinBox" name="metroidMphSensitvitySpinBox">
												<property name="minimum">
													<double>-5.008</double>
												</property>
												<property name="maximum">
													<double>155.225</double>
												</property>
												<property name="singleStep">
													<double>0.1</double>
												</property>
												<property name="decimals">
													<number>3</number>
												</property>
												<property name="value">
													<double>-3.000</double>
												</property>
											</widget>
										</item>
										<item row="0" column="1">
											<widget class="QLabel" name="metroidMphSensitvityLabel">
												<property name="text">
													<string>MPH Sensitivity (default: -3)</string>
												</property>
											</widget>
										</item>
										<item row="1" column="0" colspan="2">
											<widget class="QLabel" name="metroidMphSensitvityLabel2">
												<property name="text">
													<string>(Set this value to 1 or lower if possible for precise aiming. We recommend a range of -3 to 0. However, setting it too low will increase the HUD shake when aiming. This value is relative to the game's sensitivity, so 0 is not zero sensitivity; it is only lower than 1. This setting overrides MPH's in-game sensitivity, so changing sensitivity inside the game has no effect.)</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
												<property name="indent">
													<number>20</number>
												</property>
											</widget>
										</item>
										<item row="2" column="0" colspan="2">
											<widget class="QCheckBox" name="cbMetroidDisableMphAimSmoothing">
												<property name="text"><string>Disable MPH Aim Smoothing (Disables the in-game aim smoothing. Note: Sensitivity will be reduced to 25% in Stylus Mode)</string></property>
											</widget>
										</item>
										<item row="3" column="0" colspan="2">
											<widget class="QCheckBox" name="cbMetroidEnableNativeAimPostFoldWrite">
												<property name="text"><string>Enable Native Aim Delta Hook (PostFold Write)</string></property>
												<property name="styleSheet"><string>QCheckBox { margin-left: 24px; }</string></property>
											</widget>
										</item>
										<item row="4" column="0" colspan="2">
											<widget class="QLabel" name="lblMetroidNativeAimHookModeDesc">
												<property name="text"><string>PostFold Write hooks after TouchInputProcessor and covers all AltForms including spec108=0 (Samus/Kanden/Noxus/Spire).</string></property>
												<property name="wordWrap"><bool>true</bool></property>
												<property name="styleSheet"><string>QLabel { margin-left: 48px; }</string></property>
											</widget>
										</item>
										<item row="8" column="0" colspan="2">
											<widget class="QCheckBox" name="cbMetroidEnableDirectAltFormTransform">
												<property name="text"><string>Enable Direct Alt-Form Transform</string></property>
											</widget>
										</item>
										<item row="9" column="0" colspan="2">
											<widget class="QLabel" name="lblMetroidDirectAltFormTransformDesc">
												<property name="text"><string>Triggers the Alt-Form transition by writing directly to the game's player state flags instead of simulating touch input. Uses the same guard conditions as the game's own TransformRequest function. Note: Weavel Halfturret spawn (hunter-specific setup inside TransformRequest) is not reproduced.</string></property>
												<property name="wordWrap"><bool>true</bool></property>
												<property name="styleSheet"><string>QLabel { margin-left: 24px; }</string></property>
											</widget>
										</item>
										<item row="10" column="0" colspan="2">
											<widget class="QCheckBox" name="cbMetroidEnableStylusMode">
												<property name="text"><string>Enable Stylus Mode (Leave this unchecked unless you want to play with the stylus)</string></property>
											</widget>
										</item>
										<item row="11" column="0">
											<widget class="QSpinBox" name="metroidAimSensitvitySpinBox">
												<property name="minimum">
													<number>0</number>
												</property>
												<property name="maximum">
													<number>99999</number>
												</property>
												<property name="value">
													<number>63</number>
												</property>
											</widget>
										</item>
										<item row="11" column="1">
											<widget class="QLabel" name="metroidAimSensitvityLabel">
												<property name="text">
													<string>Aim sensitivity (default: 63)</string>
												</property>
											</widget>
										</item>
										<item row="12" column="0">
											<widget class="QDoubleSpinBox" name="metroidAimYAxisScaleSpinBox">
												<property name="minimum">
													<double>0.000001</double>
												</property>
												<property name="maximum">
													<double>2</double>
												</property>
												<property name="singleStep">
													<double>0.1</double>
												</property>
												<property name="decimals">
													<number>6</number>
												</property>
												<property name="value">
													<double>1.514700</double>
												</property>
											</widget>
										</item>
										<item row="12" column="1">
											<widget class="QLabel" name="metroidAimYAxisScaleLabel">
												<property name="text">
													<string>Aim Y-Axis Scale (default: 1.5147)</string>
												</property>
											</widget>
										</item>
										<item row="13" column="0" colspan="2">
											<widget class="QLabel" name="metroidAimYAxisScaleLabel2">
												<property name="text">
													<string>(1.5147 = MPH native; option: 1.9429 = perfectly matches X/Y angular velocity)</string>
												</property>
												<property name="wordWrap">
													<bool>true</bool>
												</property>
												<property name="indent">
													<number>20</number>
												</property>
											</widget>
										</item>
										<item row="14" column="0">
											<widget class="QDoubleSpinBox" name="metroidAimAdjustSpinBox">
												<property name="minimum">
													<double>0.000000</double>
												</property>
												<property name="maximum">
													<double>100.000000</double>
												</property>
												<property name="singleStep">
													<double>0.1</double>
												</property>
												<property name="decimals">
													<number>6</number>
												</property>
												<property name="value">
													<double>0.010000</double>
												</property>
											</widget>
										</item>
										<item row="14" column="1">
											<widget class="QLabel" name="metroidAimAdjustLabel">
												<property name="text">
													<string notr="true">&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;b&gt;Input threshold (deadzone + snap)&lt;/b&gt; (recommended: 0.01 [default] or 0.5): |x|&amp;lt;a → 0, a ≤ |x|&amp;lt;1 → ±1, |x|≥1 → as is (a=0: off = all values under 1 ignored, no snap)&lt;br/&gt;When your aim isn't going the way you want, try lowering this value.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
												</property>
											</widget>
										</item>
										<item row="15" column="0" colspan="2">
											<widget class="QCheckBox" name="cbMetroidEnableAimAccumulator">
												<property name="text"><string>Enable Aim Sub-pixel Accumulator (Carry fractional mouse movement across frames. Enable for smoother low-sensitivity aiming)</string></property>
											</widget>
										</item>
										<item row="16" column="0">
											<widget class="QPushButton" name="metroidResetSensitivityValues">
												<property name="text">
													<string>Reset sensitivity values</string>
												</property>
											</widget>
