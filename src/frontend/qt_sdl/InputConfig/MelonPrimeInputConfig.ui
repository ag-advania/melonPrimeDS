							</widget></item>
							<item>
								<widget class="QWidget" name="sectionInputSettings">
								<layout class="QVBoxLayout">
									<item>
										<widget class="QCheckBox" name="cbMetroidApplyJoy2KeySupport">
											<property name="text"><string>Enable Joy2KeySupport (slightly increase input delay)</string></property>
										</widget>
									</item>
									<item>
										<widget class="QCheckBox" name="cbMetroidEnableStylusMode">
											<property name="text"><string>Enable Stylus Mode (Leave this unchecked unless you want to play with the stylus)</string></property>
										</widget>
									</item>
									<item>
										<widget class="QCheckBox" name="cbMetroidDisableMphAimSmoothing">
											<property name="text"><string>Disable MPH Aim Smoothing (Disables the in-game aim smoothing. Note: Sensitivity will be reduced to 25% in Stylus Mode)</string></property>
										</widget>
									</item>
									<item>
										<widget class="QCheckBox" name="cbMetroidEnableAimAccumulator">
											<property name="text"><string>Enable Aim Sub-pixel Accumulator (Carry fractional mouse movement across frames. Enable for smoother low-sensitivity aiming)</string></property>
										</widget>
									</item>
								</layout>
								</widget>
							</item>

							<!-- SCREEN SYNC toggle (merged from tabMetroid2) -->
							<item><widget class="QPushButton" name="btnToggleScreenSync">
								<property name="text"><string>▶ SCREEN SYNC</string></property>
								<property name="checkable"><bool>true</bool></property>
								<property name="checked"><bool>false</bool></property>
								<property name="flat"><bool>true</bool></property>
								<property name="styleSheet"><string>QPushButton { text-align: left; font-weight: bold; padding: 4px; } QPushButton::checked { font-weight: bold; }</string></property>
							</widget></item>
							<item>
								<widget class="QWidget" name="sectionScreenSync">
								<layout class="QVBoxLayout" name="vboxScreenSync">
									<item>
										<layout class="QHBoxLayout" name="hboxScreenSync">
											<item>
												<widget class="QComboBox" name="comboMetroidScreenSyncMode">
													<property name="toolTip"><string>Screen Sync Mode: Off = no sync call, glFinish = wait for GL commands to complete, DwmFlush = wait for DWM compositor (Windows only)</string></property>
													<item><property name="text"><string>Off</string></property></item>
													<item><property name="text"><string>glFinish</string></property></item>
													<item><property name="text"><string>DwmFlush</string></property></item>
													<property name="currentIndex"><number>0</number></property>
												</widget>
											</item>
											<item>
												<widget class="QLabel" name="labelMetroidScreenSyncMode">
													<property name="text"><string>Screen Sync Mode — Default: Off</string></property>
												</widget>
											</item>
										</layout>
									</item>
									<item>
										<widget class="QLabel" name="labelMetroidScreenSyncDesc">
											<property name="text"><string>Off: No sync (lowest latency, but the display may look choppy). glFinish: Smoother display by waiting for rendering to fully complete each frame. DwmFlush: Smoother display by syncing with the Windows compositor (Windows only). Try glFinish or DwmFlush if the screen looks choppy or flickery. Automatically disabled during FastForward/SlowMo.</string></property>
											<property name="wordWrap"><bool>true</bool></property>
											<property name="indent"><number>20</number></property>
										</widget>
									</item>

								</layout>
								</widget>
							</item>

