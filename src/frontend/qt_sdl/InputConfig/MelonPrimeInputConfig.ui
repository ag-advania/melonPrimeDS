											<item row="0" column="0"><widget class="QLabel"><property name="text"><string>Enable In-Game Aspect Ratio</string></property></widget></item>
											<item row="0" column="1"><widget class="QCheckBox" name="cbMetroidInGameAspectRatio"><property name="text"><string></string></property><property name="checked"><bool>true</bool></property></widget></item>
											<item row="1" column="0"><widget class="QLabel"><property name="text"><string>Aspect Ratio Mode</string></property></widget></item>
											<item row="1" column="1">
												<widget class="QComboBox" name="comboMetroidInGameAspectRatioMode">
													<item><property name="text"><string>Auto (match Aspect Ratio)</string></property></item>
													<item><property name="text"><string>5:3 (3DS)</string></property></item>
													<item><property name="text"><string>16:10 (3DS)</string></property></item>
													<item><property name="text"><string>16:9</string></property></item>
													<item><property name="text"><string>21:9</string></property></item>
												</widget>
											</item>
										</layout>
									</item>
									<item>
										<widget class="QLabel" name="labelInGameAspectRatioAutoDesc">
											<property name="text"><string>Auto: Automatically applies the aspect ratio patch to match the current Aspect Ratio setting (4:3 = off, 5:3/16:9/21:9 = auto-applied, window = off).</string></property>
											<property name="wordWrap"><bool>true</bool></property>
											<property name="indent"><number>20</number></property>
										</widget>
									</item>
								</layout>
								</widget>
							</item>

							<item>
								<spacer name="settingsSpacer"><property name="orientation"><enum>Qt::Vertical</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property></spacer>
							</item>

						</layout>
									</widget>
								</widget>
							</item>
						</layout>
					</widget>



					<widget class="QWidget" name="tabCrosshair">
