@@ -165,7 +165,7 @@
         "metroidAimAdjustLabel",
         {
             {MenuLangId::Japanese, "<html><head/><body><p><b>入力しきい値 (デッドゾーン + スナップ)</b>(推奨: 0.01 [既定] または 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → そのまま (a=0: オフ = 1未満をすべて無視、スナップなし)<br/>エイムが思った通りに動かない場合は、この値を下げてみてください。</p></body></html>"},
-            {MenuLangId::German, "<html><head/><body><p><b>Eingabeschwellenwert (Totzone + Einrasten)</b>(empfohlen: 0.01 [Standard] oder 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → unverändert (a=0: Aus = alles unter 1 ignorieren, kein Einrasten)<br/>Wenn sich die Zielbewegung nicht wie erwartet anfühlt, versuche diesen Wert zu senken.</p></body></html>"},
+            {MenuLangId::German, "<html><head/><body><p><b>Eingabeschwelle (Totzone + Sprung auf Vollausschlag)</b> (empfohlen: 0.01 [Standard] oder 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → unverändert (a=0: Aus = alle Werte unter 1 ignorieren, kein Sprung auf Vollausschlag)<br/>Wenn sich das Zielen nicht wie erwartet verhält, versuche, diesen Wert zu verringern.</p></body></html>"},
             {MenuLangId::Spanish, "<html><head/><body><p><b>Umbral de entrada (zona muerta + salto al máximo)</b>(recomendado: 0.01 [predeterminado] o 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → sin cambios (a=0: desactivado = ignorar todo lo inferior a 1, sin salto al máximo)<br/>Si la puntería no se comporta como esperas, prueba a bajar este valor.</p></body></html>"},
             {MenuLangId::French, "<html><head/><body><p><b>Seuil d'entrée (zone morte + basculement à pleine amplitude)</b>(recommandé : 0.01 [par défaut] ou 0.5) : |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → inchangé (a=0 : désactivé = ignorer toutes les valeurs inférieures à 1, sans basculement à pleine amplitude)<br/>Si la visée ne se comporte pas comme prévu, essayez de baisser cette valeur.</p></body></html>"},
             {MenuLangId::Italian, "<html><head/><body><p><b>Soglia dei comandi (zona morta + scatto)</b>(consigliato: 0.01 [predefinito] o 0.5): |x|&lt;a → 0, a ≤ |x|&lt;1 → ±1, |x|≥1 → invariato (a=0: disattivato = ignora tutto sotto 1, nessuno scatto)<br/>Se la mira non si comporta come previsto, prova ad abbassare questo valore.</p></body></html>"},
@@ -246,7 +246,7 @@
         "lblMetroidLowLatencyAimDesc",
         {
             {MenuLangId::Japanese, "即時同期は低遅延ARM9フックで現在の照準を目標の照準へ同期し、照準基準を再構築します。『Moon』風エイム、大きなジャンプだけ最大ステップ付きで追従します。MPHのエイム補間無効化が必要です。"},
-            {MenuLangId::German, "Sofortige Synchronisation synchronisiert die aktuelle Visierung über einen latenzarmen ARM9-Haken mit dem Ziel und baut die Visierungsbasis neu auf. Zielen im Moon-Stil spiegelt kleine Bewegungen sofort wider und folgt großen Sprüngen nur mit maximaler Schrittweite. Deaktivierung der MPH-Zielglättung erforderlich."},
+            {MenuLangId::German, "Die Sofortsynchronisierung gleicht den aktuellen Zielpunkt über einen ARM9-Hook mit niedriger Latenz an die Zielposition an und erstellt die Zielreferenz neu. Das Zielen im Moon-Stil setzt kleine Bewegungen sofort um und folgt großen Sprüngen nur mit der maximalen Schrittweite. Dafür muss die Zielinterpolation von MPH deaktiviert sein."},
             {MenuLangId::Spanish, "La sincronización inmediata usa un hook de ARM9 de baja latencia para alinear al instante la mira actual con la posición objetivo y reconstruir la referencia de la mira. La puntería de estilo Moon refleja de inmediato los movimientos pequeños y solo sigue los saltos grandes con el paso máximo. Es necesario desactivar la interpolación de la mira de MPH."},
             {MenuLangId::French, "La synchronisation immédiate utilise un hook ARM9 à faible latence pour aligner instantanément la visée actuelle sur la position cible et reconstruire la référence de visée. La visée de style Moon répercute immédiatement les petits mouvements et ne suit les grands écarts qu’à hauteur du pas maximal. L’interpolation de la visée de MPH doit être désactivée."},
             {MenuLangId::Italian, "La sincronizzazione immediata allinea la mira attuale al bersaglio tramite un gancio ARM9 a bassa latenza e ricostruisce la base di mira. Mira in stile Moon riflette subito i piccoli movimenti e segue i grandi salti solo con passo massimo. Richiede la disattivazione dell'interpolazione mira MPH."},
@@ -1299,7 +1299,7 @@
         "lblMetroidDisableDoubleDamageMultiplierDesc",
         {
             {MenuLangId::Japanese, "<html><body>\nダブルダメージの取得、タイマー、HUD、サウンド、視覚効果はそのままに、ダメージ倍率だけを2倍から1倍へ変更します。<br><br>\n<font color=\"red\"><b>重要:</b> 2倍 → 1倍の変更は<b>自分側</b>にだけ適用されます。相手側もダメージ1倍を有効にしていない場合、ダブルダメージ中の自分の弾は相手には2倍ダメージとして扱われます。</font><br><br>\n参加者全員の同意がある場合にだけ使用してください。\n</body></html>"},
-            {MenuLangId::German, "<html><body>\nBehält das Aufnehmen, den Timer, das HUD, den Sound und die visuellen Effekte des Doppelschadens bei, ändert aber nur den Schadensmultiplikator von 2× auf 1×.\n<br><br>\n<font color=\"red\"><b>Wichtig:</b> Die Änderung 2× → 1× gilt nur <b>auf deiner Seite</b>. Wenn der Gegner den 1×-Schaden nicht aktiviert hat, zählen deine Kugeln während Doppelschaden für ihn weiter als 2×.</font>\n<br><br>\nNur mit Zustimmung aller Teilnehmer verwenden.\n</body></html>"},
+            {MenuLangId::German, "<html><body>\nBehält das Aufnehmen von Doppelschaden, den Timer, das HUD, den Sound und die visuellen Effekte bei, ändert jedoch nur den Schadensmultiplikator von 2× auf 1×.\n<br><br>\n<font color=\"red\"><b>Wichtig:</b> Die Änderung von 2× auf 1× gilt nur lokal <b>auf deiner Seite</b>. Wenn der Gegner den 1×-Schaden nicht aktiviert hat, werden deine Schüsse während Doppelschaden auf seiner Seite weiterhin als 2× gewertet.</font>\n<br><br>\nNur mit Zustimmung aller Teilnehmer verwenden.\n</body></html>"},
             {MenuLangId::Spanish, "<html><body>\nMantiene la recogida, el temporizador, el HUD, el sonido y los efectos visuales del doble daño, pero cambia solo el multiplicador de 2× a 1×.\n<br><br>\n<font color=\"red\"><b>Importante:</b> el cambio 2× → 1× solo se aplica <b>de tu lado</b>. Si el rival no tiene activado el daño 1×, tus disparos mientras está activo el doble daño seguirán contando como 2× para él.</font>\n<br><br>\nÚsalo solo con el consentimiento de todos los participantes.\n</body></html>"},
             {MenuLangId::French, "<html><body>\nConserve le ramassage, le minuteur, le HUD, le son et les effets visuels des dégâts doubles, mais ne modifie que le multiplicateur de dégâts, de 2× à 1×.\n<br><br>\n<font color=\"red\"><b>Important :</b> le passage de 2× à 1× s’applique <b>uniquement de votre côté</b>. Si l’adversaire n’a pas activé les dégâts à 1×, vos tirs pendant que les dégâts doubles sont actifs compteront toujours comme 2× pour lui.</font>\n<br><br>\nUtilisez cette option uniquement avec l’accord de tous les participants.\n</body></html>"},
             {MenuLangId::Italian, "<html><body>\nMantiene l’ottenimento, il timer, l’HUD, il suono e gli effetti visivi del doppio danno, ma cambia solo il moltiplicatore da 2× a 1×.\n<br><br>\n<font color=\"red\"><b>Importante:</b> la modifica 2× → 1× si applica solo <b>dal tuo lato</b>. Se l'avversario non ha attivato il danno 1×, i tuoi colpi durante il doppio danno conteranno ancora come 2× per lui.</font>\n<br><br>\nUsalo solo con il consenso di tutti i partecipanti.\n</body></html>"},
@@ -1380,7 +1380,7 @@
         "lblMetroidDamageNotifyPurpleDesc",
         {
             {MenuLangId::Japanese, "<html><body>\nダメージを受けたときに短時間だけダブルダメージの紫状態で点滅させ、相手から被弾が見えるようにします。<br><br>\n<font color=\"red\"><b>重要:</b> これは実際のダブルダメージタイマーを書き込むため、短い間だけ本当に<b>ダブルダメージ状態に入ります</b>。その間、自分の弾は相手にも2倍ダメージを与えます。これを避けるには相手側もダメージ1倍を有効にする必要があります。</font><br><br>\n<b>対戦で使う前に、必ず参加者全員の同意を取ってください。</b> 自分のダメージを1倍に保つには、上の「ダブルダメージ倍率を無効化」と組み合わせてください。\n</body></html>"},
-            {MenuLangId::German, "<html><body>\nLässt dich kurz im lila Doppelschaden-Zustand blinken, wenn du Schaden nimmst, damit Gegner Treffer sehen.\n<br><br>\n<font color=\"red\"><b>Wichtig:</b> Dies schreibt den echten Doppelschaden-Timer und setzt dich kurz wirklich in den <b>Doppelschaden-Zustand</b>. In dieser Zeit verursachen deine Kugeln beim Gegner 2× Schaden. Um das zu vermeiden, muss der Gegner ebenfalls den 1×-Schaden aktivieren.</font>\n<br><br>\n<b>Hole vor dem Online-Einsatz die Zustimmung aller Teilnehmer ein.</b> Kombiniere mit „Doppelschaden-Multiplikator deaktivieren“ oben, um deinen Schaden bei 1× zu halten.\n</body></html>"},
+            {MenuLangId::German, "<html><body>\nLässt dich bei erlittenem Schaden kurz im violetten Doppelschaden-Zustand aufleuchten, damit der Gegner den Treffer erkennt.\n<br><br>\n<font color=\"red\"><b>Wichtig:</b> Diese Option schreibt einen Wert in den tatsächlichen Doppelschaden-Timer und versetzt dich dadurch tatsächlich kurzzeitig in den <b>Doppelschaden-Zustand</b>. Während dieser Zeit verursachen deine Schüsse beim Gegner 2× Schaden. Um das zu verhindern, muss der Gegner ebenfalls den 1×-Schaden aktivieren.</font>\n<br><br>\n<b>Hole vor der Verwendung in Online-Partien die Zustimmung aller Teilnehmer ein.</b> Kombiniere diese Option mit „Doppelschaden-Multiplikator deaktivieren“ oben, damit dein Schaden bei 1× bleibt.\n</body></html>"},
             {MenuLangId::Spanish, "<html><body>\nHace que parpadees brevemente en el estado púrpura de doble daño cuando recibes daño, para que el rival vea el impacto.\n<br><br>\n<font color=\"red\"><b>Importante:</b> esto escribe en el temporizador real del doble daño y te introduce brevemente en el <b>estado de doble daño</b>. Durante ese tiempo, tus disparos infligen 2× de daño al rival. Para evitarlo, el rival también debe activar el daño 1×.</font>\n<br><br>\n<b>Antes de usarlo en una partida, obtén el consentimiento de todos los participantes.</b> Combínalo con «Desactivar multiplicador de doble daño» de arriba para mantener tu daño en 1×.\n</body></html>"},
             {MenuLangId::French, "<html><body>\nVous fait brièvement clignoter dans l’état violet des dégâts doubles lorsque vous subissez des dégâts, pour que l'adversaire voie l'impact.\n<br><br>\n<font color=\"red\"><b>Important :</b> cette option modifie directement le véritable minuteur des dégâts doubles et vous place réellement, pendant un court instant, en <b>état de dégâts doubles</b>. Pendant ce temps, vos tirs infligent des dégâts multipliés par 2 à l’adversaire. Pour l'éviter, l’adversaire doit lui aussi activer les dégâts à 1×.</font>\n<br><br>\n<b>Avant de l’utiliser dans une partie, obtenez l’accord de tous les participants.</b> Associez cette option à « Désactiver le multiplicateur des dégâts doubles » ci-dessus pour garder vos dégâts à 1×.\n</body></html>"},
             {MenuLangId::Italian, "<html><body>\nTi fa lampeggiare brevemente nello stato viola del doppio danno quando subisci danni, così l'avversario vede l'impatto.\n<br><br>\n<font color=\"red\"><b>Importante:</b> scrive il timer reale del doppio danno e ti mette brevemente nello <b>stato di doppio danno</b>. In quel periodo, i tuoi colpi infliggono 2× danni all'avversario. Per evitarlo, anche l'avversario deve attivare il danno 1×.</font>\n<br><br>\n<b>Prima di usarlo online, ottieni il consenso di tutti.</b> Combinalo con «Disattiva moltiplicatore del doppio danno» sopra per mantenere il tuo danno a 1×.\n</body></html>"},
@@ -1542,7 +1542,7 @@
         "lblMetroidJoy2KeySupportDesc",
         {
             {MenuLangId::Japanese, "JoyToKey、Steam Input、reWASD など、外部のコントローラー→キーボード/マウス変換ツール向けの互換モードです。割り当てたボタンが離した後も押されっぱなしになる場合に役立ちます。通常のキーボードとマウスを直接使う場合は、無効にすると入力遅延が少し減ることがあります。"},
-            {MenuLangId::German, "Kompatibilitätsmodus für externe Controller-zu-Tastatur/Maus-Tools wie JoyToKey, Steam Input oder reWASD. Hilft, wenn zugewiesene Tasten nach dem Loslassen hängen bleiben. Bei direkter Nutzung von Tastatur und Maus kann die Deaktivierung die Eingabeverzögerung leicht reduzieren."},
+            {MenuLangId::German, "Kompatibilitätsmodus für externe Programme, die Controller-Eingaben in Tastatur-/Mauseingaben umwandeln, z. B. JoyToKey. Nützlich, wenn zugewiesene Tasten nach dem Loslassen gedrückt bleiben. Bei direkter Verwendung von Tastatur und Maus kann das Deaktivieren dieser Option die Eingabeverzögerung geringfügig verringern."},
             {MenuLangId::Spanish, "Modo de compatibilidad para herramientas externas de mando→teclado/ratón como JoyToKey, Steam Input o reWASD. Útil si los botones asignados quedan pulsados tras soltarlos. Al usar directamente el teclado y el ratón, desactivarlo puede reducir ligeramente la latencia de entrada."},
             {MenuLangId::French, "Mode de compatibilité pour les outils externes manette→clavier/souris comme JoyToKey, Steam Input ou reWASD. Utile si les boutons assignés restent enfoncés après relâchement. Lors de l’utilisation directe du clavier et de la souris, sa désactivation peut réduire légèrement la latence d’entrée."},
             {MenuLangId::Italian, "Modalità di compatibilità per strumenti esterni che convertono controller→tastiera/mouse come JoyToKey, Steam Input o reWASD. Utile se i pulsanti assegnati restano premuti dopo il rilascio. Con tastiera e mouse usati direttamente, disattivarla può ridurre leggermente la latenza di input."},
@@ -1623,7 +1623,7 @@
         "labelMetroidScreenSyncDesc",
         {
             {MenuLangId::Japanese, "オフ: 同期なし (最小遅延ですが、表示がカクつくことがあります)。glFinish: 各フレームの描画完了を待つことで表示を滑らかにします。DwmFlush: Windowsコンポジターと同期して表示を滑らかにします (Windowsのみ)。画面がカクついたりちらついたりする場合は、glFinish または DwmFlush を試してください。早送り/スローモーション中は自動的に無効になります。"},
-            {MenuLangId::German, "Aus: keine Synchronisation (geringste Latenz, Anzeige kann ruckeln). glFinish: glattere Anzeige durch Warten auf den Abschluss jedes Frames. DwmFlush: Synchronisation mit dem Windows-Kompositor (nur Windows). Bei Ruckeln oder Flackern glFinish oder DwmFlush testen. Wird bei Vorspulen/Zeitlupe automatisch deaktiviert."},
+            {MenuLangId::German, "<html><body>Aus: keine Synchronisierung (niedrigste Latenz, aber das Bild kann ruckeln).<br>glFinish: sorgt für ein flüssigeres Bild, indem auf die Fertigstellung jedes Frames gewartet wird.<br>DwmFlush: synchronisiert mit dem Windows-Compositor (nur unter Windows).<br>Bei Ruckeln oder Flackern glFinish oder DwmFlush ausprobieren.<br>Wird während des Schnellvorlaufs oder der Zeitlupe automatisch deaktiviert.</body></html>"},
             {MenuLangId::Spanish, "Desactivado: sin sincronización (latencia mínima, pero la imagen puede entrecortarse). glFinish: ofrece una imagen más fluida al esperar a que termine cada fotograma. DwmFlush: sincroniza con el compositor de Windows (solo Windows). Si hay tirones o parpadeos, prueba glFinish o DwmFlush. Se desactiva automáticamente durante el avance rápido o la cámara lenta."},
             {MenuLangId::French, "Désactivé : aucune synchronisation (latence minimale, mais l’affichage peut être saccadé). glFinish : offre un affichage plus fluide en attendant la fin du rendu de chaque image. DwmFlush : synchronise avec le compositeur Windows (Windows uniquement). En cas de saccades ou de scintillement, essayez glFinish ou DwmFlush. Se désactive automatiquement pendant l’avance rapide ou le ralenti."},
             {MenuLangId::Italian, "Disattivato: nessuna sincronizzazione (latenza minima, ma l’immagine può scattare). glFinish: immagine più fluida attendendo il completamento di ogni fotogramma. DwmFlush: sincronizza con il compositore Windows (solo Windows). In caso di scatti o sfarfallio, prova glFinish o DwmFlush. Si disattiva automaticamente in avanzamento rapido/rallentatore."},
@@ -2028,7 +2028,7 @@
         "lblMetroidWeaponSwitchMethodDesc",
         {
             {MenuLangId::Japanese, "オン: ARM9フックでゲーム本来の武器装備処理を使います。オフ: 互換性テスト用に従来のタッチ/メニュー模擬を使います。"},
